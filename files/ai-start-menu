# setup-module: ai-menu
# setup-version: 2026.06.06.1
# setup-source: files/ai-start-menu

ai() {
    local choice current_host
    local -a options ssh_hosts
    current_host=$(hostname)
    local current_aliases=("$current_host" "${current_host%%.*}" "${current_host%%.*}.local")
    options=(claude codex opencode)

    if [[ -f ~/.ssh/config ]]; then
        ssh_hosts=( $(grep -E "^Host " ~/.ssh/config | awk '{print $2}') )
        for h in "${ssh_hosts[@]}"; do
            [[ "$h" != "*" ]] && (( ${current_aliases[(I)$h]} == 0 )) && options+=("$h")
        done
    fi

    options+=(resume neither)

    choice=$(printf '%s\n' "${options[@]}" | fzf --height=15 --reverse --border \
        --header="current machine: ${current_host}" --pointer='▌' --prompt='▌ ' --cycle)

    case "$choice" in
        claude) claude ;;
        codex)
            local npm_prefix
            npm_prefix=$(npm config get prefix 2>/dev/null)
            if [[ -n "$npm_prefix" && -x "$npm_prefix/bin/codex" ]]; then
                "$npm_prefix/bin/codex"
            else
                codex
            fi
            ;;
        opencode) OPENCODE_ENABLE_EXA=1 opencode ;;
        resume) resume ;;
        neither|"") ;;
        *) ssh "$choice" ;;
    esac
}
