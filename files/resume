#!/usr/bin/env bash
# setup-module: resume
# setup-source: files/resume
# resume - interactively pick and resume a Claude Code, Codex, OpenCode, or ForgeCode session

set -euo pipefail

usage() {
    cat <<'EOF'
Usage: resume [--help]

  Interactively pick and resume a Claude Code, Codex, OpenCode, or
  ForgeCode session via fzf.

  Without arguments, opens an fzf picker of recent sessions. Selecting
  a session resumes it with the appropriate tool.

  help    Show this message
EOF
}

case "${1:-}" in
    help|--help|-h) usage; exit 0 ;;
esac

CLAUDE_DIR="$HOME/.claude/projects"
CODEX_DIR="$HOME/.codex/sessions"
OC_DB="$HOME/.local/share/opencode/opencode.db"
FG_DB="$HOME/.forge/.forge.db"
MAX_SESSIONS=100
# Only the newest SCAN_LIMIT files per source get the expensive per-file jq
# extraction; the merged list is then trimmed to MAX_SESSIONS. Without this the
# scan is O(all sessions ever created) and stalls for tens of seconds silently
# on large histories (looks like a hang before the picker appears).
SCAN_LIMIT=$((MAX_SESSIONS * 2))

case "$(uname -s)" in
    Darwin)
        STAT_EXEC=(-exec stat -f '%m %N' {} +)
        DATE_FLAVOR=bsd
        ;;
    *)
        STAT_EXEC=(-exec stat -c '%Y %n' {} +)
        DATE_FLAVOR=gnu
        ;;
esac

format_epoch() {
    local ts="$1"
    case "$DATE_FLAVOR" in
        bsd) date -r "$ts" "+%m/%d %H:%M" ;;
        gnu) date -d "@$ts" "+%m/%d %H:%M" ;;
    esac
}

_cc_first_msg() {
    grep -m5 '"role":"user"' "$1" 2>/dev/null \
    | jq -r 'select(.message.content != null)
             | .message.content
             | if type == "array" then (.[0].text // "") else . end
             | select(. != null and (startswith("<") | not))
             | .' 2>/dev/null \
    | head -1
}

_cc_is_print_session() {
    local meta entrypoint prompt_source
    meta=$(jq -r 'select(.type == "user" and .message.role == "user")
                  | [.entrypoint // "", .promptSource // ""]
                  | @tsv' "$1" 2>/dev/null | head -1) || return 1
    [[ -n "$meta" ]] || return 1
    IFS=$'\t' read -r entrypoint prompt_source <<< "$meta"
    [[ "$entrypoint" == "sdk-cli" || "$prompt_source" == "sdk" ]]
}

_cx_first_msg() {
    grep '"role":"user"' "$1" 2>/dev/null \
    | jq -r 'select(.type == "response_item")
             | .payload.content[]
             | select(.type == "input_text")
             | .text
             | select(startswith("#") or startswith("<") or (length > 300) | not)' 2>/dev/null \
    | head -1
}

_cc_proj_path() {
    local proj="$1"
    local rest="${proj#-}"
    echo "/${rest//-//}"
}

# The project dir name encodes both '/' and literal '-' as '-', so decoding it
# is ambiguous (e.g. 'repo-template' becomes 'repo/template'). The session
# JSONL stores the real cwd, so prefer that and only fall back to the decode.
_cc_cwd() {
    grep -m1 '"cwd":' "$1" 2>/dev/null | jq -r '.cwd // empty' 2>/dev/null | head -1
}

collect_sessions() {
    if [[ -d "$CLAUDE_DIR" ]]; then
        find "$CLAUDE_DIR" -maxdepth 2 -type f -name '*.jsonl' "${STAT_EXEC[@]}" 2>/dev/null \
        | sort -rn | head -n "$SCAN_LIMIT" \
        | while read -r mtime f; do
            id=$(basename "$f" .jsonl)
            [[ "$id" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]] || continue
            cwd=$(_cc_cwd "$f")
            [[ -n "$cwd" ]] || cwd=$(_cc_proj_path "$(basename "$(dirname "$f")")")
            [[ "$cwd" == *"CodexBar"* ]] && continue
            _cc_is_print_session "$f" && continue
            # claudex runs the claude binary through the codex proxy, so its
            # sessions land here indistinguishable from native claude ones
            # except that assistant turns record model "claudex-proxy". Tag
            # those so resume relaunches them on the codex backend, not bare
            # claude (which would resume on the Anthropic subscription).
            tag=cc
            grep -m1 -q '"model":"claudex-proxy"' "$f" 2>/dev/null && tag=clx
            msg=$(_cc_first_msg "$f")
            echo "$mtime|$tag|$id|$cwd|${msg:-}"
        done || true
    fi

    if [[ -d "$CODEX_DIR" ]]; then
        find "$CODEX_DIR" -type f -name "rollout-*.jsonl" "${STAT_EXEC[@]}" 2>/dev/null \
        | sort -rn | head -n "$SCAN_LIMIT" \
        | while read -r mtime f; do
            id=$(basename "$f" .jsonl | sed 's/^rollout-[0-9T-]\{19\}-//')
            meta=$(head -1 "$f" 2>/dev/null)
            src=$(echo "$meta" | jq -r '.payload.thread_source // ""' 2>/dev/null)
            [[ "$src" == "subagent" ]] && continue
            cwd=$(echo "$meta" | jq -r '.payload.cwd // ""' 2>/dev/null || echo "")
            msg=$(_cx_first_msg "$f")
            echo "$mtime|cx|$id|$cwd|${msg:-}"
        done || true
    fi

    if [[ -f "$OC_DB" ]]; then
        python3 - "$OC_DB" "$HOME" << 'PYEOF'
import sqlite3, sys
db, home = sys.argv[1], sys.argv[2]
conn = sqlite3.connect(db)
for sid, title, directory, ts_ms in conn.execute(
    "SELECT id, title, directory, time_updated FROM session "
    "WHERE parent_id IS NULL ORDER BY time_updated DESC LIMIT 100"
):
    ts = ts_ms // 1000
    cwd = directory or home
    print(f"{ts}|oc|{sid}|{cwd}|{title or ''}")
conn.close()
PYEOF
    fi

    if [[ -f "$FG_DB" ]]; then
        python3 - "$FG_DB" "$HOME" << 'PYEOF'
import sqlite3, sys, json, re
from datetime import datetime, timezone
db, home = sys.argv[1], sys.argv[2]
conn = sqlite3.connect(db)
for cid, title, updated_at, context in conn.execute(
    "SELECT conversation_id, title, updated_at, context FROM conversations ORDER BY updated_at DESC LIMIT 100"
):
    try:
        ts = int(datetime.strptime(updated_at.split('.')[0], "%Y-%m-%d %H:%M:%S").replace(tzinfo=timezone.utc).timestamp())
    except Exception:
        ts = 0
    cwd, msg = None, title or ""
    if context:
        try:
            for m in json.loads(context).get("messages", []):
                text = m.get("message", {}).get("text", {})
                content = text.get("content", "")
                role = text.get("role", "")
                if role == "System" and cwd is None and isinstance(content, str):
                    match = re.search(r'<current_working_directory>(.*?)</current_working_directory>', content)
                    if match:
                        cwd = match.group(1)
                if not msg and role == "User":
                    if isinstance(content, list):
                        content = next((c["text"] for c in content if isinstance(c, dict) and c.get("type") == "text"), "")
                    if isinstance(content, str):
                        task = re.search(r'<task>(.*?)</task>', content, re.DOTALL)
                        msg = ' '.join((task.group(1) if task else re.sub(r'<[^>]+>', '', content)).split())
        except Exception:
            pass
    cwd = cwd or home
    print(f"{ts}|fg|{cid}|{cwd}|{msg}")
conn.close()
PYEOF
    fi
}

format_for_fzf() {
    while IFS='|' read -r ts tool id cwd msg; do
        date_str=$(format_epoch "$ts" 2>/dev/null || echo "??/?? ??:??")
        case "$tool" in
            cc) label="claude  " ;;
            clx) label="claudex " ;;
            cx) label="codex   " ;;
            oc) label="opencode" ;;
            fg) label="forge   " ;;
        esac
        display_cwd=$(echo "$cwd" | sed "s|^$HOME|~|")
        printf "%s  %s  %-22s  %s\t%s|%s|%s\n" \
            "$date_str" "$label" "${display_cwd:0:22}" "$msg" "$tool" "$id" "$cwd"
    done
}

selected=$(collect_sessions | sort -rn | head -n "$MAX_SESSIONS" | format_for_fzf | \
    fzf --no-sort \
        --reverse \
        --height=50% \
        --min-height=8 \
        --with-nth=1 \
        --delimiter=$'\t' \
        --prompt="resume > " \
        --header="ENTER: resume   ESC: cancel")

[[ -z "$selected" ]] && exit 0

ref=$(printf '%s' "$selected" | cut -f2)
tool=$(echo "$ref" | cut -d'|' -f1)
id=$(echo "$ref" | cut -d'|' -f2)
session_cwd=$(echo "$ref" | cut -d'|' -f3-)

if [[ "$tool" != "cx" && -n "$session_cwd" && "$session_cwd" != "$PWD" ]]; then
    if ! cd "$session_cwd" 2>/dev/null; then
        echo "Warning: session dir '$session_cwd' not accessible, staying in $PWD" >&2
    fi
fi

echo "Resuming $tool session $id..."

case "$tool" in
    cc) harness=claude; resume_args=(--resume "$id") ;;
    clx) harness=claudex; resume_args=(run codex --config "$HOME/.config/claudex/config.toml" --resume "$id") ;;
    cx) harness=codex; resume_args=(resume "$id") ;;
    oc) harness=opencode; resume_args=(--session "$id") ;;
    fg) harness=forge; resume_args=(--conversation-id "$id") ;;
    *) exit 0 ;;
esac

if [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
    tmux rename-window -- "$harness" || true
fi

exec "$harness" "${resume_args[@]}"
