#!/usr/bin/env python3
# setup-module: refresh-models
# setup-source: files/refresh-models
"""refresh-models — probe /v1/models endpoints and update opencode.json provider blocks.

Commands:
  (no args)        Refresh all configured servers
  <server>         Refresh a single server by name
  --list           List configured server names
  enable           Install systemd user timer (runs hourly)
  disable          Remove systemd user timer
  status           Show timer state and next run
"""

import json, os, sys, urllib.request, urllib.error, subprocess, pathlib, getpass

CONFIG_PATH = os.path.expanduser("~/.config/opencode/refresh-models.json")
OPENCODE_PATH = os.path.expanduser("~/.config/opencode/opencode.json")
ZSENV_PATH = os.path.expanduser("~/.zshenv")
SERVICE_DIR = os.path.expanduser("~/.config/systemd/user")
OLD_AUTH_PATH = os.path.expanduser("~/.local/share/opencode/auth.json")

AUTH_BLOCK_BEGIN = "# BEGIN setup:api-keys"
AUTH_BLOCK_END = "# END setup:api-keys"

SERVICE_UNIT = """[Unit]
Description=Refresh opencode model list from configured providers

[Service]
Type=oneshot
EnvironmentFile=-%%h/.zshenv
ExecStart=%s
"""

TIMER_UNIT = """[Unit]
Description=Hourly refresh-models check

[Timer]
OnCalendar=hourly
Persistent=true

[Install]
WantedBy=timers.target
"""


def load_json(path):
    with open(path) as f:
        return json.load(f)


def save_json(path, data):
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")


def _env_name(provider):
    return f"{provider.replace('-', '_').upper()}_API_KEY"


def _oauth_env_name(provider):
    return f"{provider.replace('-', '_').upper()}_OAUTH_TOKEN"


def _provider_from_env(env_name):
    if env_name.endswith("_API_KEY"):
        return env_name[:-8].lower().replace("_", "-")
    if env_name.endswith("_OAUTH_TOKEN"):
        return env_name[:-12].lower().replace("_", "-")
    return ""


def _source_zsenv():
    """Export .zshenv api-keys block into os.environ (for launchd/cron contexts)."""
    if not os.path.exists(ZSENV_PATH):
        return
    in_block = False
    with open(ZSENV_PATH) as f:
        for line in f:
            s = line.strip()
            if s == AUTH_BLOCK_BEGIN:
                in_block = True
                continue
            if s == AUTH_BLOCK_END:
                in_block = False
                continue
            if in_block and s.startswith("export ") and "=" in s:
                kv = s[len("export "):]
                name, _, val = kv.partition("=")
                if name and val:
                    os.environ[name] = val


def _export_auth_to_zsenv():
    """One-way sync: auth.json → .zshenv. Called on enable/auth to surface
    keys set by opencode's /connect command."""
    if not os.path.exists(OLD_AUTH_PATH):
        return
    try:
        old = load_json(OLD_AUTH_PATH)
    except Exception:
        return
    if not isinstance(old, dict) or not old:
        return

    lines = []
    for provider, entry in old.items():
        if not isinstance(entry, dict):
            continue
        etype = entry.get("type", "")
        if etype == "api":
            key = entry.get("key", "")
            if key and isinstance(key, str) and key.strip():
                env_name = _env_name(provider)
                lines.append(f"export {env_name}={key.strip()}")
        elif etype == "oauth":
            access = entry.get("access", "")
            if access and isinstance(access, str):
                env_name = _oauth_env_name(provider)
                lines.append(f"export {env_name}={access}")

    if not lines:
        return

    _write_env_block(lines)
    print(f"Exported {len(lines)} key(s) from {OLD_AUTH_PATH} to {ZSENV_PATH}")


def _sync_zsenv_to_auth():
    """Ensure auth.json reflects the current .zshenv api-keys block.
    Never deletes entries that exist only in auth.json."""
    block = _read_env_block()
    if not block:
        return

    existing = {}
    if os.path.exists(OLD_AUTH_PATH):
        try:
            existing = load_json(OLD_AUTH_PATH)
        except Exception:
            pass
    if not isinstance(existing, dict):
        existing = {}

    updated = False
    for env_name, value in block.items():
        provider = _provider_from_env(env_name)
        if not provider:
            continue
        if env_name.endswith("_API_KEY"):
            if provider not in existing or existing.get(provider, {}).get("key") != value:
                existing[provider] = {"type": "api", "key": value}
                updated = True
        elif env_name.endswith("_OAUTH_TOKEN"):
            if provider not in existing or existing.get(provider, {}).get("access") != value:
                existing.setdefault(provider, {})["type"] = "oauth"
                existing[provider]["access"] = value
                updated = True

    if updated:
        pathlib.Path(os.path.dirname(OLD_AUTH_PATH)).mkdir(parents=True, exist_ok=True)
        save_json(OLD_AUTH_PATH, existing)


def _read_env_block():
    if not os.path.exists(ZSENV_PATH):
        return {}
    keys = {}
    in_block = False
    with open(ZSENV_PATH) as f:
        for line in f:
            if line.strip() == AUTH_BLOCK_BEGIN:
                in_block = True
                continue
            if line.strip() == AUTH_BLOCK_END:
                in_block = False
                continue
            if in_block:
                line = line.strip()
                if line.startswith("export ") and "=" in line:
                    kv = line[len("export "):]
                    name, _, val = kv.partition("=")
                    keys[name] = val
    return keys


def _reconstruct_auth_json():
    if os.path.exists(OLD_AUTH_PATH):
        return
    block = _read_env_block()
    if not block:
        return
    data = {}
    for env_name, value in block.items():
        if env_name.endswith("_API_KEY"):
            provider = env_name[:-8].lower().replace("_", "-")
            data[provider] = {"type": "api", "key": value}
        elif env_name.endswith("_OAUTH_TOKEN"):
            provider = env_name[:-12].lower().replace("_", "-")
            data[provider] = {"type": "oauth", "access": value}
    if not data:
        return
    pathlib.Path(os.path.dirname(OLD_AUTH_PATH)).mkdir(parents=True, exist_ok=True)
    save_json(OLD_AUTH_PATH, data)
    print(f"Reconstructed {OLD_AUTH_PATH} from {ZSENV_PATH} ({len(data)} provider(s))")


def _fallback_auth_json(provider):
    if not os.path.exists(OLD_AUTH_PATH):
        return ""
    try:
        data = load_json(OLD_AUTH_PATH)
    except Exception:
        return ""
    if not isinstance(data, dict):
        return ""
    entry = data.get(provider, {})
    if not isinstance(entry, dict):
        return ""
    etype = entry.get("type", "")
    if etype == "api":
        return entry.get("key", "")
    if etype == "oauth":
        return entry.get("access", "")
    return ""


def _write_env_block(lines):
    ensure_block = False
    existing = []
    if os.path.exists(ZSENV_PATH):
        in_block = False
        with open(ZSENV_PATH) as f:
            for line in f:
                stripped = line.strip()
                if stripped == AUTH_BLOCK_BEGIN:
                    in_block = True
                    continue
                if stripped == AUTH_BLOCK_END:
                    in_block = False
                    continue
                if not in_block:
                    existing.append(line)
                # drop old block lines
        ensure_block = True
    else:
        ensure_block = True

    with open(ZSENV_PATH, "w") as f:
        for line in existing:
            f.write(line)
        if ensure_block:
            f.write(f"\n{AUTH_BLOCK_BEGIN}\n")
            for l in lines:
                f.write(l + "\n")
            f.write(f"{AUTH_BLOCK_END}\n")


def get_auth(auth_cfg):
    if auth_cfg is None:
        return None, None
    atype = auth_cfg.get("type")
    if atype == "auth_json":
        provider = auth_cfg.get("provider", "")
        key = os.environ.get(_env_name(provider), "")
        if not key:
            key = _fallback_auth_json(provider)
        if key:
            return "api_key", key
    elif atype == "api_key":
        return "api_key", auth_cfg["key"]
    elif atype == "bearer":
        return "bearer", auth_cfg["key"]
    return None, None


def as_number(value, default=0):
    if value is None:
        return default
    if isinstance(value, (int, float)):
        return value
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def as_int(value, default):
    number = as_number(value, default)
    try:
        return int(number)
    except (TypeError, ValueError):
        return default


def fetch_models(base_url, auth_cfg):
    url = base_url.rstrip("/") + "/models"
    req = urllib.request.Request(url)
    req.add_header("Accept", "application/json")
    req.add_header("User-Agent", "refresh-models/1.0")
    auth_type, auth_val = get_auth(auth_cfg)
    if auth_type in ("api_key", "bearer"):
        req.add_header("Authorization", f"Bearer {auth_val}")
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(f"  HTTP {e.code} fetching {url}", file=sys.stderr)
        return None
    except Exception as e:
        print(f"  Error fetching {url}: {e}", file=sys.stderr)
        return None


def model_to_config_grimoire(m):
    cost = m.get("cost", {})
    return {
        "limit": {
            "context": as_int(m.get("context"), 32768),
            "output": as_int(m.get("output"), 16384),
        },
        "cost": {
            "input": as_number(cost.get("input")),
            "output": as_number(cost.get("output")),
            "cache_read": as_number(cost.get("cache_read")),
        },
    }


def model_to_config_crofai(m):
    pricing = m.get("pricing", {})
    return {
        "limit": {
            "context": as_int(m.get("context_length"), 32768),
            "output": as_int(m.get("max_completion_tokens"), 16384),
        },
        "cost": {
            "input": as_number(pricing.get("prompt")),
            "output": as_number(pricing.get("completion")),
            "cache_read": as_number(pricing.get("cache_prompt")),
        },
    }


def model_to_config_openai(m):
    return {
        "limit": {
            "context": m.get("context_length", 32768),
            "output": m.get("max_completion_tokens", 16384),
        },
        "cost": {"input": 0, "output": 0, "cache_read": 0},
    }


FORMAT_HANDLERS = {
    "grimoire": model_to_config_grimoire,
    "crofai": model_to_config_crofai,
    "openai": model_to_config_openai,
}


def _grimoire_url():
    import socket
    host = socket.gethostname()
    if "grimoire" in host.lower():
        return "http://localhost:9001/v1"
    return "https://chat.lost.plus/v1"


def refresh_server(name, cfg):
    base_url = cfg["baseURL"]
    if name == "grimoire":
        base_url = _grimoire_url()
    fmt = cfg.get("api_format", "openai")
    handler = FORMAT_HANDLERS.get(fmt, FORMAT_HANDLERS["openai"])
    npm = cfg.get("npm", "@ai-sdk/openai-compatible")
    print(f"  {name} ({base_url}) ...", file=sys.stderr)
    resp = fetch_models(base_url, cfg.get("auth"))
    if resp is None:
        return False
    models_list = resp.get("data", resp.get("models", []))
    if not models_list:
        print(f"  Warning: no models returned for {name}", file=sys.stderr)
        return False
    models = {}
    for m in models_list:
        model_id = m.get("id", "")
        if not model_id:
            continue
        models[model_id] = handler(m)
    opencode = load_json(OPENCODE_PATH) if os.path.exists(OPENCODE_PATH) else {}
    provider_block = opencode.get("provider", {})
    existing = provider_block.setdefault(name, {})
    existing["npm"] = npm
    existing["name"] = name
    if "options" not in existing:
        existing["options"] = {"baseURL": base_url}
    else:
        existing["options"]["baseURL"] = base_url
    existing["models"] = models
    provider_block[name] = existing
    opencode["provider"] = provider_block
    save_json(OPENCODE_PATH, opencode)
    jsonc_path = OPENCODE_PATH.replace(".json", ".jsonc")
    if jsonc_path != OPENCODE_PATH and os.path.exists(jsonc_path):
        os.remove(jsonc_path)
        print(f"  Removed stale {os.path.basename(jsonc_path)}", file=sys.stderr)
    print(f"  {name}: {len(models)} models updated", file=sys.stderr)
    return True


# --- systemd management ----------------------------------------------


LAUNCHD_DIR = os.path.expanduser("~/Library/LaunchAgents")
PLIST_NAME = "com.lost.plus.refresh-models"


def _is_macos():
    return sys.platform == "darwin"


PROVIDER_URLS = {
    "grimoire": "http://localhost:9001 (self-hosted, no key needed if open)",
    "crofai": "https://crof.ai",
    "commandcode": "https://commandcode.ai/studio → Settings → API Keys",
    "deepseek": "https://platform.deepseek.com/api_keys",
}


def _env_name(provider):
    return f"{provider.replace('-', '_').upper()}_API_KEY"


def _get_key(provider):
    key = os.environ.get(_env_name(provider), "")
    if not key:
        key = _fallback_auth_json(provider)
    return key


def _set_key(provider, key):
    block = _read_env_block()
    block[_env_name(provider)] = key
    lines = [f"export {k}={v}" for k, v in block.items()]
    _write_env_block(lines)
    _sync_zsenv_to_auth()
    print(f"Saved {_env_name(provider)} to {ZSENV_PATH} and {OLD_AUTH_PATH}")


def cmd_auth():
    """Interactive or direct API key onboarding.

    refresh-models auth                     → interactive prompt for all missing keys
    refresh-models auth <provider> <key>    → write key directly (agent-friendly)
    """
    _export_auth_to_zsenv()

    cfg = load_json(CONFIG_PATH) if os.path.exists(CONFIG_PATH) else {"servers": {}}
    servers = cfg.get("servers", {})

    if len(sys.argv) >= 4:
        provider = sys.argv[2]
        key = sys.argv[3]
        if provider not in servers:
            print(f"Unknown provider: {provider}", file=sys.stderr)
            print(f"Known: {', '.join(servers.keys())}", file=sys.stderr)
            sys.exit(1)
        _set_key(provider, key)
        print(f"Wrote {provider.upper()}_API_KEY to {ZSENV_PATH}")
        return

    existing_keys = _read_env_block()
    missing = [s for s in servers if _env_name(s) not in existing_keys]
    configured = [s for s in servers if _env_name(s) in existing_keys]

    if configured:
        print("Configured:")
        for s in configured:
            print(f"  {s}: ✓")
        print()

    if not missing:
        print("All providers have API keys in ~/.zshenv.")
        return

    print("Missing API keys:")
    for s in missing:
        url = PROVIDER_URLS.get(s, "")
        print(f"  {s}" + (f"  — {url}" if url else ""))
    print()

    updated = False
    for s in missing:
        url = PROVIDER_URLS.get(s, "")
        prompt = f"  {s} API key" + (f" ({url})" if url else "") + ": "
        try:
            key = getpass.getpass(prompt)
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if key.strip():
            existing_keys[_env_name(s)] = key.strip()
            updated = True

    if updated:
        lines = [f"export {k}={v}" for k, v in existing_keys.items()]
        _write_env_block(lines)
        _sync_zsenv_to_auth()
        print(f"\nSaved to {ZSENV_PATH}")
    else:
        print("\nNo keys entered.")


def cmd_enable():
    _export_auth_to_zsenv()

    script_path = os.path.abspath(sys.argv[0])
    cfg_dir = os.path.dirname(CONFIG_PATH)
    pathlib.Path(cfg_dir).mkdir(parents=True, exist_ok=True)

    if _is_macos():
        pathlib.Path(LAUNCHD_DIR).mkdir(parents=True, exist_ok=True)
        plist_path = os.path.join(LAUNCHD_DIR, f"{PLIST_NAME}.plist")
        plist = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>{PLIST_NAME}</string>
    <key>ProgramArguments</key>
    <array>
        <string>{script_path}</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Minute</key><integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/refresh-models.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/refresh-models.log</string>
</dict>
</plist>"""
        with open(plist_path, "w") as f:
            f.write(plist)
        _uid = os.getuid()
        subprocess.run(["launchctl", "bootout", f"gui/{_uid}/{PLIST_NAME}"],
                       capture_output=True)
        r = subprocess.run(["launchctl", "bootstrap", f"gui/{_uid}", plist_path],
                           capture_output=True)
        if r.returncode == 0:
            print("refresh-models launchd agent enabled (hourly)")
        else:
            if r.returncode == 125:
                print("no GUI session — log in on the Mac's screen first", file=sys.stderr)
            else:
                print(f"refresh-models installed but launchd enable failed (rc={r.returncode})", file=sys.stderr)
            if r.stderr:
                print(r.stderr.decode().rstrip(), file=sys.stderr)
    else:
        pathlib.Path(SERVICE_DIR).mkdir(parents=True, exist_ok=True)
        with open(os.path.join(SERVICE_DIR, "refresh-models.service"), "w") as f:
            f.write(SERVICE_UNIT % script_path)
        with open(os.path.join(SERVICE_DIR, "refresh-models.timer"), "w") as f:
            f.write(TIMER_UNIT)
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
        subprocess.run(
            ["systemctl", "--user", "enable", "--now", "refresh-models.timer"], check=True
        )
        print("refresh-models timer enabled (hourly)")

    # --- config onboarding ---

    cfg_dir = os.path.dirname(CONFIG_PATH)
    pathlib.Path(cfg_dir).mkdir(parents=True, exist_ok=True)

    default_config = {
        "servers": {
            "grimoire": {
                "baseURL": _grimoire_url(),
                "api_format": "grimoire",
                "npm": "@ai-sdk/openai-compatible",
                "auth": {"type": "auth_json", "provider": "grimoire"},
            },
            "crofai": {
                "baseURL": "https://crof.ai/v1",
                "api_format": "crofai",
                "npm": "@ai-sdk/openai-compatible",
                "auth": {"type": "auth_json", "provider": "crofai"},
            },
            "commandcode": {
                "baseURL": "https://api.commandcode.ai/provider/v1",
                "api_format": "openai",
                "npm": "@ai-sdk/openai-compatible",
                "auth": {"type": "auth_json", "provider": "commandcode"},
            },
        }
    }

    if not os.path.exists(CONFIG_PATH):
        save_json(CONFIG_PATH, default_config)
        print(f"  Wrote default config to {CONFIG_PATH}")

    cfg = load_json(CONFIG_PATH)
    existing = cfg.get("servers", {})
    added = []
    for name, srv in default_config["servers"].items():
        if name not in existing:
            existing[name] = srv
            added.append(name)
    if added:
        cfg["servers"] = existing
        save_json(CONFIG_PATH, cfg)
        print(f"  Added new providers to config: {', '.join(added)}")

    servers = cfg.get("servers", {})
    existing_keys = _read_env_block()
    missing = [s for s in servers if _env_name(s) not in existing_keys]
    if missing:
        print()
        miss_list = ", ".join(missing)
        print(f"  {len(missing)} provider(s) missing API keys: {miss_list}")
        if not sys.stdin.isatty():
            state_home = os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state"))
            marker = os.path.join(state_home, "setup", "refresh-models.needs-auth")
            pathlib.Path(os.path.dirname(marker)).mkdir(parents=True, exist_ok=True)
            with open(marker, "w") as f:
                f.write("\n".join(missing) + "\n")
        else:
            print()
            updated = False
            for s in missing:
                url = PROVIDER_URLS.get(s, "")
                prompt = f"  {s} API key" + (f" ({url})" if url else "") + ": "
                try:
                    key = getpass.getpass(prompt)
                except (EOFError, KeyboardInterrupt):
                    print()
                    break
                if key.strip():
                    existing_keys[_env_name(s)] = key.strip()
                    updated = True
            if updated:
                lines = [f"export {k}={v}" for k, v in existing_keys.items()]
                _write_env_block(lines)
                _sync_zsenv_to_auth()
                print(f"\nSaved to {ZSENV_PATH}")
            else:
                print("  Run: refresh-models auth")


def cmd_disable():
    if _is_macos():
        plist_path = os.path.join(LAUNCHD_DIR, f"{PLIST_NAME}.plist")
        if os.path.exists(plist_path):
            _uid = os.getuid()
            subprocess.run(["launchctl", "bootout", f"gui/{_uid}/{PLIST_NAME}"],
                           capture_output=True)
            os.remove(plist_path)
        print("refresh-models launchd agent disabled")
    else:
        subprocess.run(
            ["systemctl", "--user", "disable", "--now", "refresh-models.timer"],
            capture_output=True,
        )
        for f in ["refresh-models.service", "refresh-models.timer"]:
            p = os.path.join(SERVICE_DIR, f)
            if os.path.exists(p):
                os.remove(p)
        subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
        print("refresh-models timer disabled")


def cmd_status():
    if _is_macos():
        plist_path = os.path.join(LAUNCHD_DIR, f"{PLIST_NAME}.plist")
        if os.path.exists(plist_path):
            result = subprocess.run(
                ["launchctl", "print", f"gui/{os.getuid()}/{PLIST_NAME}"],
                capture_output=True, text=True,
            )
            if result.returncode == 0:
                print("timer: active (launchd hourly)")
            else:
                print("timer: not loaded")
        else:
            print("timer: not installed")
    else:
        result = subprocess.run(
            ["systemctl", "--user", "is-active", "refresh-models.timer"],
            capture_output=True, text=True,
        )
        state = result.stdout.strip()
        if state == "active":
            next_run = subprocess.run(
                ["systemctl", "--user", "show", "-p", "NextElapseUSecRealtime", "refresh-models.timer"],
                capture_output=True, text=True,
            ).stdout.strip().split("=")[-1]
            print(f"timer: active (next: {next_run})")
        else:
            print(f"timer: {state}")
    cfg = load_json(CONFIG_PATH) if os.path.exists(CONFIG_PATH) else {"servers": {}}
    servers = cfg.get("servers", {})
    print(f"servers configured: {len(servers)}")
    existing_keys = _read_env_block()
    for name in servers:
        env_name = _env_name(name)
        status = "key: ✓" if env_name in existing_keys else "key: ✗"
        print(f"  {name}: {servers[name].get('baseURL')}  {status}")


# --- main -------------------------------------------------------------


def main():
    args = sys.argv[1:]

    if not args:
        _source_zsenv()
        _export_auth_to_zsenv()
        _sync_zsenv_to_auth()
        cfg = load_json(CONFIG_PATH) if os.path.exists(CONFIG_PATH) else {}
        servers = cfg.get("servers", {})
        for name, srv_cfg in servers.items():
            refresh_server(name, srv_cfg)
        return

    cmd = args[0]

    if cmd == "--list":
        cfg = load_json(CONFIG_PATH) if os.path.exists(CONFIG_PATH) else {"servers": {}}
        for name in cfg.get("servers", {}):
            print(name)
        return

    if cmd == "enable":
        cmd_enable()
        return

    if cmd == "disable":
        cmd_disable()
        return

    if cmd == "status":
        cmd_status()
        return

    if cmd == "auth":
        cmd_auth()
        return

    if cmd in ("--help", "-h", "help"):
        print("refresh-models — probe /v1/models and update opencode.json")
        print()
        print("Usage:")
        print("  refresh-models              Refresh all configured servers")
        print("  refresh-models <server>     Refresh a single server")
        print("  refresh-models --list       List configured server names")
        print("  refresh-models enable       Install systemd/launchd timer (hourly)")
        print("  refresh-models disable      Remove timer")
        print("  refresh-models status       Show timer state and next run")
        print("  refresh-models auth         Interactive API key setup")
        print("  refresh-models auth <p> <k> Write key directly (agent-friendly)")
        print("  refresh-models --help       Show this message")
        return

    cfg = load_json(CONFIG_PATH) if os.path.exists(CONFIG_PATH) else {}
    servers = cfg.get("servers", {})
    if cmd in servers:
        refresh_server(cmd, servers[cmd])
        return

    print(f"Unknown: {cmd}", file=sys.stderr)
    print(f"Usage: refresh-models [enable|disable|status|auth|--list|<server>]", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
