#!/bin/bash
# linux-setup-module: gpu-xid-watch
# linux-setup-version: 2026.06.06.1
# linux-setup-source: files/gpu-xid-watch
#
# Poll kernel journal for NVIDIA Xid events and log new occurrences.

set -eu

XID_KNOWN=/tmp/gpu-xid-known
POLL_INTERVAL=30

rm -f "$XID_KNOWN"

while true; do
    XID_MSG=$(journalctl -k --no-pager -n 200 2>/dev/null | grep 'NVRM: Xid' | tail -1)
    if [ -n "$XID_MSG" ]; then
        XID_HASH=$(echo "$XID_MSG" | md5sum | cut -d' ' -f1)
        if [ ! -f "$XID_KNOWN" ] || ! grep -q "$XID_HASH" "$XID_KNOWN" 2>/dev/null; then
            echo "$XID_HASH" >> "$XID_KNOWN"
            logger -p daemon.crit -t gpu-xid "Xid event detected: $XID_MSG"
        fi
    fi
    sleep "$POLL_INTERVAL"
done
