# setup-module: ai-menu
# setup-source: files/ai-menu

# Recent cd targets from $history, newest first, as canonical absolute paths
# (deduped by abs path, existence-checked). One path per line on stdout.
#
# `ai` calls this inside a command substitution, so it runs in a subshell —
# a hard failsafe boundary. Parsing arbitrary history strings is the one place
# a malformed entry can raise a *fatal* expansion error (see the ${~arg} note
# below); contained here it dies with the subshell and the folder column just
# comes back empty, instead of unwinding the whole shell / plugin stack during
# startup auto-launch. Forkless within itself: $history assoc + builtin
# modifiers, no external process.
_ai_recent_dirs() {
    emulate -L zsh
    local max=${1:-8}
    zmodload -F zsh/parameter p:history 2>/dev/null
    # zsh loads $HISTFILE only after .zshrc finishes, and HISTSIZE is still the
    # default 30 during auto-launch, so read the file in ourselves. typeset
    # localizes the bumped HISTSIZE (reverts on return, harmless: zsh re-reads
    # the file after init); fc -R is a builtin, forkless manual read.
    if (( $#history < 200 )); then
        typeset HISTSIZE=2000
        builtin fc -R ${HISTFILE:-$HOME/.zsh_history} 2>/dev/null
    fi
    local k cmd arg dest canon
    local -a words
    local -A seen_path                 # canonical abs path -> 1
    for k in ${(On)${(k)history}}; do
        cmd=${history[$k]}
        words=( ${(z)cmd} )
        [[ $words[1] == (builtin|command|nocorrect) ]] && shift words
        [[ $words[1] == cd && $#words -ge 2 ]] || continue
        arg=$words[2]
        [[ $arg == -- ]] && arg=${words[3]:-}
        # Skip non-paths: empty/special targets, option flags (cd -P x), and
        # args with unexpanded $vars/backticks we can't resolve here.
        [[ $arg == (''|-*|.|..|~|/) || $arg == *[\$\`]* ]] && continue
        arg=${(Q)arg}
        # Expand ONLY a literal leading ~/ (or bare ~) by hand. Do NOT use
        # ${~arg}: its tilde flag also does named-directory lookup AND glob
        # expansion, both of which raise FATAL errors on ordinary history junk
        # — `cd ~Documents` (a slash typo) -> "no such user or named
        # directory: Documents", `cd build*` -> "no matches found" — aborting
        # the caller (and, at startup, the whole plugin stack). Plain string
        # ops can't throw; the [[ -d ]] test below is the real validity gate.
        dest=$arg
        [[ $arg == '~' || $arg == '~/'* ]] && dest=$HOME${arg#\~}
        [[ $dest != /* && -d $HOME/$dest ]] && dest=$HOME/$dest
        [[ -d $dest ]] || continue     # drop vanished dirs (stale history)
        # Dedup on the absolute path (${dest:a}), not the basename, so distinct
        # dirs sharing a name (~/work/api vs ~/play/api) are both kept while a
        # dir reached repeatedly collapses to one. :a folds . / .. lexically
        # but keeps symlinks, so the logical path the user typed is preserved.
        canon=${dest:a}
        (( ${+seen_path[$canon]} )) && continue
        seen_path[$canon]=1
        print -r -- $canon
        (( ${#seen_path} >= max )) && break
    done
}

ai() {
    local choice line
    local -a options ssh_hosts words tools folders
    local -A folder_paths
    # $HOST is set natively by zsh — no fork, unlike $(hostname).
    local current_host=$HOST
    local current_aliases=("$current_host" "${current_host%%.*}" "${current_host%%.*}.local")
    # Forkless availability filter: ${+commands[...]} is a hash lookup,
    # so missing tools drop out of the menu without any external probe.
    local tool
    for tool in claude codex claudex opencode hermes grok; do
        (( ${+commands[$tool]} )) && tools+=("$tool")
    done
    tools+=(setup resume neither)

    # Forkless parse: $(<file) + (z) word-split instead of $(grep | awk).
    # A pipeline inside a command substitution can spin forever in zsh's
    # hasprocs wait loop if a pipeline-member fork fails (orphaned -zsh at
    # 100% CPU, unkillable by SIGHUP — incident 2026-07-08). Single-command
    # substitutions fail clean; pipelines in $() must not appear in this
    # startup-critical path.
    if [[ -f ~/.ssh/config ]]; then
        for line in ${(f)"$(<~/.ssh/config)"}; do
            [[ $line == Host\ * ]] || continue
            words=( ${(z)line} )
            (( $#words >= 2 )) && ssh_hosts+=( $words[2] )
        done
        local -a hosts
        for h in "${ssh_hosts[@]}"; do
            [[ "$h" != "*" ]] && (( ${current_aliases[(I)$h]} == 0 )) && hosts+=("$h")
        done
        ssh_hosts=("${hosts[@]}")
    fi

    # Self-heal: machines that received this file via `setup update` (e.g.
    # the daily `setup schedule` timer) won't have the fzf-multicolumn
    # binary yet. Install it through the setup module exactly once — the
    # marker stops retry loops on offline machines (delete it or run
    # `setup install fzf-multicolumn` manually to retry). Plain foreground
    # commands, no command substitution — fork-safety rule intact.
    local mc_marker=${XDG_STATE_HOME:-$HOME/.local/state}/setup/ai-menu-grid-attempted
    if ! (( ${+commands[fzf-multicolumn]} )) && (( ${+commands[setup]} )) && [[ ! -e $mc_marker ]]; then
        echo "ai-menu: installing fzf-multicolumn (grid menu) ..."
        mkdir -p ${mc_marker:h} 2>/dev/null
        : >| $mc_marker
        setup install fzf-multicolumn
        rehash  # so ${+commands[fzf-multicolumn]} sees it immediately
    fi

    if (( ${+commands[fzf-multicolumn]} )); then
        # 3-column grid via our fzf fork: col 1 = agentic tools,
        # col 2 = SSH hosts, col 3 = recent cd targets from history.
        # Rows are interleaved (grid is row-major) and short columns are
        # padded with ' ' blanks so each column keeps its meaning.

        # Nerd Font column icons:  desktop monitor (U+F108) for SSH hosts,
        #  folder (U+F07B) for cd targets. The folder icon is part of the
        # folder's dispatch key, so a folder named like a tool or host entry
        # stays unambiguous and never needs to be skipped.
        local host_icon=$'' folder_icon=$''

        # Recent cd targets for column 3. The fragile part — parsing arbitrary
        # history strings and expanding them into paths — is done by the
        # _ai_recent_dirs helper, invoked through a single-command substitution
        # (one fork, no pipeline: the fork-safe form blessed above, and a
        # subshell that fails clean). That subshell is the failsafe boundary: a
        # fatal expansion error from malformed history stays inside it and the
        # column comes back empty, rather than aborting the menu at startup.
        local folder_max=$(( $#tools > $#ssh_hosts ? $#tools : $#ssh_hosts ))
        local -a cand_dest cand_base cand_parent
        local d
        cand_dest=( ${(f)"$(_ai_recent_dirs $folder_max)"} )
        for d in "${cand_dest[@]}"; do
            cand_base+=("${d:t}")          # basename = default menu label
            cand_parent+=("${d:h:t}")      # parent dir, to disambiguate dupes
        done
        # Turn candidates into display names + dispatch keys. Show a bare
        # basename when it is unique; otherwise qualify with the parent dir
        # (work/api vs play/api). The folder icon + display name doubles as
        # the folder_paths dispatch key and MUST stay unique per directory, so
        # if a parent/basename pair still collides (…/proj/api twice under
        # different roots) fall through to the full ~-abbreviated path, which
        # is unique because canon is unique.
        local -i ci
        local -A base_count
        local base disp key
        for base in "${cand_base[@]}"; do (( base_count[$base]++ )); done
        # Declare disp/key ONCE, above the loop. A `local disp key` *inside* the
        # loop re-declares an already-set `key` each pass, and zsh's typeset
        # echoes a bare, already-set name back as `key='…'` — that stray line
        # leaked into the picker input on every render. One declaration up here,
        # plain assignment below, no leak.
        for (( ci = 1; ci <= $#cand_dest; ci++ )); do
            base=$cand_base[ci]
            disp=$base
            (( base_count[$base] > 1 )) && disp="$cand_parent[ci]/$base"
            key="$folder_icon $disp"
            (( ${+folder_paths[$key]} )) && { disp=${(D)cand_dest[ci]}; key="$folder_icon $disp"; }
            folders+=("$disp")
            folder_paths[$key]=$cand_dest[ci]
        done
        local -i i rows=$#tools
        (( $#ssh_hosts > rows )) && rows=$#ssh_hosts
        (( $#folders > rows )) && rows=$#folders
        for (( i = 1; i <= rows; i++ )); do
            options+=("${tools[i]:- }" \
                "${ssh_hosts[i]:+$host_icon }${ssh_hosts[i]:- }" \
                "${folders[i]:+$folder_icon }${folders[i]:- }")
        done
        local -a picker
        picker=(fzf-multicolumn --grid=3 --grid-gap=4 --height=$(( rows + 5 )))
    else
        # Fallback: classic single-column fzf, no folder column.
        # Legacy order: tools, hosts, setup, resume, neither.
        options=("${(@)tools:#(setup|resume|neither)}" "${ssh_hosts[@]}" setup resume neither)
        local -a picker
        picker=(fzf --height=$(( $#options + 5 )))
    fi

    # Single-command substitution: one fork, child tail-execs into the picker.
    # No zsh subshell survives, no pipeline job exists — the hasprocs spin
    # is structurally impossible here. <<< is a temp file, not a fork.
    # Height = list rows + 5 chrome lines (border top/bottom, header, prompt,
    # match-counter info line) so the whole menu is visible without
    # scrolling; the picker clamps to the terminal height if it outgrows it.
    # ${(D)PWD} = prompt-style ~-abbreviated cwd. Showing it in the header
    # gives visible feedback after a folder jump reopens the menu.
    choice=$("${picker[@]}" --reverse --border \
        --header="current machine: ${current_host} · ${(D)PWD}" --pointer='▌' --prompt='▌ ' --cycle \
        <<< "${(F)options}")

    # Folder selections keep the folder icon in their dispatch key, so a
    # folder named like a tool or host can never be misdispatched — check
    # before any icon stripping.
    if [[ -n "${folder_paths[$choice]:-}" ]]; then
        # folder_paths already holds the resolved, existence-checked absolute
        # directory (see collection above), so no re-resolution is needed.
        # Re-open the menu after the jump so a tool can be launched in place.
        cd -- "${folder_paths[$choice]}" && ai
        return
    fi

    # Strip the display-only host icon back off (grid path only)
    if (( ${+host_icon} )); then
        choice=${choice#$host_icon }
    fi

    # preexec sees only the outer `ai` function call, not commands dispatched
    # from inside it. Hand the selected tool or SSH host to the tmux module's
    # title helper explicitly so the tab follows the command actually launched.
    if [[ -n $choice && $choice != (neither|' ') ]] \
        && (( ${+functions[_setup_tmux_set_title]} )); then
        _setup_tmux_set_title "${choice##*@}"
    fi

    case "$choice" in
        claude) claude ;;
        codex)
            local npm_prefix
            npm_prefix=$(npm config get prefix 2>/dev/null)
            if [[ -n "$npm_prefix" && -x "$npm_prefix/bin/codex" ]]; then
                "$npm_prefix/bin/codex"
            else
                codex
            fi
            ;;
        claudex) claudex run codex --config "$HOME/.config/claudex/config.toml" ;;
        opencode) OPENCODE_ENABLE_EXA=1 opencode ;;
        hermes) hermes ;;
        grok) grok ;;
        setup) setup ;;
        resume) resume ;;
        neither|""|" ") ;;
        *) ssh "$choice" ;;
    esac
}
