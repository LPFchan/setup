# setup-module: ai-menu
# setup-source: files/ai-menu

# History intake depth: how far back into $history to look for new cd targets on
# each menu open (see _ai_intake_history). NOT a storage cap — the store keeps
# every distinct dir ever visited (dedup bounds it to one line per directory, so
# it stays naturally modest). Kept generous so a fresh machine's first open is
# well-primed and later opens still catch newly-typed cds deeper in a burst of
# history. Plain (non-readonly) global so re-sourcing is harmless.
_AI_HISTORY_INTAKE_DEPTH=50

# Recent cd targets parsed out of $history, newest first, as canonical absolute
# paths (deduped by abs path, existence-checked). One path per line on stdout.
# This is the HISTORY INTAKE source: _ai_intake_history calls it on every open
# to discover cd targets that aren't in the recency store yet. History ORDER is
# the recency signal, not its timestamps — EXTENDED_HISTORY is commonly off and
# fc back-dates untimestamped lines to the session start, so timestamps here are
# unreliable; the newest-first order the loop emits is not.
#
# It runs (via _ai_intake_history) inside a command substitution, so it executes
# in a subshell — a hard failsafe boundary. Parsing arbitrary history strings is
# the one place a malformed entry can raise a *fatal* expansion error (see the
# ${~arg} note below); contained in that subshell it dies with it and the folder
# column just comes back empty, instead of unwinding the whole shell / plugin
# stack during startup auto-launch. Forkless within itself: $history assoc +
# builtin modifiers, no external process.
_ai_recent_dirs_from_history() {
    emulate -L zsh
    local max=${1:-8}
    zmodload -F zsh/parameter p:history 2>/dev/null
    # zsh loads $HISTFILE only after .zshrc finishes, and HISTSIZE is still the
    # default 30 during auto-launch, so read the file in ourselves. typeset
    # localizes the bumped HISTSIZE (reverts on return, harmless: zsh re-reads
    # the file after init); fc -R is a builtin, forkless manual read.
    if (( $#history < 200 )); then
        typeset HISTSIZE=2000
        builtin fc -R ${HISTFILE:-$HOME/.zsh_history} 2>/dev/null
    fi
    local k cmd arg dest canon
    local -a words
    local -A seen_path                 # canonical abs path -> 1
    for k in ${(On)${(k)history}}; do
        cmd=${history[$k]}
        words=( ${(z)cmd} )
        [[ $words[1] == (builtin|command|nocorrect) ]] && shift words
        [[ $words[1] == cd && $#words -ge 2 ]] || continue
        arg=$words[2]
        [[ $arg == -- ]] && arg=${words[3]:-}
        # Skip non-paths: empty/special targets, option flags (cd -P x), and
        # args with unexpanded $vars/backticks we can't resolve here.
        [[ $arg == (''|-*|.|..|~|/) || $arg == *[\$\`]* ]] && continue
        arg=${(Q)arg}
        # Expand ONLY a literal leading ~/ (or bare ~) by hand. Do NOT use
        # ${~arg}: its tilde flag also does named-directory lookup AND glob
        # expansion, both of which raise FATAL errors on ordinary history junk
        # — `cd ~Documents` (a slash typo) -> "no such user or named
        # directory: Documents", `cd build*` -> "no matches found" — aborting
        # the caller (and, at startup, the whole plugin stack). Plain string
        # ops can't throw; the [[ -d ]] test below is the real validity gate.
        dest=$arg
        [[ $arg == '~' || $arg == '~/'* ]] && dest=$HOME${arg#\~}
        [[ $dest != /* && -d $HOME/$dest ]] && dest=$HOME/$dest
        [[ -d $dest ]] || continue     # drop vanished dirs (stale history)
        # Dedup on the absolute path (${dest:a}), not the basename, so distinct
        # dirs sharing a name (~/work/api vs ~/play/api) are both kept while a
        # dir reached repeatedly collapses to one. :a folds . / .. lexically
        # but keeps symlinks, so the logical path the user typed is preserved.
        canon=${dest:a}
        (( ${+seen_path[$canon]} )) && continue
        seen_path[$canon]=1
        print -r -- $canon
        (( ${#seen_path} >= max )) && break
    done
}

# Recent directories, newest first, as canonical absolute paths (deduped by abs
# path, existence-checked). One path per line on stdout — the exact output
# contract the display code at the ai() call site depends on. A pure reader over
# the recency store: it does no seeding or writing. The store is filled before
# this runs, by _ai_intake_history (new cd targets from history) and
# _ai_stamp_recent_dir ($PWD), both called from ai() ahead of the menu build.
#
# `ai` calls this inside a command substitution, so it runs in a subshell — the
# same failsafe boundary as before; a malformed store line cannot unwind the
# shell. Reads the whole store (cheap — dedup bounds it to one line per distinct
# dir ever visited) and stops at $max existing dirs, so an unbounded store never
# bloats the column.
_ai_recent_dirs() {
    emulate -L zsh
    local max=${1:-8}
    local store=${XDG_STATE_HOME:-$HOME/.local/state}/setup/ai-menu-dirs
    local -a lines
    # Forkless read: $(<file) is optimized to not fork in zsh (same pattern as
    # the ssh-config / claudex-config reads in ai()). Records are epoch<TAB>path.
    [[ -r $store ]] && lines=( ${(f)"$(<$store)"} )
    # Rank by recency. Records lead with the epoch, so a reverse-numeric sort of
    # the whole line orders by that epoch, newest first — a real sort, not line
    # position, because intake and stamping append rather than rewrite in order.
    # (On) is zsh's descending-numeric flag: forkless, no external `sort`.
    lines=( ${(On)lines} )
    local -i n=0
    local rec dir
    local -A seen
    for rec in "${lines[@]}"; do
        dir=${rec#*$'\t'}                      # strip the epoch<TAB> prefix
        [[ -n $dir && -d $dir ]] || continue   # skip blank / vanished dirs
        (( ${+seen[$dir]} )) && continue
        seen[$dir]=1
        print -r -- $dir
        (( ++n >= max )) && break
    done
    # Explicit success: the loop's trailing `(( ++n >= max ))` is false (status 1)
    # whenever fewer than $max dirs exist, and callers under ERR_EXIT would
    # otherwise unwind on that ordinary short-list path.
    return 0
}

# Intake new cd targets from shell history into the recency store. Called from
# ai() on every open, BEFORE _ai_stamp_recent_dir. Order-based and once-per-dir:
# a cd target enters the store the first time history surfaces it and is left
# untouched forever after, so nothing re-anchors on later opens and menu-jump /
# $PWD stamps keep their earned recency. This is what makes newly-typed cds show
# up — they are simply the history entries not yet in the store.
#
# New arrivals are written just under "now" (now-1, now-2, ..., newest-history
# first), so they surface at the top of the column but still sit below the
# current dir, which _ai_stamp_recent_dir bumps to exactly `now` right after.
#
# Runs inline in ai() (outside the reader's $()), but the one throwing step —
# parsing arbitrary history — is quarantined in a single command substitution
# (a subshell): a fatal expansion error there dies with it, `hist` comes back
# empty, and intake is a silent no-op instead of unwinding the shell at startup.
_ai_intake_history() {
    emulate -L zsh
    # Every early exit returns 0: intake is best-effort, called inline in ai(),
    # and a nonzero status on an ordinary "nothing to do" path would unwind a
    # caller running under ERR_EXIT.
    zmodload -F zsh/datetime p:EPOCHREALTIME 2>/dev/null || return 0
    local store=${XDG_STATE_HOME:-$HOME/.local/state}/setup/ai-menu-dirs
    local -a hist
    # Failsafe boundary: history parsing can throw; the $() contains it. hist is
    # newest-first canonical abs paths.
    hist=( ${(f)"$(_ai_recent_dirs_from_history $_AI_HISTORY_INTAKE_DEPTH)"} )
    (( $#hist )) || return 0
    local -a lines add
    local rec dir e
    local -A known
    [[ -r $store ]] && lines=( ${(f)"$(<$store)"} )
    for rec in "${lines[@]}"; do known[${rec#*$'\t'}]=1; done
    # Epochs are sub-second EPOCHREALTIME formatted %.6f: 1s resolution ties, and
    # the reader's numeric sort breaks ties unpredictably, so microsecond stamps
    # are what keep two accesses in the same wall-clock second correctly ordered.
    # Append only dirs not already known, newest-history-first getting the
    # highest (now-1) epoch — just under `now`, which _ai_stamp_recent_dir then
    # takes for $PWD, so the current dir stays on top.
    local now
    printf -v now '%.6f' $EPOCHREALTIME
    local -i k=1
    for dir in "${hist[@]}"; do
        (( ${+known[$dir]} )) && continue
        known[$dir]=1
        printf -v e '%.6f' $(( now - k ))
        add+=( "$e"$'\t'"$dir" )
        (( k++ ))
    done
    (( $#add )) || return 0
    mkdir -p -- ${store:h} 2>/dev/null || return 0
    print -rl -- "${lines[@]}" "${add[@]}" >| $store 2>/dev/null
    return 0
}

# Stamp $PWD into the recency store so folders reached via the menu (the
# recursive `ai` after a jump), or by any other navigation, bubble to the top of
# the folder column next time. Called directly from ai() on every real menu
# open — OUTSIDE the _ai_recent_dirs $() failsafe — including during startup
# auto-launch, so it MUST NOT raise a fatal error that unwinds the shell.
#
# $PWD is always a real existing directory, so ${PWD:a} and the string / array /
# redirection ops below cannot throw (unlike the ${~arg} history parsing that is
# deliberately quarantined in a subshell). Run inline in a dedicated function:
# emulate -L zsh scopes options and locals, only non-throwing constructs are
# used, dedup is a literal-string compare (not a glob), and every fallible
# external step is guarded so any failure is a silent no-op. Forkless on the hot
# path: EPOCHREALTIME (module param), $(<file) read, print redirection; the lone
# mkdir matches the external mkdir the enable/disable block already runs
# directly in ai().
_ai_stamp_recent_dir() {
    emulate -L zsh
    # Every early exit returns 0 (best-effort, called inline in ai(); see the
    # matching note on _ai_intake_history).
    # No datetime module -> stamping is a graceful no-op (never an error).
    zmodload -F zsh/datetime p:EPOCHREALTIME 2>/dev/null || return 0
    local dir=${PWD:a}
    # Skip $HOME: every interactive shell auto-launches `ai` from ~, which would
    # otherwise permanently pin $HOME to the top of the column.
    [[ $dir == "$HOME" || $dir == "${HOME:a}" ]] && return 0
    local store=${XDG_STATE_HOME:-$HOME/.local/state}/setup/ai-menu-dirs
    local -a lines kept
    local rec
    [[ -r $store ]] && lines=( ${(f)"$(<$store)"} )
    # Drop any existing record for this dir (dedup by abs path). Literal-string
    # compare with a quoted RHS, so a path holding glob-active chars ([ ? * ()
    # can never be misinterpreted as a pattern.
    for rec in "${lines[@]}"; do
        [[ ${rec#*$'\t'} == "$dir" ]] || kept+=( "$rec" )
    done
    # Record the access at `now` (sub-second EPOCHREALTIME, %.6f) — the highest
    # epoch anyone writes, so $PWD always sorts to the top of the column (intake
    # writes now-1 and below). Microsecond resolution keeps rapid successive
    # opens — a folder jump and its recursive reopen land in the same second —
    # correctly ordered where a 1s epoch would tie. The reader ranks by epoch, so
    # line position is cosmetic; prepend anyway to keep the file human-readable
    # newest-first. No storage cap: dedup already bounds the store to one line per
    # distinct dir ever visited, so it grows only with genuinely new directories.
    local now
    printf -v now '%.6f' $EPOCHREALTIME
    kept=( "$now"$'\t'"$dir" "${kept[@]}" )
    mkdir -p -- ${store:h} 2>/dev/null || return 0
    # >| overwrites regardless of noclobber; single builtin redirection, no fork.
    print -rl -- "${kept[@]}" >| $store 2>/dev/null
    return 0
}

# Launch claudex with a named profile and record the session→profile mapping
# so `resume` can relaunch with the correct profile. The mapping is a TSV at
# ~/.config/claudex/sessions.tsv (<session-id>\t<profile>).
#
# The JSONL always records model "claudex-proxy" regardless of profile (the
# string is hardcoded in claudex's stream translator), so without this mapping
# `resume` cannot tell codex and commandcode sessions apart.
_claudex_launch() {
    local profile="$1"
    shift
    local marker
    marker=$(mktemp)
    touch "$marker"
    claudex run "$profile" "$@"
    local rc=$?
    # Find the session JSONL created during this launch (modified after the
    # marker). Narrow to files containing the claudex-proxy model marker so a
    # concurrent native claude session doesn't pollute the mapping.
    local newest
    newest=$(find "$HOME/.claude/projects" -maxdepth 2 -name '*.jsonl' -newer "$marker" -type f 2>/dev/null \
        | while IFS= read -r f; do
            grep -q '"model":"claudex-proxy"' "$f" 2>/dev/null && printf '%s\n' "$f"
        done \
        | head -1)
    rm -f "$marker"
    if [[ -n "$newest" ]]; then
        local sid
        sid=$(basename "$newest" .jsonl)
        local mapping="$HOME/.config/claudex/sessions.tsv"
        mkdir -p "$(dirname "$mapping")"
        # Deduplicate: remove any prior entry for this session before appending
        if [[ -f "$mapping" ]]; then
            grep -v "^${sid}	" "$mapping" > "$mapping.tmp" 2>/dev/null || true
            mv "$mapping.tmp" "$mapping"
        fi
        printf '%s\t%s\n' "$sid" "$profile" >> "$mapping"
    fi
    return $rc
}

ai() {
    local autolaunch_state_dir=${XDG_STATE_HOME:-$HOME/.local/state}/setup
    local autolaunch_disabled=$autolaunch_state_dir/ai-menu-autolaunch-disabled
    case ${1:-} in
        enable)
            rm -f -- $autolaunch_disabled
            echo "ai-menu: auto-launch enabled"
            return
            ;;
        disable)
            mkdir -p -- $autolaunch_state_dir || return
            : >| $autolaunch_disabled
            echo "ai-menu: auto-launch disabled"
            return
            ;;
    esac

    # Refresh the recency store BEFORE building the menu (and after enable/disable,
    # which return early and must not write). Two steps, order matters:
    #   1. intake newly-typed cd targets from history (new dirs -> just under now),
    #   2. stamp the current dir at exactly now, so $PWD sits on top — including
    #      the recursive open after a folder jump, which is how menu-driven
    #      navigation earns its place with no special-casing at the jump site.
    # Both run outside the _ai_recent_dirs $() failsafe and are written to be
    # incapable of unwinding the shell (the history parse each does is quarantined
    # in its own $(); see _ai_intake_history / _ai_stamp_recent_dir).
    _ai_intake_history
    _ai_stamp_recent_dir

    local choice line
    local -a options ssh_hosts words tools folders
    local -A folder_paths
    # $HOST is set natively by zsh — no fork, unlike $(hostname).
    local current_host=$HOST
    local current_aliases=("$current_host" "${current_host%%.*}" "${current_host%%.*}.local")
    # Forkless availability filter: ${+commands[...]} is a hash lookup,
    # so missing tools drop out of the menu without any external probe.
    local tool
    for tool in claude codex claudex opencode hermes grok; do
        (( ${+commands[$tool]} )) && tools+=("$tool")
        # claudex-cc is a second claudex profile (Command Code catalog), shown
        # right under claudex — only when claudex exists AND the global
        # config carries the profile. $(<file) + literal match, no external
        # probe; with the profile absent (module not yet applied here), the
        # entry stays out of the menu.
        if [[ $tool == claudex ]] && (( ${+commands[claudex]} )) \
            && [[ -f $HOME/.config/claudex/config.toml ]] \
            && [[ "$(<$HOME/.config/claudex/config.toml)" == *'name = "commandcode"'* ]]; then
            tools+=(claudex-cc)
        fi
    done
    tools+=(setup resume neither)

    # Forkless parse: $(<file) + (z) word-split instead of $(grep | awk).
    # A pipeline inside a command substitution can spin forever in zsh's
    # hasprocs wait loop if a pipeline-member fork fails (orphaned -zsh at
    # 100% CPU, unkillable by SIGHUP — incident 2026-07-08). Single-command
    # substitutions fail clean; pipelines in $() must not appear in this
    # startup-critical path.
    if [[ -f ~/.ssh/config ]]; then
        for line in ${(f)"$(<~/.ssh/config)"}; do
            [[ $line == Host\ * ]] || continue
            words=( ${(z)line} )
            (( $#words >= 2 )) && ssh_hosts+=( $words[2] )
        done
        local -a hosts
        for h in "${ssh_hosts[@]}"; do
            [[ "$h" != "*" ]] && (( ${current_aliases[(I)$h]} == 0 )) && hosts+=("$h")
        done
        ssh_hosts=("${hosts[@]}")
    fi

    # Probe the managed binary itself, not PATH identity alone. A missing or
    # pre-span copy is repaired through setup on every invocation; failures are
    # not permanently marked, so a later online invocation recovers naturally.
    local mc=$HOME/.local/bin/fzf-multicolumn mc_capable=0
    if [[ -x $mc ]] && [[ "$($mc --help 2>&1)" == *--grid-span-prefix* ]]; then
        mc_capable=1
    elif (( ${+commands[setup]} )); then
        echo "ai-menu: repairing span-aware picker ..."
        setup install fzf-multicolumn
        rehash
        [[ -x $mc ]] && [[ "$($mc --help 2>&1)" == *--grid-span-prefix* ]] && mc_capable=1
    fi

    local delim=$'\x1f'
    if (( mc_capable )); then
        # Semantic 3-column body: tools, SSH hosts, and recent directories.
        # setup/resume/neither are 2-track span rows below the body, so the
        # folder column keeps running beside them for the menu's full height.
        local host_icon=$'' folder_icon=$''
        local -a cand_dest cand_base cand_parent body_tools
        body_tools=("${(@)tools:#(setup|resume|neither)}")
        # Folders may fill every physical row: the interleaved body rows
        # (tallest of tools/hosts) plus the three action rows, clamped to 10
        # so a long host list can't bloat the menu.
        local -i body_rows=$#body_tools
        (( $#ssh_hosts > body_rows )) && body_rows=$#ssh_hosts
        local folder_max=$(( body_rows + 3 ))
        (( folder_max > 10 )) && folder_max=10
        local d
        cand_dest=( ${(f)"$(_ai_recent_dirs $folder_max)"} )
        for d in "${cand_dest[@]}"; do
            cand_base+=("${d:t}")
            cand_parent+=("${d:h:t}")
        done
        local -i ci
        local -A base_count
        local base disp key
        for base in "${cand_base[@]}"; do (( base_count[$base]++ )); done
        for (( ci = 1; ci <= $#cand_dest; ci++ )); do
            base=$cand_base[ci]
            disp=$base
            (( base_count[$base] > 1 )) && disp="$cand_parent[ci]/$base"
            key="$folder_icon $disp"
            (( ${+folder_paths[$key]} )) && { disp=${(D)cand_dest[ci]}; key="$folder_icon $disp"; }
            folders+=("$disp")
            folder_paths[$key]=$cand_dest[ci]
        done
        local -i i rows=body_rows
        for (( i = 1; i <= rows; i++ )); do
            options+=(
                "tool${delim}${body_tools[i]:- }${delim}${body_tools[i]:- }"
                "host${delim}${ssh_hosts[i]:- }${delim}${ssh_hosts[i]:+$host_icon }${ssh_hosts[i]:- }"
                "folder${delim}${folders[i]:- }${delim}${folders[i]:+$folder_icon }${folders[i]:- }"
            )
        done
        # Action rows span tracks 1-2 (tools + hosts); track 3 carries the
        # folder overflow so the folder column reaches the menu's last row.
        local -a actions=(setup resume neither)
        local -i oi
        for (( i = 1; i <= $#actions; i++ )); do
            oi=$(( rows + i ))
            options+=(
                "@@2@@action${delim}${actions[i]}${delim}${actions[i]}"
                "folder${delim}${folders[oi]:- }${delim}${folders[oi]:+$folder_icon }${folders[oi]:- }"
            )
        done
        local -a picker
        picker=("$mc" --grid=3 --grid-gap=4 --grid-span-prefix=@@ --delimiter="$delim" --with-nth=3 --height=$(( rows + 8 )))
    else
        # ai-menu alone retains a plain-fzf fallback. setup itself never depends
        # on stock fzf. Folder jumps are omitted because the fallback is linear.
        options=("${(@)tools:#(setup|resume|neither)}" "${ssh_hosts[@]}" setup resume neither)
        local -a picker
        picker=(fzf --height=$(( $#options + 5 )))
    fi
    # Single-command substitution: one fork, child tail-execs into the picker.
    # No zsh subshell survives, no pipeline job exists — the hasprocs spin
    # is structurally impossible here. <<< is a temp file, not a fork.
    # Height = list rows + 5 chrome lines (border top/bottom, header, prompt,
    # match-counter info line) so the whole menu is visible without
    # scrolling; the picker clamps to the terminal height if it outgrows it.
    # ${(D)PWD} = prompt-style ~-abbreviated cwd. Showing it in the header
    # gives visible feedback after a folder jump reopens the menu.
    choice=$("${picker[@]}" --reverse --border \
        --header="current machine: ${current_host} · ${(D)PWD}" --pointer='▌' --prompt='▌ ' --cycle \
        <<< "${(F)options}")

    # The span picker returns typed hidden metadata; strip it before dispatch.
    if (( mc_capable )); then
        local choice_kind choice_key choice_display
        IFS="$delim" read -r choice_kind choice_key choice_display <<< "$choice"
        case "$choice_kind" in
            folder) choice="$folder_icon $choice_key" ;;
            *) choice=$choice_key ;;
        esac
    fi

    # Folder selections keep the folder icon in their dispatch key, so a
    # folder named like a tool or host can never be misdispatched — check
    # before any icon stripping.
    if [[ -n "${folder_paths[$choice]:-}" ]]; then
        # folder_paths already holds the resolved, existence-checked absolute
        # directory (see collection above), so no re-resolution is needed.
        # Re-open the menu after the jump so a tool can be launched in place.
        cd -- "${folder_paths[$choice]}" && ai
        return
    fi

    # Strip the display-only host icon back off (grid path only)
    if (( ${+host_icon} )); then
        choice=${choice#$host_icon }
    fi

    # preexec sees only the outer `ai` function call, not commands dispatched
    # from inside it. Hand the selected tool or SSH host to the tmux module's
    # title helper explicitly so the tab follows the command actually launched.
    if [[ -n $choice && $choice != (neither|' ') ]] \
        && (( ${+functions[_setup_tmux_set_title]} )); then
        _setup_tmux_set_title "${choice##*@}"
    fi

    case "$choice" in
        claude) claude --dangerously-skip-permissions ;;
        codex)
            local npm_prefix
            npm_prefix=$(npm config get prefix 2>/dev/null)
            if [[ -n "$npm_prefix" && -x "$npm_prefix/bin/codex" ]]; then
                "$npm_prefix/bin/codex"
            else
                codex
            fi
            ;;
        claudex) _claudex_launch codex --config "$HOME/.config/claudex/config.toml" --dangerously-skip-permissions ;;
        claudex-cc) _claudex_launch commandcode --config "$HOME/.config/claudex/config.toml" --dangerously-skip-permissions ;;
        opencode) OPENCODE_ENABLE_EXA=1 opencode ;;
        hermes) hermes ;;
        grok) grok ;;
        setup) setup ;;
        resume) resume ;;
        neither|""|" ") ;;
        *) ssh "$choice" ;;
    esac
}
