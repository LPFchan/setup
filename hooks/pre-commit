#!/usr/bin/env bash
# pre-commit: syntax check + auto-refresh checksums
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

for f in install.sh bin/setup lib/script-helpers.sh; do
    zsh -n "$f" || { echo "Syntax error in $f — commit blocked" >&2; exit 1; }
done
while IFS=$'\t' read -r _module _target mode source; do
    [[ "$mode" == script ]] || continue
    zsh -n "$source" || { echo "Syntax error in $source — commit blocked" >&2; exit 1; }
done < manifest.tsv

for f in bin/*; do
    [[ -f "$f" ]] || continue
    [[ "$f" == bin/setup ]] && continue
    bash -n "$f" || { echo "Syntax error in $f — commit blocked" >&2; exit 1; }
done

for f in files/refresh-models; do
    [[ -f "$f" ]] || continue
    python3 -c "import py_compile; py_compile.compile('$f', doraise=True)" || exit 1
done

scripts/checksums
git add checksums.tsv
