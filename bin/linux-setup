#!/usr/bin/env bash
# linux-setup-module: linux-setup
# linux-setup-version: 2026.06.06.1
# linux-setup-source: bin/linux-setup
set -euo pipefail

BASE_URL="${LINUX_SETUP_BASE_URL:-https://setup.lost.plus}"
FALLBACK_URL="${LINUX_SETUP_FALLBACK_URL:-https://raw.githubusercontent.com/LPFchan/linux-setup/main}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/linux-setup"
MANIFEST_URL="$BASE_URL/manifest.tsv"
MANIFEST_FILE="$STATE_DIR/manifest.tsv"
HASH_FILE="$STATE_DIR/installed.tsv"
FORCE=0

SERVICE_MODULES="kernel-simmer service-ctl cgroup-monitor docker-events gpu-fancontrol gpu-xid-watch backup"
BATCH=0

usage() {
    cat <<'EOF'
Usage: linux-setup [--force] [--batch] <command> [module...]

Commands:
  list                 List available modules
  status [module...]   Show installed/current/outdated/modified state
  install [module...]  Install module files (copies to ~/.local/bin/)
  update [module...]   Update installed modules; reports new modules available
  uninstall [module...] Remove managed files
  enable [module...]   Enable service modules (requires sudo)
  disable [module...]  Disable service modules (requires sudo)
  diff [module...]     Show local diff against remote source
  doctor               Check required local tools

Run without arguments for interactive fzf reconfigure.

Environment:
  LINUX_SETUP_BASE_URL Override source URL root
EOF
}

module_enable_cmd() {
    case "$1" in
        kernel-simmer)  echo "kernel-simmer enable" ;;
        service-ctl)    echo "service-ctl enable --all" ;;
        cgroup-monitor|docker-events|gpu-fancontrol|gpu-xid-watch)
                        echo "service-ctl enable $1" ;;
        backup)         echo "backup enable" ;;
    esac
}

module_disable_cmd() {
    case "$1" in
        kernel-simmer)  echo "kernel-simmer disable" ;;
        service-ctl)    echo "service-ctl disable --all" ;;
        cgroup-monitor|docker-events|gpu-fancontrol|gpu-xid-watch)
                        echo "service-ctl disable $1" ;;
        backup)         echo "backup disable" ;;
    esac
}

sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | cut -d' ' -f1
    else
        shasum -a 256 "$1" | cut -d' ' -f1
    fi
}

expand_path() {
    case "$1" in
        '~') printf '%s\n' "$HOME" ;;
        '~/'*) printf '%s/%s\n' "$HOME" "${1:2}" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

fetch_manifest() {
    mkdir -p "$STATE_DIR"
    if ! curl -fsSL "$MANIFEST_URL" -o "$MANIFEST_FILE" \
        || ! grep -q '^# module' "$MANIFEST_FILE"; then
        curl -fsSL "$FALLBACK_URL/manifest.tsv" -o "$MANIFEST_FILE"
    fi
}

module_selected() {
    local module="$1"
    shift || true
    if (($# == 0)); then
        return 0
    fi
    local wanted
    for wanted in "$@"; do
        [[ "$module" == "$wanted" ]] && return 0
    done
    return 1
}

installed_hash_for() {
    local target="$1"
    [[ -f "$HASH_FILE" ]] || return 0
    while IFS=$'\t' read -r path hash version; do
        [[ "$path" == "$target" ]] && printf '%s\n' "$hash" && return 0
    done < "$HASH_FILE"
}

version_for() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    while IFS= read -r line; do
        case "$line" in
            '# linux-setup-version: '*) printf '%s\n' "${line#'# linux-setup-version: '}"; return 0 ;;
        esac
    done < "$file"
}

module_for() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    while IFS= read -r line; do
        case "$line" in
            '# linux-setup-module: '*) printf '%s\n' "${line#'# linux-setup-module: '}"; return 0 ;;
        esac
    done < "$file"
}

has_path_setup() {
    local file="$1"
    [[ -f "$file" ]] || return 1
    grep -Eq '(^|["=:])\$HOME/\.local/bin|(^|["=:])~/\.local/bin|(^|["=:])/.*/\.local/bin' "$file"
}

has_ai_autolaunch() {
    local file="$1"
    [[ -f "$file" ]] || return 1
    grep -Eq 'ai-start-menu' "$file" \
        && grep -Eq 'AI_AUTO_LAUNCHED' "$file" \
        && grep -Eq '(^|[^[:alnum:]_])ai([[:space:]]*$|[[:space:]]|;|&&|\|\|)' "$file"
}

has_managed_block() {
    local file="$1" label="$2"
    [[ -f "$file" ]] || return 1
    grep -Fq "# >>> linux-setup:$label >>>" "$file"
}

# --- shell config helpers (for setup command) -----------------------

append_block_once() {
    local file="$1" label="$2" content="$3" dir begin_mark end_mark
    begin_mark="# >>> linux-setup:$label >>>"
    end_mark="# <<< linux-setup:$label <<<"
    dir=$(dirname "$file")
    mkdir -p "$dir"
    touch "$file"
    if grep -Fq "$begin_mark" "$file"; then
        return 0
    fi
    {
        printf '\n%s\n' "$begin_mark"
        printf '%s\n' "$content"
        printf '%s\n' "$end_mark"
    } >> "$file"
    echo "Updated $file"
}

prepend_block_once() {
    local file="$1" label="$2" content="$3" dir begin_mark end_mark tmp
    begin_mark="# >>> linux-setup:$label >>>"
    end_mark="# <<< linux-setup:$label <<<"
    dir=$(dirname "$file")
    mkdir -p "$dir"
    touch "$file"
    if grep -Fq "$begin_mark" "$file"; then
        return 0
    fi
    tmp=$(mktemp)
    {
        printf '%s\n' "$begin_mark"
        printf '%s\n' "$content"
        printf '%s\n\n' "$end_mark"
        cat "$file"
    } > "$tmp"
    mv "$tmp" "$file"
    echo "Updated $file"
}

configure_shell() {
    local path_block zsh_ai_block bash_ai_block bash_profile_block

    path_block='case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac'

    zsh_ai_block='[[ -o interactive && -t 0 ]] || return
[[ -n ${TERM_PROGRAM-} || -n ${SSH_TTY-} ]] || return
(( SHLVL > 1 )) && return

[[ -f "$HOME/.bashrc.d/ai-start-menu" ]] && source "$HOME/.bashrc.d/ai-start-menu"
if (( ${+functions[ai]} )) && [[ -z "${AI_AUTO_LAUNCHED:-}" ]]; then
    export AI_AUTO_LAUNCHED=1
    ai
fi'

    bash_ai_block='[[ $- == *i* && -t 0 ]] || return

[[ -f "$HOME/.bashrc.d/ai-start-menu" ]] && source "$HOME/.bashrc.d/ai-start-menu"
if declare -F ai >/dev/null && [[ -z "${AI_AUTO_LAUNCHED:-}" ]]; then
    export AI_AUTO_LAUNCHED=1
    ai
fi'

    bash_profile_block='case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

if [[ -f "$HOME/.bashrc" ]]; then
    . "$HOME/.bashrc"
fi'

    if has_path_setup "$HOME/.zshenv"; then
        echo "Current shell path -> $HOME/.zshenv"
    else
        append_block_once "$HOME/.zshenv" path "$path_block"
    fi
    if has_ai_autolaunch "$HOME/.zshrc"; then
        echo "Current zsh ai autolaunch -> $HOME/.zshrc"
    else
        prepend_block_once "$HOME/.zshrc" zsh-ai "$zsh_ai_block"
    fi

    if has_path_setup "$HOME/.bashrc"; then
        echo "Current shell path -> $HOME/.bashrc"
    else
        append_block_once "$HOME/.bashrc" path "$path_block"
    fi
    if has_ai_autolaunch "$HOME/.bashrc"; then
        echo "Current bash ai autolaunch -> $HOME/.bashrc"
    else
        append_block_once "$HOME/.bashrc" bash-ai "$bash_ai_block"
    fi

    if [[ ! -f "$HOME/.bash_profile" && ! -f "$HOME/.bash_login" && ! -f "$HOME/.profile" ]]; then
        append_block_once "$HOME/.bash_profile" bash-profile "$bash_profile_block"
    else
        echo "Current bash login profile -> existing profile"
    fi
}

fetch_payload() {
    local source="$1" payload="$2"
    if ! curl -fsSL "$BASE_URL/$source" -o "$payload" \
        || ! grep -q '^# linux-setup-module: ' "$payload"; then
        curl -fsSL "$FALLBACK_URL/$source" -o "$payload"
    fi
}

version_gt() {
    local remote="$1" local_version="$2" i remote_part local_part max
    [[ -z "$remote" ]] && return 1
    [[ -z "$local_version" ]] && return 0
    [[ "$remote" == "$local_version" ]] && return 1

    local -a remote_parts local_parts
    IFS='.' read -r -a remote_parts <<< "$remote"
    IFS='.' read -r -a local_parts <<< "$local_version"
    max=${#remote_parts[@]}
    ((${#local_parts[@]} > max)) && max=${#local_parts[@]}

    for ((i = 0; i < max; i++)); do
        remote_part="${remote_parts[$i]:-0}"
        local_part="${local_parts[$i]:-0}"
        [[ "$remote_part" =~ ^[0-9]+$ ]] || remote_part=0
        [[ "$local_part" =~ ^[0-9]+$ ]] || local_part=0
        ((10#$remote_part > 10#$local_part)) && return 0
        ((10#$remote_part < 10#$local_part)) && return 1
    done

    return 1
}

record_hash() {
    local target="$1" hash="$2" version="$3" tmp
    mkdir -p "$STATE_DIR"
    tmp=$(mktemp)
    if [[ -f "$HASH_FILE" ]]; then
        while IFS=$'\t' read -r path old_hash old_version; do
            [[ "$path" == "$target" ]] && continue
            printf '%s\t%s\t%s\n' "$path" "$old_hash" "${old_version:-}"
        done < "$HASH_FILE" > "$tmp"
    fi
    printf '%s\t%s\t%s\n' "$target" "$hash" "$version" >> "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_hash() {
    local target="$1" tmp
    [[ -f "$HASH_FILE" ]] || return 0
    tmp=$(mktemp)
    while IFS=$'\t' read -r path old_hash old_version; do
        [[ "$path" == "$target" ]] && continue
        printf '%s\t%s\t%s\n' "$path" "$old_hash" "${old_version:-}"
    done < "$HASH_FILE" > "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_marker_blocks() {
    local file="$1" tmp status=0
    [[ -f "$file" ]] || return 0
    tmp=$(mktemp)
    awk '
        /^# >>> linux-setup:/ { skip=1; changed=1; next }
        /^# <<< linux-setup:/ { skip=0; next }
        !skip { print }
        END { if (changed) exit 42 }
    ' "$file" > "$tmp" || status=$?
    status=${status:-0}
    if [[ "$status" == 42 ]]; then
        mv "$tmp" "$file"
        echo "Updated $file"
    else
        rm -f "$tmp"
    fi
}

remove_shell_config() {
    remove_marker_blocks "$HOME/.zshenv"
    remove_marker_blocks "$HOME/.zshrc"
    remove_marker_blocks "$HOME/.bashrc"
    remove_marker_blocks "$HOME/.bash_profile"
}

uninstall_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"
    local target old_hash current_hash local_module
    target=$(expand_path "$target_spec")
    old_hash=$(installed_hash_for "$target" || true)

    if [[ ! -f "$target" ]]; then
        remove_hash "$target"
        echo "Missing $module -> $target"
        return 0
    fi

    if [[ -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" && "$FORCE" -ne 1 ]]; then
            echo "Local changes detected: keeping $target (use --force to remove)"
            return 0
        fi
    elif [[ "$FORCE" -ne 1 ]]; then
        local_module=$(module_for "$target" || true)
        if [[ "$local_module" != "$module" ]]; then
            echo "Untracked file: keeping $target (use --force to remove)"
            return 0
        fi
    fi

    rm -f "$target"
    remove_hash "$target"
    echo "Removed $module -> $target"
}

install_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"
    local target dir payload old_hash current_hash new_hash install_target local_version remote_version remote_module

    target=$(expand_path "$target_spec")
    dir=$(dirname "$target")
    mkdir -p "$dir"

    payload=$(mktemp)

    fetch_payload "$source" "$payload"
    remote_version=$(version_for "$payload" || true)
    remote_module=$(module_for "$payload" || true)

    if [[ "$remote_module" != "$module" ]]; then
        echo "Metadata mismatch for $source: expected module '$module', got '${remote_module:-missing}'" >&2
        rm -f "$payload"
        return 1
    fi
    if [[ -z "$remote_version" ]]; then
        echo "Missing linux-setup-version in $source" >&2
        rm -f "$payload"
        return 1
    fi

    new_hash=$(sha256 "$payload")
    old_hash=$(installed_hash_for "$target" || true)
    local_version=$(version_for "$target" || true)

    if [[ -f "$target" && -n "$local_version" ]] && ! version_gt "$remote_version" "$local_version" && [[ "$FORCE" -ne 1 ]]; then
        if [[ -n "$old_hash" ]]; then
            current_hash=$(sha256 "$target")
            if [[ "$current_hash" != "$old_hash" ]]; then
                echo "Local changes detected: $module remains at $local_version"
                rm -f "$payload"
                return 0
            fi
        fi
        echo "Current $module $local_version -> $target"
        rm -f "$payload"
        return 0
    fi

    if [[ -f "$target" && -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" && "$FORCE" -ne 1 ]]; then
            install_target="$target.new"
            install -m "$mode" "$payload" "$install_target"
            echo "Local changes detected: wrote $install_target for $module $remote_version"
            rm -f "$payload"
            return 0
        fi
    elif [[ -f "$target" && "$FORCE" -ne 1 ]]; then
        install_target="$target.new"
        install -m "$mode" "$payload" "$install_target"
        echo "Untracked existing file: wrote $install_target for $module $remote_version"
        rm -f "$payload"
        return 0
    fi

    install -m "$mode" "$payload" "$target"
    record_hash "$target" "$new_hash" "$remote_version"
    if [[ -n "$local_version" && "$local_version" != "$remote_version" ]]; then
        echo "Updated $module $local_version -> $remote_version"
    else
        echo "Installed $module $remote_version -> $target"
    fi
    rm -f "$payload"
}

status_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"
    local target payload remote_version local_version local_module old_hash current_hash state extra
    target=$(expand_path "$target_spec")
    payload=$(mktemp)
    fetch_payload "$source" "$payload"
    remote_version=$(version_for "$payload" || true)
    rm -f "$payload"

    if [[ ! -f "$target" ]]; then
        printf '%-14s %-12s remote=%s target=%s\n' "$module" "uninstalled" "${remote_version:-unknown}" "$target"
        return 0
    fi

    local_module=$(module_for "$target" || true)
    local_version=$(version_for "$target" || true)
    old_hash=$(installed_hash_for "$target" || true)

    if [[ "$local_module" != "$module" ]]; then
        printf '%-14s %-12s target=%s\n' "$module" "foreign" "$target"
        return 0
    fi

    state="current"
    extra="local=${local_version:-unknown} remote=${remote_version:-unknown}"

    if [[ -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" ]]; then
            state="modified"
        fi
    else
        extra="$extra untracked-hash"
    fi

    if [[ "$state" != "modified" ]]; then
        if version_gt "$remote_version" "$local_version"; then
            state="outdated"
        elif version_gt "$local_version" "$remote_version"; then
            state="ahead"
        fi
    fi

    printf '%-14s %-12s %s target=%s\n' "$module" "$state" "$extra" "$target"
}

cmd_list() {
    fetch_manifest
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        printf '%-14s %s\n' "$module" "$target"
    done < "$MANIFEST_FILE"
}

cmd_status() {
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            status_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    if (($# == 0)); then
        echo
        shell_status
    fi
}

shell_status() {
    shell_status_one "$HOME/.zshenv" path has_path_setup
    shell_status_one "$HOME/.zshrc" zsh-ai has_ai_autolaunch
    shell_status_one "$HOME/.bashrc" path has_path_setup
    shell_status_one "$HOME/.bashrc" bash-ai has_ai_autolaunch
    if [[ -f "$HOME/.bash_profile" || -f "$HOME/.bash_login" || -f "$HOME/.profile" ]]; then
        printf '%-14s %-12s target=%s\n' "bash-profile" "existing" "login profile present"
    else
        printf '%-14s %-12s target=%s\n' "bash-profile" "missing" "$HOME/.bash_profile"
    fi
}

shell_status_one() {
    local file="$1" label="$2" detector="$3" state="missing"
    if "$detector" "$file"; then
        state="configured"
    fi
    if has_managed_block "$file" "$label"; then
        state="managed"
    fi
    printf '%-14s %-12s target=%s\n' "$label" "$state" "$file"
}

cmd_install() {
    local modules=("$@")
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "${modules[@]}"; then
            found=1
            install_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    # Enable service modules after install
    for module in "${modules[@]}"; do
        local enable_cmd
        enable_cmd=$(module_enable_cmd "$module") || continue
        echo "Enabling $module..."
        sudo ${enable_cmd} 2>/dev/null || echo "(enable deferred — run with sudo later)"
    done
}

cmd_update() {
    fetch_manifest
    local new_count=0 new_names=()
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        local target_path local_ver
        target_path=$(expand_path "$target")
        local_ver=$(version_for "$target_path" || true)
        if [[ -z "$local_ver" ]]; then
            new_count=$((new_count + 1))
            new_names+=("$module")
        else
            install_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    echo
    if [[ "$new_count" -gt 0 ]]; then
        echo "$new_count new module(s) available: ${new_names[*]}"
        echo "Run 'linux-setup' to select what to install."
    else
        echo "All modules up to date."
    fi
}

cmd_uninstall() {
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            uninstall_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    if (($# == 0)); then
        remove_shell_config
        rm -f "$MANIFEST_FILE" "$HASH_FILE"
        rmdir "$STATE_DIR" 2>/dev/null || true
    fi
}

cmd_diff() {
    fetch_manifest
    local module target mode source local_path payload found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        module_selected "$module" "$@" || continue
        found=1
        local_path=$(expand_path "$target")
        payload=$(mktemp)
        fetch_payload "$source" "$payload"
        if [[ -f "$local_path" ]]; then
            diff -u "$local_path" "$payload" || true
        else
            echo "Missing: $local_path"
        fi
        rm -f "$payload"
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }
}

cmd_enable() {
    local modules=("$@")
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        local cmd
        cmd=$(module_enable_cmd "$module") || { echo "No enable command for $module" >&2; continue; }
        echo "Enabling $module..."
        sudo ${cmd}
    done
}

cmd_disable() {
    local modules=("$@")
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        local cmd
        cmd=$(module_disable_cmd "$module") || { echo "No disable command for $module" >&2; continue; }
        echo "Disabling $module..."
        sudo ${cmd}
    done
}

cmd_doctor() {
    local missing=0 tool
    for tool in awk cat curl cut diff dirname grep install mktemp mv rm rmdir; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            echo "missing: $tool"
            missing=1
        fi
    done
    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        echo "missing: sha256sum or shasum"
        missing=1
    fi
    ((missing == 0)) && echo "ok"
    return "$missing"
}

# --- fzf interactive reconfigure ------------------------------------

detect_env_summary() {
    local os arch distro fs
    os=$(uname -s)
    arch=$(uname -m)
    if [[ -f /etc/os-release ]]; then
        distro=$(. /etc/os-release && echo "${NAME} ${VERSION_ID}")
    else
        distro="${os}"
    fi
    fs=$(stat -f -c '%T' / 2>/dev/null || echo "unknown")
    echo "${os} ${arch} · ${distro} · ${fs}"
}

module_state() {
    local module="$1" target_spec="$2"
    local target payload remote_ver local_ver
    target=$(expand_path "$target_spec")
    if [[ ! -f "$target" ]]; then
        echo "not installed"
        return
    fi
    local_ver=$(version_for "$target" || true)
    payload=$(mktemp)
    fetch_payload "$3" "$payload" 2>/dev/null || true
    remote_ver=$(version_for "$payload" || true)
    rm -f "$payload"
    if [[ -z "$local_ver" ]]; then
        echo "installed (no version)"
    elif version_gt "$remote_ver" "$local_ver"; then
        echo "outdated · ${local_ver}"
    else
        echo "current · ${local_ver}"
    fi
}

cmd_reconfigure() {
    configure_shell
    fetch_manifest
    local input_lines=() module target mode source state label env_summary

    # Build fzf input
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        state=$(module_state "$module" "$target" "$source")
        # Pre-check if installed
        case "$state" in
            "not installed") label="  " ;;
            *)               label="[x]" ;;
        esac
        input_lines+=("${label} ${module}  ${state}")
    done < "$MANIFEST_FILE"

    env_summary=$(detect_env_summary)

    # If fzf is available and stdout is a terminal, use interactive selector
    if command -v fzf >/dev/null 2>&1 && [[ -t 1 ]]; then
        local selected
        selected=$(
            printf '%s\n' "${input_lines[@]}" | \
            fzf --multi \
                --bind=space:toggle+down,tab:toggle \
                --header="${env_summary}  |  Tab/Spc toggle · Enter confirm" \
                --preview='echo "linux-setup module: {2}"' \
                --preview-window=hidden
        ) || return 0  # user cancelled

        local -a wanted=()
        while IFS= read -r line; do
            local mod
            mod=$(echo "$line" | awk '{print $2}')
            [[ -n "$mod" ]] && wanted+=("$mod")
        done <<< "$selected"

        # Install + enable wanted modules
        for module in "${wanted[@]}"; do
            while IFS=$'\t' read -r m target mode source; do
                [[ "$m" == "$module" ]] || continue
                install_one "$module" "$target" "$mode" "$source"
                local enable_cmd
                enable_cmd=$(module_enable_cmd "$module") && {
                    echo "Enabling $module..."
                    sudo ${enable_cmd} 2>/dev/null || echo "(enable deferred — run 'linux-setup enable $module' with sudo later)"
                }
            done < "$MANIFEST_FILE"
        done

        # Uninstall modules not wanted (that are currently installed)
        while IFS=$'\t' read -r module target mode source; do
            [[ -z "${module:-}" || "$module" == \#* ]] && continue
            local wanted_module
            for wanted_module in "${wanted[@]}"; do
                [[ "$wanted_module" == "$module" ]] && continue 2
            done
            local target_path
            target_path=$(expand_path "$target")
            if [[ -f "$target_path" ]]; then
                echo "Removing $module..."
                uninstall_one "$module" "$target" "$mode" "$source"
                local disable_cmd
                disable_cmd=$(module_disable_cmd "$module") && {
                    echo "Disabling $module..."
                    sudo ${disable_cmd} 2>/dev/null || echo "(disable deferred — run with sudo later)"
                }
            fi
        done < "$MANIFEST_FILE"
    else
        echo "No interactive terminal or fzf missing. Run with --batch or specify modules."
        exit 1
    fi
}

while (($# > 0)); do
    case "$1" in
        --force) FORCE=1; shift ;;
        --batch) BATCH=1; shift ;;
        -h|--help) usage; exit 0 ;;
        *) break ;;
    esac
done

cmd="${1:-}"
shift || true

if [[ -z "$cmd" ]]; then
    if [[ -t 1 ]] && command -v fzf >/dev/null 2>&1; then
        cmd_reconfigure
    else
        cmd_update
        cmd_install resume ai-menu 2>/dev/null || true
    fi
    exit 0
fi

case "$cmd" in
    list) cmd_list "$@" ;;
    status) cmd_status "$@" ;;
    install) cmd_install "$@" ;;
    update) cmd_update "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    enable) cmd_enable "$@" ;;
    disable) cmd_disable "$@" ;;
    diff) cmd_diff "$@" ;;
    doctor) cmd_doctor ;;
    *) usage >&2; exit 1 ;;
esac
