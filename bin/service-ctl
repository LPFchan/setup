#!/usr/bin/env bash
# setup-module: service-ctl
# setup-version: 2026.06.06.2
# setup-source: bin/service-ctl
#
# service-ctl — manage system monitoring and control services
#
# Components:
#   gpu-fancontrol  Temperature-based chassis fan controller
#   monitoring      Unified container cgroup, Docker events, and GPU Xid monitor
#   kernel-simmer   Delayed kernel upgrades with cool-off (delegates)
#
# Usage:
#   service-ctl enable <component>   Install systemd units and start
#   service-ctl disable <component>  Stop and remove systemd units
#   service-ctl enable --all         Enable all components
#   service-ctl disable --all        Disable all components
#   service-ctl status               Show state of all components
#   service-ctl list                 List available components

set -euo pipefail

NAME="service-ctl"
COMPONENTS="gpu-fancontrol monitoring kernel-simmer"

# --- helpers ----------------------------------------------------------

die() { echo "error: $*" >&2; exit 1; }
info() { echo "$*"; }

require_root() {
    if [[ $EUID -ne 0 ]]; then
        die "this command requires root — try sudo ${NAME} $*"
    fi
}

find_script() {
    local script="$1"
    for dir in "${HOME}/.local/bin" "/usr/local/bin" "/usr/local/sbin"; do
        if [[ -f "${dir}/${script}" ]]; then
            echo "${dir}/${script}"
            return 0
        fi
    done
    return 1
}

# --- legacy migration ------------------------------------------------

migrate_legacy() {
    local comp="$1"
    case "${comp}" in
        gpu-fancontrol)
            if systemctl list-unit-files "gpu-fancontrol.service" &>/dev/null; then
                systemctl disable --now "gpu-fancontrol.service" 2>/dev/null || true
                rm -f "/etc/systemd/system/gpu-fancontrol.service"
            fi
            rm -f "/usr/local/bin/gpu-fancontrol.py"
            ;;
        monitoring)
            for unit in grimoire-cgroup-monitor.service grimoire-docker-events.service nvidia-crash-watch.service host-cgroup-monitor.service host-docker-events.service host-xid-watch.service; do
                if systemctl list-unit-files "$unit" &>/dev/null; then
                    systemctl disable --now "$unit" 2>/dev/null || true
                    rm -f "/etc/systemd/system/$unit"
                fi
            done
            for script in /usr/local/sbin/grimoire-cgroup-monitor /usr/local/sbin/grimoire-docker-events /home/yeowool/nvidia-crash-watch.sh ~/.local/bin/cgroup-monitor ~/.local/bin/docker-events ~/.local/bin/gpu-xid-watch; do
                rm -f "$script"
            done
            rm -f /usr/local/bin/cgroup-monitor /usr/local/bin/docker-events /usr/local/bin/gpu-xid-watch
            ;;
    esac
}

# --- systemd unit templates ------------------------------------------

SERVICE_UNIT_gpu_fancontrol() {
    local script_path="$1"
    cat <<UNIT
[Unit]
Description=GPU-based chassis fan controller
After=network.target nvidia-persistenced.service
Wants=nvidia-persistenced.service

[Service]
Type=simple
ExecStart=${script_path}
Restart=on-failure
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
UNIT
}

SERVICE_UNIT_monitoring() {
    local script_path="$1"
    cat <<UNIT
[Unit]
Description=Unified container monitoring (cgroup + events + Xid)
After=docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=${script_path}
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=monitoring

[Install]
WantedBy=multi-user.target
UNIT
}

SERVICE_UNIT_kernel_simmer() {
    # delegated — handled by kernel-simmer itself
    :
}

# --- enable ----------------------------------------------------------

component_enable() {
    local comp="$1"
    require_root "enable ${comp}"
    migrate_legacy "${comp}"

    case "${comp}" in
        gpu-fancontrol)
            local src; src=$(find_script "gpu-fancontrol") || die "gpu-fancontrol not found"
            [[ "${src}" == "/usr/local/bin/gpu-fancontrol" ]] || ln -sf "${src}" "/usr/local/bin/gpu-fancontrol"
            SERVICE_UNIT_gpu_fancontrol "/usr/local/bin/gpu-fancontrol" > /etc/systemd/system/gpu-fancontrol.service
            systemctl daemon-reload
            systemctl enable --now gpu-fancontrol.service
            info "gpu-fancontrol enabled"
            ;;
        monitoring)
            local src; src=$(find_script "monitoring") || die "monitoring not found"
            [[ "${src}" == "/usr/local/bin/monitoring" ]] || ln -sf "${src}" "/usr/local/bin/monitoring"
            SERVICE_UNIT_monitoring "/usr/local/bin/monitoring" > /etc/systemd/system/monitoring.service
            systemctl daemon-reload
            systemctl enable --now monitoring.service
            info "monitoring enabled"
            ;;
        kernel-simmer)
            if command -v kernel-simmer &>/dev/null; then
                kernel-simmer enable
            elif [[ -x /usr/local/bin/kernel-simmer ]]; then
                /usr/local/bin/kernel-simmer enable
            else
                die "kernel-simmer not found"
            fi
            ;;
        *) die "unknown component '${comp}'" ;;
    esac
}

# --- disable ---------------------------------------------------------

component_disable() {
    local comp="$1"
    local service_name

    case "${comp}" in
        gpu-fancontrol) service_name="gpu-fancontrol" ;;
        monitoring)     service_name="monitoring" ;;
        kernel-simmer)
            if command -v kernel-simmer &>/dev/null; then
                kernel-simmer disable
            elif [[ -x /usr/local/bin/kernel-simmer ]]; then
                /usr/local/bin/kernel-simmer disable
            else
                die "kernel-simmer not found"
            fi
            ;;
        *) die "unknown component '${comp}'" ;;
    esac

    require_root "disable ${comp}"
    systemctl disable --now "${service_name}.service" 2>/dev/null || true
    rm -f "/etc/systemd/system/${service_name}.service"
    rm -f "/usr/local/bin/${service_name}"
    systemctl daemon-reload
    info "${comp} disabled"
}

# --- status ----------------------------------------------------------

component_status() {
    local comp="$1"
    local service_name
    case "${comp}" in
        gpu-fancontrol) service_name="gpu-fancontrol" ;;
        monitoring)     service_name="monitoring" ;;
        kernel-simmer)  service_name="kernel-simmer" ;;
        *) echo "  ${comp}: unknown"; return ;;
    esac

    local state
    state=$(systemctl is-active "${service_name}.service" 2>/dev/null || echo "not-installed")
    if [[ "${state}" == "active" ]] || [[ "${state}" == "activating" ]]; then
        printf '  \e[32m%-20s %s\e[0m\n' "${comp}" "${state}"
    else
        printf '  %-20s %s\n' "${comp}" "${state}"
    fi
}

# --- commands --------------------------------------------------------

cmd_enable() {
    if [[ $# -eq 0 ]]; then
        die "usage: ${NAME} enable <component> | ${NAME} enable --all"
    fi
    if [[ "$1" == "--all" ]]; then
        for comp in ${COMPONENTS}; do
            component_enable "${comp}" || warn "failed to enable ${comp}"
        done
        return 0
    fi
    component_enable "$1"
}

cmd_disable() {
    if [[ $# -eq 0 ]]; then
        die "usage: ${NAME} disable <component> | ${NAME} disable --all"
    fi
    if [[ "$1" == "--all" ]]; then
        for comp in ${COMPONENTS}; do
            component_disable "${comp}" || true
        done
        return 0
    fi
    component_disable "$1"
}

cmd_status() {
    require_root
    echo "${NAME} status:"
    for comp in ${COMPONENTS}; do
        component_status "${comp}"
    done
}

cmd_list() {
    echo "Available components:"
    for comp in ${COMPONENTS}; do
        printf '  %-20s ' "${comp}"
        case "${comp}" in
            gpu-fancontrol) echo "Temperature-based chassis fan PWM" ;;
            monitoring)     echo "Unified cgroup + Docker events + Xid monitor" ;;
            kernel-simmer)  echo "Delayed kernel upgrades (delegates)" ;;
        esac
    done
}

# --- main ------------------------------------------------------------

cmd="${1:-help}"; [[ $# -gt 0 ]] && shift

case "${cmd}" in
    enable)  cmd_enable "$@" ;;
    disable) cmd_disable "$@" ;;
    status)  cmd_status ;;
    list)    cmd_list ;;
    help|--help|-h) cat <<HELP
Usage: ${NAME} <command> [args]

Commands:
  enable <component>  Install systemd units and enable component
  enable --all        Enable all components
  disable <component> Stop and remove systemd units
  disable --all       Disable all components
  status              Show systemd state of all components
  list                List available components
  help                Show this message

Components: ${COMPONENTS}
HELP
        ;;
    *) die "unknown command. Try '${NAME} help'." ;;
esac
