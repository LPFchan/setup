#!/usr/bin/env bash
# linux-setup-module: service-ctl
# linux-setup-version: 2026.06.06.2
# linux-setup-source: bin/service-ctl
#
# service-ctl — manage system monitoring and control services
#
# Components:
#   cgroup-monitor  Log container cgroup memory, GPU, and health state
#   docker-events   Log container lifecycle events (die, oom, kill)
#   gpu-fancontrol  Temperature-based chassis fan controller
#   gpu-xid-watch       Monitor kernel log for NVIDIA Xid (GPU) errors
#   kernel-simmer   Delayed kernel upgrades with cool-off (delegates)
#
# Usage:
#   service-ctl enable <component>   Install systemd units and start
#   service-ctl disable <component>  Stop and remove systemd units
#   service-ctl enable --all         Enable all components
#   service-ctl disable --all        Disable all components
#   service-ctl status               Show state of all components
#   service-ctl list                 List available components

set -euo pipefail

NAME="service-ctl"
LOG_TAG="${NAME}"

COMPONENTS="cgroup-monitor docker-events gpu-fancontrol gpu-xid-watch kernel-simmer"

# --- helpers ----------------------------------------------------------

die() { echo "error: $*" >&2; exit 1; }

info() { echo "$*"; }

require_root() {
    if [[ $EUID -ne 0 ]]; then
        die "this command requires root -- try sudo ${NAME} $*"
    fi
}

find_script() {
    local script="$1"
    for dir in "${HOME}/.local/bin" "/usr/local/bin" "/usr/local/sbin"; do
        if [[ -f "${dir}/${script}" ]]; then
            echo "${dir}/${script}"
            return 0
        fi
    done
    return 1
}

# --- legacy migration (pre-session setups) ---------------------------
# Maps old systemd unit names that existed before this module was created.

LEGACY_MAP_cgroup_monitor() {
    echo "grimoire-cgroup-monitor.service" "/usr/local/sbin/grimoire-cgroup-monitor"
}
LEGACY_MAP_docker_events() {
    echo "grimoire-docker-events.service" "/usr/local/sbin/grimoire-docker-events"
}
LEGACY_MAP_gpu_fancontrol() {
    echo "gpu-fancontrol.service" "/usr/local/bin/gpu-fancontrol.py"
}
LEGACY_MAP_gpu_xid_watch() {
    echo "nvidia-crash-watch.service" "/home/yeowool/nvidia-crash-watch.sh"
}

migrate_legacy() {
    local comp="$1"
    local map_func="LEGACY_MAP_${comp//-/_}"
    local old_unit old_script
    read -r old_unit old_script < <("${map_func}")

    if [[ -n "${old_unit}" ]] && systemctl list-unit-files "${old_unit}" &>/dev/null; then
        systemctl disable --now "${old_unit}" 2>/dev/null || true
        rm -f "/etc/systemd/system/${old_unit}"
    fi
    if [[ -n "${old_script}" ]] && [[ -f "${old_script}" ]]; then
        rm -f "${old_script}"
    fi
}

# --- component definitions with embedded systemd units ----------------

SERVICE_UNIT_cgroup_monitor() {
    local script_path="$1"
    cat <<UNIT
[Unit]
Description=Log container cgroup memory and GPU state
After=docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=${script_path}
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=cgroup-monitor

[Install]
WantedBy=multi-user.target
UNIT
}

SERVICE_UNIT_docker_events() {
    local script_path="$1"
    cat <<UNIT
[Unit]
Description=Log container lifecycle events
After=docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=${script_path}
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=docker-events

[Install]
WantedBy=multi-user.target
UNIT
}

SERVICE_UNIT_gpu_fancontrol() {
    local script_path="$1"
    cat <<UNIT
[Unit]
Description=GPU-based chassis fan controller
After=network.target nvidia-persistenced.service
Wants=nvidia-persistenced.service

[Service]
Type=simple
ExecStart=${script_path}
Restart=on-failure
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
UNIT
}

SERVICE_UNIT_gpu_xid_watch() {
    local script_path="$1"
    cat <<UNIT
[Unit]
Description=NVIDIA Xid error monitor

[Service]
Type=simple
ExecStart=${script_path}
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
UNIT
}

# --- per-component handlers ------------------------------------------

component_enable() {
    local comp="$1"
    local script_file service_name unit_func

    case "${comp}" in
        cgroup-monitor)
            script_file="cgroup-monitor"
            service_name="cgroup-monitor"
            unit_func=SERVICE_UNIT_cgroup_monitor
            ;;
        docker-events)
            script_file="docker-events"
            service_name="docker-events"
            unit_func=SERVICE_UNIT_docker_events
            ;;
        gpu-fancontrol)
            script_file="gpu-fancontrol"
            service_name="gpu-fancontrol"
            unit_func=SERVICE_UNIT_gpu_fancontrol
            ;;
        gpu-xid-watch)
            script_file="gpu-xid-watch"
            service_name="gpu-xid-watch"
            unit_func=SERVICE_UNIT_gpu_xid_watch
            ;;
        kernel-simmer)
            if command -v kernel-simmer &>/dev/null; then
                exec kernel-simmer enable
            elif [[ -x /usr/local/bin/kernel-simmer ]]; then
                exec /usr/local/bin/kernel-simmer enable
            else
                die "kernel-simmer not found -- install via 'linux-setup install kernel-simmer' first"
            fi
            ;;
        *)
            die "unknown component '${comp}'. Available: ${COMPONENTS}"
            ;;
    esac

    require_root "enable ${comp}"

    # Migrate any legacy service before installing the new one
    migrate_legacy "${comp}"

    local src_path
    src_path=$(find_script "${script_file}") || die "${script_file} not found -- install via 'linux-setup install service-ctl'"

    # Symlink into /usr/local/bin so systemd-as-root can find us
    if [[ "${src_path}" != /usr/local/bin/${script_file} ]]; then
        ln -sf "${src_path}" "/usr/local/bin/${script_file}"
    fi
    local target="/usr/local/bin/${script_file}"

    # Write systemd unit
    "${unit_func}" "${target}" > "/etc/systemd/system/${service_name}.service"

    systemctl daemon-reload
    systemctl enable --now "${service_name}.service"
    info "${comp} enabled (${service_name}.service)"
}

component_disable() {
    local comp="$1"
    local service_name

    case "${comp}" in
        cgroup-monitor) service_name="cgroup-monitor" ;;
        docker-events)  service_name="docker-events" ;;
        gpu-fancontrol) service_name="gpu-fancontrol" ;;
        gpu-xid-watch)      service_name="gpu-xid-watch" ;;
        kernel-simmer)
            if command -v kernel-simmer &>/dev/null; then
                exec kernel-simmer disable
            elif [[ -x /usr/local/bin/kernel-simmer ]]; then
                exec /usr/local/bin/kernel-simmer disable
            else
                die "kernel-simmer not found"
            fi
            ;;
        *) die "unknown component '${comp}'" ;;
    esac

    require_root "disable ${comp}"

    systemctl disable --now "${service_name}.service" 2>/dev/null || true
    rm -f "/etc/systemd/system/${service_name}.service"
    rm -f "/usr/local/bin/${service_name}" "/usr/local/sbin/${service_name}"
    systemctl daemon-reload
    info "${comp} disabled"
}

component_status() {
    local comp="$1"
    local service_name
    case "${comp}" in
        cgroup-monitor) service_name="cgroup-monitor" ;;
        docker-events)  service_name="docker-events" ;;
        gpu-fancontrol) service_name="gpu-fancontrol" ;;
        gpu-xid-watch)      service_name="gpu-xid-watch" ;;
        kernel-simmer)  service_name="kernel-simmer" ;;
        *)              echo "  ${comp}: unknown"; return ;;
    esac

    local state
    state=$(systemctl is-active "${service_name}.service" 2>/dev/null || echo "not-installed")
    if [[ "${state}" == "active" ]] || [[ "${state}" == "activating" ]]; then
        printf '  \e[32m%-20s %s\e[0m\n' "${comp}" "${state}"
    else
        printf '  %-20s %s\n' "${comp}" "${state}"
    fi
}

# --- subcommands ------------------------------------------------------

cmd_enable() {
    if [[ $# -eq 0 ]]; then
        die "usage: ${NAME} enable <component> | ${NAME} enable --all"
    fi
    if [[ "$1" == "--all" ]]; then
        for comp in ${COMPONENTS}; do
            component_enable "${comp}" || warn "failed to enable ${comp}"
        done
        return 0
    fi
    component_enable "$1"
}

cmd_disable() {
    if [[ $# -eq 0 ]]; then
        die "usage: ${NAME} disable <component> | ${NAME} disable --all"
    fi
    if [[ "$1" == "--all" ]]; then
        for comp in ${COMPONENTS}; do
            component_disable "${comp}" || true
        done
        return 0
    fi
    component_disable "$1"
}

cmd_status() {
    require_root
    echo "${NAME} status:"
    for comp in ${COMPONENTS}; do
        component_status "${comp}"
    done
}

cmd_list() {
    echo "Available components:"
    for comp in ${COMPONENTS}; do
        printf '  %-20s ' "${comp}"
        case "${comp}" in
            cgroup-monitor)  echo "cgroup memory, GPU, health -> journald" ;;
            docker-events)   echo "Docker die/oom/kill events -> journald" ;;
            gpu-fancontrol)  echo "Temperature-based chassis fan PWM" ;;
            gpu-xid-watch)       echo "NVIDIA Xid GPU error monitor" ;;
            kernel-simmer)   echo "Delayed kernel upgrades (delegates)" ;;
        esac
    done
}

cmd_help() {
    cat <<HELP
Usage: ${NAME} <command> [args]

Commands:
  enable <component>  Install systemd units and enable component
  enable --all        Enable all components
  disable <component> Stop and remove systemd units
  disable --all       Disable all components
  status              Show systemd state of all components
  list                List available components
  help                Show this message

Components: ${COMPONENTS}
HELP
}

# --- main -------------------------------------------------------------

cmd="${1:-help}"; [[ $# -gt 0 ]] && shift

case "${cmd}" in
    enable)  cmd_enable "$@" ;;
    disable) cmd_disable "$@" ;;
    status)  cmd_status ;;
    list)    cmd_list ;;
    help|--help|-h) cmd_help ;;
    *)       die "unknown command '${cmd}'. Try '${NAME} help'." ;;
esac
