#!/usr/bin/env zsh
# setup-module: setup
# setup-source: bin/setup
[[ -n "${ZSH_VERSION:-}" ]] || { echo "setup must be run with zsh" >&2; exit 1; }
emulate -R zsh
setopt KSH_ARRAYS SH_WORD_SPLIT NO_UNSET PIPE_FAIL
ORIG_ARGS=("$@")

SOURCE_URL="${LINUX_SETUP_SOURCE_URL:-https://raw.githubusercontent.com/LPFchan/setup/main}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/setup"
MANIFEST_URL="$SOURCE_URL/manifest.tsv"
MANIFEST_FILE="$STATE_DIR/manifest.tsv"
HASH_FILE="$STATE_DIR/installed.tsv"
SCRIPT_HELPERS_FILE="$STATE_DIR/lib/script-helpers.sh"
FORCE=0

SERVICE_MODULES="kernel-simmer service-ctl gpu-fancontrol monitoring refresh-models backup"
USER_SERVICE_MODULES="refresh-models"
BATCH=0

# SOURCE_URL normally points at a moving GitHub branch.  Raw GitHub caches each
# path independently, so checksums.tsv and its payload can otherwise describe
# different commits for up to five minutes.  Revalidate every source fetch so
# status and install observe one current branch state instead of repeatedly
# "updating" an already-current file.
fetch_source_url() {
    curl -fsSL -H 'Cache-Control: no-cache' --connect-timeout 8 --max-time 60 "$@"
}

fetch_script_helpers() {
    mkdir -p "$(dirname "$SCRIPT_HELPERS_FILE")"
    fetch_source_url "$SOURCE_URL/lib/script-helpers.sh" -o "$SCRIPT_HELPERS_FILE" 2>/dev/null \
        || echo "Warning: could not fetch lib/script-helpers.sh" >&2
    # shellcheck disable=SC1090
    [[ -f "$SCRIPT_HELPERS_FILE" ]] && source "$SCRIPT_HELPERS_FILE"
}
fetch_script_helpers

usage() {
    cat <<'EOF'
Usage: setup [--force] [--batch] <command> [module...]
  Flags must come before the command.
  --force  overwrite when uninstalling locally edited files
  --batch  non-interactive mode

Commands:
  list                 List available modules
  status [module...]   Show installed/current/outdated/modified state
  install [module...]  Install module files (copies to ~/.local/bin/)
  update [module...]   Update installed modules; reports new modules available
  uninstall [module...] Remove managed files
  enable [module...]   Enable service modules (requires sudo)
  disable [module...]  Disable service modules (requires sudo)
  diff [module...]     Show local diff against remote source
  doctor               Check required local tools
  schedule [status]    Install daily auto-update timer or show its state
  unschedule           Remove daily auto-update timer

Run without arguments for interactive span-aware reconfigure.

Environment:
  LINUX_SETUP_SOURCE_URL Override source URL root
EOF
}

_resolve_bin() {
    local name="$1"
    local bin_path="$HOME/.local/bin/$name"
    if [[ -x "$bin_path" ]]; then
        echo "$bin_path"
    else
        echo "$name"
    fi
}

module_enable_cmd() {
    local bin
    case "$1" in
        kernel-simmer)  bin=$(_resolve_bin kernel-simmer); echo "$bin enable" ;;
        service-ctl)    bin=$(_resolve_bin service-ctl); echo "$bin enable --all" ;;
        gpu-fancontrol|monitoring)
                        bin=$(_resolve_bin service-ctl); echo "$bin enable $1" ;;
        refresh-models) bin=$(_resolve_bin refresh-models); echo "$bin enable" ;;
        backup)         bin=$(_resolve_bin backup); echo "$bin enable" ;;
    esac
}

module_disable_cmd() {
    local bin
    case "$1" in
        kernel-simmer)  bin=$(_resolve_bin kernel-simmer); echo "$bin disable" ;;
        service-ctl)    bin=$(_resolve_bin service-ctl); echo "$bin disable --all" ;;
        gpu-fancontrol|monitoring)
                        bin=$(_resolve_bin service-ctl); echo "$bin disable $1" ;;
        refresh-models) bin=$(_resolve_bin refresh-models); echo "$bin disable" ;;
        backup)         bin=$(_resolve_bin backup); echo "$bin disable" ;;
    esac
}

module_service_unit() {
    case "$1" in
        service-ctl)    echo "tool" ;;
        kernel-simmer)  echo "kernel-simmer.timer" ;;
        gpu-fancontrol) echo "gpu-fancontrol.service" ;;
        monitoring)     echo "monitoring.service" ;;
        refresh-models) echo "refresh-models.timer" ;;
        backup)         echo "backup-daily.timer" ;;
    esac
}

is_service_module() {
    local m
    for m in ${SERVICE_MODULES}; do [[ "$m" == "$1" ]] && return 0; done
    return 1
}

module_is_active() {
    local unit user_flag=""
    unit=$(module_service_unit "$1") || return 1
    [[ "$unit" == tool ]] && return 1
    if echo " ${USER_SERVICE_MODULES} " | grep -q " $1 "; then
        user_flag="--user"
    fi
    # macOS: check launchd for refresh-models
    if [[ "$1" == "refresh-models" ]] && [[ "$(uname -s)" == "Darwin" ]]; then
        launchctl print "gui/$(id -u)/com.lost.plus.refresh-models" &>/dev/null && return 0
        return 1
    fi
    [[ "$(systemctl ${user_flag} is-active "${unit}" 2>/dev/null)" == "active" ]]
}

module_service_transition() {
    local action="$1" module="$2" cmd command_ok=0 state_ok=0 unit
    unit=$(module_service_unit "$module") || { echo "Not a service module: $module" >&2; return 1; }
    [[ "$unit" != tool ]] || { echo "Not an enable/disable service: $module (installed tool only)" >&2; return 1; }
    if [[ "$action" == enable ]]; then cmd=$(module_enable_cmd "$module")
    else cmd=$(module_disable_cmd "$module")
    fi
    case "$action" in enable) echo "Enabling $module..." ;; disable) echo "Disabling $module..." ;; esac
    if echo " ${USER_SERVICE_MODULES} " | grep -q " $module "; then
        ${cmd} && command_ok=1
    else
        sudo -E ${cmd} && command_ok=1
    fi
    if (( command_ok == 1 )); then
        if [[ "$action" == enable ]]; then module_is_active "$module" && state_ok=1
        else module_is_active "$module" || state_ok=1
        fi
    fi
    (( state_ok == 1 )) || {
        echo "Failed: $action $module (service did not reach desired state)" >&2
        return 1
    }
}

sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        if [[ -n "${1:-}" ]]; then
            sha256sum "$1" | cut -d' ' -f1
        else
            sha256sum | cut -d' ' -f1
        fi
    elif command -v shasum >/dev/null 2>&1; then
        if [[ -n "${1:-}" ]]; then
            shasum -a 256 "$1" | cut -d' ' -f1
        else
            shasum -a 256 | cut -d' ' -f1
        fi
    else
        echo "missing sha256sum/shasum" >&2; exit 1
    fi
}

expand_path() {
    case "$1" in
        '~') printf '%s\n' "$HOME" ;;
        '~/'*) printf '%s/%s\n' "$HOME" "${1:2}" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

fetch_manifest() {
    mkdir -p "$STATE_DIR"
    local tmp
    tmp=$(mktemp)
    if fetch_source_url "$MANIFEST_URL" -o "$tmp" 2>/dev/null \
       && grep -q '^# module' "$tmp"; then
        if mv "$tmp" "$MANIFEST_FILE"; then
            return 0
        fi
        rm -f "$tmp"
        echo "Failed to install fetched manifest at $MANIFEST_FILE" >&2
        return 1
    fi
    rm -f "$tmp"
    echo "Failed to fetch manifest from $MANIFEST_URL" >&2
    return 1
}

module_selected() {
    local module="$1"
    shift || true
    if (($# == 0)); then
        return 0
    fi
    local wanted
    for wanted in "$@"; do
        [[ "$module" == "$wanted" ]] && return 0
    done
    return 1
}

installed_hash_for() {
    local target="$1"
    local recorded_path hash version
    [[ -f "$HASH_FILE" ]] || return 0
    while IFS=$'\t' read -r recorded_path hash version; do
        [[ "$recorded_path" == "$target" ]] && printf '%s\n' "$hash" && return 0
    done < "$HASH_FILE"
}
fetch_checksums() {
    # Download checksums.tsv and cache source → sha256 mappings.
    if [[ -n "${_CSUM_CACHE:-}" ]]; then
        return 0
    fi
    local tmp
    tmp=$(mktemp)
    if fetch_source_url "$SOURCE_URL/checksums.tsv" -o "$tmp" 2>/dev/null \
        && grep -q '^# source' "$tmp"; then
        _CSUM_CACHE=$(cat "$tmp")
    else
        echo "Warning: could not fetch checksums.tsv from $SOURCE_URL" >&2
    fi
    rm -f "$tmp"
}

remote_checksum() {
    local source="$1"
    [[ -z "${_CSUM_CACHE:-}" ]] && fetch_checksums
    printf '%s\n' "${_CSUM_CACHE:-}" | grep "^${source}"$'\t' | head -1 | cut -f2
}

_migrate_auth_json() {
    local old="$HOME/.local/share/opencode/auth.json"
    [[ -f "$old" ]] || return 0
    python3 -c "
import json, os, pathlib
old = os.path.expanduser('~/.local/share/opencode/auth.json')
zsenv = os.path.expanduser('~/.zshenv')
begin = '# BEGIN setup:api-keys'
end = '# END setup:api-keys'
try:
    data = json.load(open(old))
except Exception:
    exit(0)
if not isinstance(data, dict) or not data:
    exit(0)
lines = []
for p, e in data.items():
    if not isinstance(e, dict):
        continue
    etype = e.get('type', '')
    if etype == 'api':
        key = e.get('key', '')
        if key and isinstance(key, str) and key.strip():
            provider = p.replace('-', '_').upper()
            lines.append(f'export {provider}_API_KEY={key.strip()}')
    elif etype == 'oauth':
        access = e.get('access', '')
        if access and isinstance(access, str):
            provider = p.replace('-', '_').upper()
            lines.append(f'export {provider}_OAUTH_TOKEN={access}')
if not lines:
    exit(0)
existing = []
in_block = False
if os.path.exists(zsenv):
    for l in open(zsenv):
        s = l.strip()
        if s == begin: in_block = True; continue
        if s == end: in_block = False; continue
        if not in_block:
            existing.append(l)
with open(zsenv, 'w') as f:
    for l in existing:
        f.write(l)
    f.write(f'\n{begin}\n')
    for l in lines:
        f.write(l + '\n')
    f.write(f'{end}\n')
print(f'Exported {len(lines)} key(s) from {old} to {zsenv}')
" 2>&1 || true
}

module_for() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    while IFS= read -r line; do
        case "$line" in
            '# setup-module: '*) printf '%s\n' "${line#'# setup-module: '}"; return 0 ;;
        esac
    done < "$file"
}


has_managed_block() {
    local file="$1" label="$2"
    [[ -f "$file" ]] || return 1
    grep -Fq "# >>> setup:$label >>>" "$file" || grep -Fq "# >>> linux-setup:$label >>>" "$file"
}

# --- shell config helpers (for setup command) -----------------------

manage_block() {
    local file="$1" label="$2" content="$3" mode="$4" position="${5:-append}"
    local begin_mark="# >>> setup:$label >>>"
    local end_mark="# <<< setup:$label <<<"
    local old_begin_mark="# >>> linux-setup:$label >>>"
    local old_end_mark="# <<< linux-setup:$label <<<"

    mkdir -p "$(dirname "$file")"
    touch "$file"

    # Prepend an in-block warning so agents editing the file know it's managed
    # and their edits will be overwritten. Included in the block body, so it is
    # part of the content hash (consistent across write and drift detection).
    local warn="# [setup] managed block — do NOT edit between these markers; overwritten on 'setup update'. Source: LPFchan/setup"
    if [[ "$mode" != "remove" && -n "$content" ]]; then
        content="$warn"$'\n'"$content"
    fi

    _extract_block_body() {
        # Print lines between begin_mark and end_mark, exclusive.
        # Normalize: strip a single trailing newline if present.
        awk -v begin="$begin_mark" -v end="$end_mark" \
            -v old_begin="$old_begin_mark" -v old_end="$old_end_mark" '
            $0 == begin || $0 == old_begin { inblock=1; next }
            $0 == end   || $0 == old_end   { inblock=0; next }
            inblock { print }
        ' "$file" | sed '$ { /^$/ d; }'
    }

    case "$mode" in
        remove)
            if ! grep -Fq "$begin_mark" "$file" && ! grep -Fq "$old_begin_mark" "$file"; then
                return 0
            fi
            local _tmp; _tmp=$(mktemp)
            awk -v begin="$begin_mark" -v end="$end_mark" \
                -v old_begin="$old_begin_mark" -v old_end="$old_end_mark" '
                $0 == begin || $0 == old_begin { skip=1; next }
                $0 == end   || $0 == old_end   { skip=0; next }
                !skip
            ' "$file" > "$_tmp" && mv "$_tmp" "$file"
            echo "Removed $label from $file"
            ;;
        prepend|append)
            if grep -Fq "$begin_mark" "$file" || grep -Fq "$old_begin_mark" "$file"; then
                echo "Current $label -> $file"
                return 0
            fi
            if [[ "$position" == "prepend" ]]; then
                local _tmp; _tmp=$(mktemp)
                { printf '%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n\n' "$end_mark"; cat "$file"; } > "$_tmp"
                mv "$_tmp" "$file"
            else
                { printf '\n%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n' "$end_mark"; } >> "$file"
            fi
            echo "Added $label -> $file"
            ;;
        upsert)
            # printf '%s\n' so the hashed bytes end with a newline exactly like
            # the awk-extracted block body; '%s' made the hashes never match and
            # every upsert rewrote an unchanged block ("Updated" on every run).
            local new_hash; new_hash=$(printf '%s\n' "$content" | sed '$ { /^$/ d; }' | sha256)
            if ! grep -Fq "$begin_mark" "$file" && ! grep -Fq "$old_begin_mark" "$file"; then
                if [[ "$position" == "prepend" ]]; then
                    local _tmp; _tmp=$(mktemp)
                    { printf '%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n\n' "$end_mark"; cat "$file"; } > "$_tmp"
                    mv "$_tmp" "$file"
                else
                    { printf '\n%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n' "$end_mark"; } >> "$file"
                fi
                echo "Added $label -> $file"
                return 0
            fi
            local old_hash; old_hash=$(_extract_block_body | sha256)
            if [[ "$new_hash" != "$old_hash" ]]; then
                local _tmp; _tmp=$(mktemp)
                {
                    awk -v begin="$begin_mark" -v end="$end_mark" \
                        -v old_begin="$old_begin_mark" -v old_end="$old_end_mark" '
                        $0 == begin || $0 == old_begin { print; skip=1; next }
                        $0 == end   || $0 == old_end   { skip=0 }
                        !skip { print }
                    ' "$file" | while IFS= read -r line; do
                        if [[ "$line" == "$begin_mark" || "$line" == "$old_begin_mark" ]]; then
                            printf '%s\n' "$begin_mark"
                            printf '%s\n' "$content"
                        else
                            printf '%s\n' "$line"
                        fi
                    done
                } > "$_tmp" && mv "$_tmp" "$file"
                echo "Updated $file $label"
            else
                echo "Current $label -> $file"
            fi
            ;;
    esac
}

BLOCK_DELIM=$'\x1f'
# Core-owned shell scaffolding. Module-owned blocks participate in the
# canonical ordering below but are installed by their respective modules.
BLOCK_REGISTRY=(
    "zshenv${BLOCK_DELIM}path${BLOCK_DELIM}path_block${BLOCK_DELIM}upsert${BLOCK_DELIM}prepend"
)

# Canonical top→bottom order of setup-managed .zshrc blocks. Enforced by
# normalize_block_order at the end of every path that may add/rewrite a block.
ZSHRC_BLOCK_ORDER=(tmux-autostart tmux-title zsh-basics starship zsh-autocomplete zsh-syntax-highlighting ai-menu)

configure_shell() {
    local path_block

    # Migration: earlier versions named the shell-init block `zsh-ai`. Its
    # behavior now belongs to zsh-basics, which adopts it during module update.
    if [[ -f "$HOME/.zshrc" ]] && grep -Fq "# >>> setup:zsh-ai >>>" "$HOME/.zshrc"; then
        manage_block "$HOME/.zshrc" "zsh-ai" "" "remove"
    fi

    path_block='for _setup_brew in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$_setup_brew" ]]; then
        eval "$("$_setup_brew" shellenv)"
        break
    fi
done
unset _setup_brew
case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac'

    for entry in "${BLOCK_REGISTRY[@]}"; do
        IFS="$BLOCK_DELIM" read -r file_key label content_var mode position <<< "$entry"
        manage_block "$HOME/.$file_key" "$label" "${(P)content_var}" "$mode" "$position"
    done

    # Ownership migration: core used to install zsh-init on every host. Keep it
    # until an installed zsh-basics module can fold it into its own block; remove
    # the legacy orphan when zsh-basics is absent.
    if has_managed_block "$HOME/.zshrc" "zsh-init" \
       && [[ -z "$(script_state_for zsh-basics || true)" ]]; then
        manage_block "$HOME/.zshrc" "zsh-init" "" "remove"
    fi

    # Ownership migration: core used to install tmux-autostart on every host.
    # Keep the block when the tmux module is installed so that module update can
    # adopt it in place; remove the legacy orphan when the module is absent.
    if has_managed_block "$HOME/.zshrc" "tmux-autostart" \
       && [[ -z "$(script_state_for tmux || true)" ]]; then
        manage_block "$HOME/.zshrc" "tmux-autostart" "" "remove"
    fi
}

# Reorder the setup-managed blocks in <file> to match the given label order,
# preserving all unmanaged content exactly and staying idempotent.
#
#   normalize_block_order <file> <label1> <label2> ...
#
# Algorithm:
#   1. Scan the file into an ordered list of items; each item is either a
#      MANAGED BLOCK (full text from `# >>> setup:LABEL >>>` through its
#      matching `# <<< setup:LABEL <<<`, inclusive) or a run of NON-block lines.
#   2. The item positions that are blocks are "slots".
#   3. Sort present blocks by canonical order: known labels by their index in
#      the argument list; unknown labels sort AFTER all known ones, keeping
#      their original relative order (stable). Unknown blocks are never dropped.
#   4. Re-emit items in place; fill block-slots with the sorted blocks. Non-block
#      items stay exactly where they were.
#   5. Exactly one blank line separates consecutive elements; block interiors and
#      unmanaged lines are left byte-for-byte intact. Written atomically via mv.
normalize_block_order() {
    local file="$1"; shift
    [[ -f "$file" ]] || return 0
    local order=("$@")

    local tmp; tmp=$(mktemp)
    ORDER_LIST="$(printf '%s\n' "${order[@]}")" awk '
        function flush_nonblock(   i) {
            # Emit accumulated non-block lines as one item, trimming leading and
            # trailing blank lines (inter-item spacing is re-added on output).
            if (nb_count == 0) return
            start = 1; endi = nb_count
            while (start <= endi && nb[start] ~ /^[[:space:]]*$/) start++
            while (endi >= start && nb[endi] ~ /^[[:space:]]*$/) endi--
            if (start > endi) { nb_count = 0; return }
            item_type[++nitems] = "text"
            s = ""
            for (i = start; i <= endi; i++) s = s (i > start ? "\n" : "") nb[i]
            item_text[nitems] = s
            nb_count = 0
        }
        BEGIN {
            n_order = 0
            m = split(ENVIRON["ORDER_LIST"], oarr, "\n")
            for (i = 1; i <= m; i++) if (oarr[i] != "") order_idx[oarr[i]] = ++n_order
        }
        {
            if ($0 ~ /^# >>> setup:.* >>>$/) {
                flush_nonblock()
                label = $0
                sub(/^# >>> setup:/, "", label)
                sub(/ >>>$/, "", label)
                blk = $0
                inblock = 1
                item_type[++nitems] = "block"
                item_label[nitems] = label
                next
            }
            if (inblock) {
                blk = blk "\n" $0
                if ($0 ~ /^# <<< setup:.* <<<$/) {
                    inblock = 0
                    item_text[nitems] = blk
                }
                next
            }
            nb[++nb_count] = $0
        }
        END {
            flush_nonblock()

            # Collect block-slot indices and sort blocks by canonical order.
            nslots = 0
            for (i = 1; i <= nitems; i++) if (item_type[i] == "block") slot[++nslots] = i
            # Build a sort key per slot: known -> index; unknown -> big base +
            # original appearance order (stable, after all known).
            for (i = 1; i <= nslots; i++) {
                idx = slot[i]
                lbl = item_label[idx]
                if (lbl in order_idx) key[i] = order_idx[lbl]
                else key[i] = n_order + i   # keeps unknowns stable & last
                ord[i] = i
            }
            # Simple stable insertion sort on key[].
            for (i = 2; i <= nslots; i++) {
                kk = key[i]; oo = ord[i]; j = i - 1
                while (j >= 1 && key[j] > kk) { key[j+1] = key[j]; ord[j+1] = ord[j]; j-- }
                key[j+1] = kk; ord[j+1] = oo
            }
            # sorted_block_text[slotpos] = text of the block that belongs there.
            for (i = 1; i <= nslots; i++) sorted_text[i] = item_text[slot[ord[i]]]

            # Re-emit items; blocks pulled from sorted order, text as-is.
            si = 0; out = 0
            for (i = 1; i <= nitems; i++) {
                if (item_type[i] == "block") { piece = sorted_text[++si] }
                else                          { piece = item_text[i] }
                if (out++) printf "\n"      # one blank line between items
                printf "%s\n", piece
            }
        }
    ' "$file" > "$tmp" && mv "$tmp" "$file" || { rm -f "$tmp"; return 1; }
}

fetch_payload() {
    local source="$1" payload="$2"
    if fetch_source_url "$SOURCE_URL/$source" -o "$payload" 2>/dev/null \
        && grep -q '^# setup-module: ' "$payload"; then
        return 0
    fi
    echo "Failed to fetch $source from $SOURCE_URL" >&2
    return 1
}

# Run one entry point of a script-module payload in a subshell. Sourcing in
# this process would leak the module's install/update/status/uninstall
# functions and globals; a leaked `install` shadows /usr/bin/install and
# silently breaks every later file-module write (including self-update).
run_script_payload() {
    local payload="$1" fn="$2"
    (
        # shellcheck disable=SC1090
        source "$payload" || exit 1
        (( ${+functions[$fn]} )) || {
            echo "Payload defines no $fn()" >&2
            exit 1
        }
        "$fn"
    )
}

_script_install() {
    local module="$1" target="$2" source="$3"
    local payload
    payload=$(mktemp)
    if ! fetch_payload "$source" "$payload"; then
        rm -f "$payload"
        return 1
    fi
    run_script_payload "$payload" install
    local rc=$?
    rm -f "$payload"
    return $rc
}

# Run a script module's live status probe once and normalize its standardized
# output for every status surface.  The durable script state remains useful as
# an installation marker, but never decides live freshness.
#
# Fields: target, state, display status, local, remote, installed, details
script_status_fields() {
    local module="$1" target_spec="$2" source="$3"
    local payload result line rc state status_label local_label remote_label
    local target installed extra
    payload=$(mktemp)
    result=$(mktemp)
    target=$(expand_path "$target_spec")

    if ! fetch_payload "$source" "$payload"; then
        installed=$(is_script_installed "$module" && echo 1 || echo 0)
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$target" "error" "probe failed" "-" "-" "$installed" "fetch failed"
        rm -f "$payload" "$result"
        return 0
    fi

    if run_script_payload "$payload" status > "$result"; then
        rc=0
    else
        rc=$?
    fi
    line=$(awk 'NF { print; exit }' "$result")
    rm -f "$payload" "$result"

    state=$(awk 'NF { print $2; exit }' <<< "$line")
    local_label=$(sed -n 's/.* local=\([^ ]*\).*/\1/p' <<< "$line")
    remote_label=$(sed -n 's/.* remote=\([^ ]*\).*/\1/p' <<< "$line")
    [[ "$line" == *" target="* ]] && target=${line##* target=}
    local_label=${local_label:--}
    remote_label=${remote_label:--}

    case "$state:$rc" in
        current:0)
            status_label="up-to-date"; installed=1 ;;
        outdated:1)
            status_label="update available"; installed=1 ;;
        installed:0|unknown:0)
            status_label="remote unknown"; installed=1 ;;
        uninstalled:2)
            status_label="not installed"; installed=0 ;;
        *)
            state="error"; status_label="probe failed"
            installed=$(is_script_installed "$module" && echo 1 || echo 0) ;;
    esac

    if [[ "$state" == "error" ]]; then
        extra="probe failed"
    elif [[ "$local_label" != "-" || "$remote_label" != "-" ]]; then
        extra="local=$local_label remote=$remote_label"
    else
        extra=""
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$target" "$state" "$status_label" "$local_label" "$remote_label" "$installed" "$extra"
}

_script_uninstall() {
    local module="$1" target="$2" source="$3"
    local payload
    payload=$(mktemp)
    if ! fetch_payload "$source" "$payload"; then
        rm -f "$payload"
        return 1
    fi
    run_script_payload "$payload" uninstall
    local rc=$?
    rm -f "$payload"
    return $rc
}

_script_update() {
    local module="$1" target="$2" source="$3"
    local payload
    payload=$(mktemp)
    if ! fetch_payload "$source" "$payload"; then
        rm -f "$payload"
        return 1
    fi
    run_script_payload "$payload" update
    local rc=$?
    rm -f "$payload"
    return $rc
}

record_hash() {
    local target="$1" hash="$2" version="$3" tmp recorded_path old_hash old_version
    mkdir -p "$STATE_DIR"
    tmp=$(mktemp)
    if [[ -f "$HASH_FILE" ]]; then
        while IFS=$'\t' read -r recorded_path old_hash old_version; do
            [[ "$recorded_path" == "$target" ]] && continue
            printf '%s\t%s\t%s\n' "$recorded_path" "$old_hash" "${old_version:-}"
        done < "$HASH_FILE" > "$tmp"
    fi
    printf '%s\t%s\t%s\n' "$target" "$hash" "$version" >> "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_hash() {
    local target="$1" tmp recorded_path old_hash old_version
    [[ -f "$HASH_FILE" ]] || return 0
    tmp=$(mktemp)
    while IFS=$'\t' read -r recorded_path old_hash old_version; do
        [[ "$recorded_path" == "$target" ]] && continue
        printf '%s\t%s\t%s\n' "$recorded_path" "$old_hash" "${old_version:-}"
    done < "$HASH_FILE" > "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_marker_blocks() {
    local file="$1" tmp status=0
    [[ -f "$file" ]] || return 0
    tmp=$(mktemp)
    awk '
        /^# >>> linux-setup:/ { skip=1; changed=1; next }
        /^# <<< linux-setup:/ { skip=0; next }
        /^# >>> setup:/ { skip=1; changed=1; next }
        /^# <<< setup:/ { skip=0; next }
        !skip { print }
        END { if (changed) exit 42 }
    ' "$file" > "$tmp" || status=$?
    status=${status:-0}
    if [[ "$status" == 42 ]]; then
        mv "$tmp" "$file"
        echo "Updated $file"
    else
        rm -f "$tmp"
    fi
}

remove_shell_config() {
    remove_marker_blocks "$HOME/.zshenv"
    remove_marker_blocks "$HOME/.zshrc"
}

uninstall_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"

    [[ "$mode" == "script" ]] && { _script_uninstall "$module" "$target_spec" "$source"; return; }

    local target old_hash current_hash local_module
    target=$(expand_path "$target_spec")
    old_hash=$(installed_hash_for "$target" || true)

    if [[ ! -f "$target" ]]; then
        remove_hash "$target"
        echo "Missing $module -> $target"
        return 0
    fi

    if [[ -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" && "$FORCE" -ne 1 ]]; then
            echo "Local changes detected: keeping $target (use --force to remove)"
            return 0
        fi
    elif [[ "$FORCE" -ne 1 ]]; then
        local_module=$(module_for "$target" || true)
        if [[ "$local_module" != "$module" ]]; then
            echo "Untracked file: keeping $target (use --force to remove)"
            return 0
        fi
    fi

    rm -f "$target"
    remove_hash "$target"
    echo "Removed $module -> $target"
}

install_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"

    [[ "$mode" == "script" ]] && { _script_install "$module" "$target_spec" "$source"; return; }

    local target dir payload old_hash current_hash new_hash install_target remote_module remote_hash disk_hash

    target=$(expand_path "$target_spec")
    dir=$(dirname "$target")
    mkdir -p "$dir"

    payload=$(mktemp)

    fetch_payload "$source" "$payload" || { rm -f "$payload"; return 1; }
    remote_module=$(module_for "$payload" || true)

    if [[ "$remote_module" != "$module" ]]; then
        echo "Metadata mismatch for $source: expected module '$module', got '${remote_module:-missing}'" >&2
        rm -f "$payload"
        return 1
    fi

    new_hash=$(sha256 "$payload")
    old_hash=$(installed_hash_for "$target" || true)

    # Hash of the file actually on disk. Compared against the recorded hash so
    # we can detect drift: an earlier install that recorded a hash but whose
    # write failed or was interrupted leaves recorded ahead of the real file.
    disk_hash=""
    [[ -f "$target" ]] && disk_hash=$(sha256 "$target")

    # Only "current" (skip) when the remote matches the recorded hash AND the
    # on-disk file still matches that hash. Without the disk_hash check a drifted
    # file is skipped forever and `setup update` can never self-heal it — only a
    # force reinstall would. See the drift routing in the condition below.
    if [[ -f "$target" && -n "$old_hash" ]] && [[ "$new_hash" == "$old_hash" ]] \
       && [[ "$disk_hash" == "$old_hash" ]] && [[ "$FORCE" -ne 1 ]]; then
        if [[ "$module" == "refresh-models" ]]; then
            _migrate_auth_json
        fi
        echo "$module ${old_hash:0:7} (current) -> $target"
        rm -f "$payload"
        return 0
    fi

    # Route both "new content" and "disk drifted from recorded" to the normal
    # install path below (rewrite + re-record) rather than the foreign branch.
    if [[ -f "$target" && -n "$old_hash" ]] && { [[ "$new_hash" != "$old_hash" ]] || [[ "$disk_hash" != "$old_hash" ]]; }; then
        :
    elif [[ -f "$target" ]]; then
        command install -m "$mode" "$payload" "$target" || {
            echo "Failed to write $module -> $target" >&2
            rm -f "$payload"
            return 1
        }
        record_hash "$target" "$new_hash" "$new_hash"
        echo "$module ${new_hash:0:7} (foreign) -> $target"
        rm -f "$payload"
        if [[ "$module" == "refresh-models" ]]; then
            _migrate_auth_json
        fi
        if [[ "$module" == "setup" ]]; then
            echo "Restarting setup..."
            exec "$target" ${ORIG_ARGS[@]+"${ORIG_ARGS[@]}"}
        fi
        return 0
    fi

    command install -m "$mode" "$payload" "$target" || {
        echo "Failed to write $module -> $target" >&2
        rm -f "$payload"
        return 1
    }
    record_hash "$target" "$new_hash" "$new_hash"
    if [[ -n "$old_hash" && "$old_hash" != "$new_hash" ]]; then
        echo "$module ${old_hash:0:7} -> ${new_hash:0:7} -> $target"
    else
        echo "$module ${new_hash:0:7} (install) -> $target"
    fi
    if [[ "$module" == "refresh-models" ]]; then
        _migrate_auth_json
    fi
    rm -f "$payload"
    if [[ "$module" == "setup" ]]; then
        echo "Restarting setup..."
        exec "$target" ${ORIG_ARGS[@]+"${ORIG_ARGS[@]}"}
    fi
}

file_status_fields() {
    local module="$1" target_spec="$2" source="$3"
    local target remote_hash remote_label recorded_hash current_hash local_module \
          state status_label local_label installed extra

    target=$(expand_path "$target_spec")
    remote_hash=$(remote_checksum "$source" || true)
    [[ -n "$remote_hash" ]] && remote_label="${remote_hash:0:7}" || remote_label="-"

    if [[ ! -f "$target" ]]; then
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$target" "uninstalled" "not installed" "-" "$remote_label" "0" "remote=$remote_label"
        return 0
    fi

    installed=1
    current_hash=$(sha256 "$target")
    local_label="${current_hash:0:7}"
    local_module=$(module_for "$target" || true)
    recorded_hash=$(installed_hash_for "$target" || true)

    if [[ "$local_module" != "$module" ]]; then
        state="foreign"
        status_label="foreign"
        extra="current=${current_hash:0:7} remote=$remote_label"
    elif [[ -z "$recorded_hash" ]]; then
        state="untracked"
        status_label="installed (untracked)"
        extra="current=${current_hash:0:7} remote=$remote_label untracked-hash"
    elif [[ "$current_hash" != "$recorded_hash" ]]; then
        state="modified"
        status_label="modified"
        extra="recorded=${recorded_hash:0:7} current=${current_hash:0:7} remote=$remote_label"
    elif [[ -z "$remote_hash" ]]; then
        state="unknown"
        status_label="remote unknown"
        extra="local=${recorded_hash:0:7} remote=-"
    elif [[ "$recorded_hash" != "$remote_hash" ]]; then
        state="outdated"
        status_label="update available"
        extra="local=${recorded_hash:0:7} remote=${remote_hash:0:7}"
    else
        state="current"
        status_label="up-to-date"
        extra="local=${recorded_hash:0:7} remote=${remote_hash:0:7}"
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$target" "$state" "$status_label" "$local_label" "$remote_label" "$installed" "$extra"
}

status_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"

    local target state status_label local_label remote_label installed extra
    if [[ "$mode" == "script" ]]; then
        IFS=$'\t' read -r target state status_label local_label remote_label installed extra \
            < <(script_status_fields "$module" "$target_spec" "$source")
        if [[ "$local_label" == "-" && "$remote_label" == "-" ]]; then
            printf '%-25s %-12s target=%s\n' "$module" "$state" "$target"
        else
            printf '%-25s %-12s local=%s remote=%s target=%s\n' \
                "$module" "$state" "$local_label" "$remote_label" "$target"
        fi
        return
    fi

    IFS=$'\t' read -r target state status_label local_label remote_label installed extra \
        < <(file_status_fields "$module" "$target_spec" "$source")

    printf '%-25s %-12s %s target=%s\n' "$module" "$state" "$extra" "$target"
}

cmd_list() {
    fetch_manifest || return 1
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        printf '%-25s %s\n' "$module" "$target"
    done < "$MANIFEST_FILE"
}

cmd_status() {
    fetch_manifest || return 1
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            status_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    if (($# == 0)); then
        echo
        shell_status
    fi
}

shell_status() {
    shell_status_one "$HOME/.zshenv" path
}

shell_status_one() {
    local file="$1" label="$2"
    if has_managed_block "$file" "$label"; then
        printf '%-25s %-12s target=%s\n' "$label" "managed" "$file"
    else
        printf '%-25s %-12s target=%s\n' "$label" "missing" "$file"
    fi
}

cmd_install() {
    local modules=("$@")
    fetch_manifest || return 1
    local found=0 failures=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "${modules[@]}"; then
            found=1
            install_one "$module" "$target" "$mode" "$source" || { failures=$((failures + 1)); echo "Failed: install $module" >&2; }
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; return 1; }

    # Explicitly selected real service modules are enabled after installation.
    for module in "${modules[@]}"; do
        is_service_module "$module" || continue
        [[ "$(module_service_unit "$module")" != tool ]] || continue
        module_service_transition enable "$module" || failures=$((failures + 1))
    done

    normalize_block_order "$HOME/.zshrc" "${ZSHRC_BLOCK_ORDER[@]}"
    (( failures == 0 ))
}

cmd_update() {
    configure_shell || true
    fetch_manifest || return 1
    local new_count=0 new_names=() failure_count=0 failure_names=() filters=()
    local target_module setup_target setup_mode setup_source setup_local_hash
    for target_module in "$@"; do
        filters+=("$target_module")
    done
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if [[ ${#filters[@]} -gt 0 ]]; then
            local found=0
            for f in "${filters[@]}"; do
                [[ "$module" == "$f" ]] && found=1 && break
            done
            [[ "$found" -eq 0 ]] && continue
        fi
        local target_path local_hash disk_hash_before disk_hash_after was_active
        target_path=$(expand_path "$target")
        if [[ "$mode" == "script" ]]; then
            local script_target script_state script_status script_local script_remote script_installed script_extra
            IFS=$'\t' read -r script_target script_state script_status script_local script_remote script_installed script_extra \
                < <(script_status_fields "$module" "$target" "$source")
            case "$script_state" in
                current)
                    ;;
                outdated)
                    if ! _script_update "$module" "$target" "$source"; then
                        echo "Warning: $module update failed." >&2
                        failure_count=$((failure_count + 1))
                        failure_names+=("$module")
                    fi
                    ;;
                uninstalled)
                    new_count=$((new_count + 1))
                    new_names+=("$module")
                    ;;
                installed|unknown)
                    echo "Warning: could not determine whether $module is current; skipping update." >&2
                    failure_count=$((failure_count + 1))
                    failure_names+=("$module")
                    ;;
                *)
                    echo "Warning: could not probe $module; skipping update." >&2
                    failure_count=$((failure_count + 1))
                    failure_names+=("$module")
                    ;;
            esac
        else
            local_hash=$(installed_hash_for "$target_path" || true)
            if [[ "$module" == "setup" ]]; then
                setup_target="$target"; setup_mode="$mode"; setup_source="$source"
                setup_local_hash="$local_hash"
                continue
            fi
            if [[ -z "$local_hash" ]]; then
                new_count=$((new_count + 1))
                new_names+=("$module")
            else
                disk_hash_before=$(sha256 "$target_path" 2>/dev/null || true)
                was_active=0
                if is_service_module "$module" \
                    && [[ "$(module_service_unit "$module" 2>/dev/null || true)" != tool ]] \
                    && module_is_active "$module"; then
                    was_active=1
                fi
                if ! install_one "$module" "$target" "$mode" "$source"; then
                    echo "Warning: $module update failed." >&2
                    failure_count=$((failure_count + 1))
                    failure_names+=("$module")
                else
                    disk_hash_after=$(sha256 "$target_path" 2>/dev/null || true)
                    if ((was_active == 1)) && [[ "$disk_hash_before" != "$disk_hash_after" ]]; then
                        if ! module_service_transition enable "$module"; then
                            echo "Warning: $module updated but could not restore its active service state." >&2
                            failure_count=$((failure_count + 1))
                            failure_names+=("$module")
                        fi
                    fi
                fi
            fi
        fi
    done < "$MANIFEST_FILE"
    # Update setup last — self-update exec restarts the process
    if [[ -n "${setup_target:-}" ]] && [[ -n "${setup_local_hash:-}" ]]; then
        if ! install_one setup "$setup_target" "$setup_mode" "$setup_source"; then
            echo "Warning: setup update failed." >&2
            failure_count=$((failure_count + 1))
            failure_names+=(setup)
        fi
    fi
    # All .zshrc blocks now exist (configure_shell + module loop); enforce order.
    normalize_block_order "$HOME/.zshrc" "${ZSHRC_BLOCK_ORDER[@]}"
    echo
    if [[ "$new_count" -gt 0 ]]; then
        echo "$new_count new module(s) available: ${new_names[*]}"
        echo "Run 'setup' to select what to install."
    fi
    if [[ "$failure_count" -gt 0 ]]; then
        echo "$failure_count module(s) could not be updated: ${failure_names[*]}" >&2
    elif [[ "$new_count" -eq 0 ]]; then
        echo "All modules up to date."
    fi
    (( failure_count == 0 ))
}

cmd_uninstall() {
    fetch_manifest || return 1
    local found=0 failures=0 target_path
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            if (($# > 0)) && is_service_module "$module" && [[ "$(module_service_unit "$module")" != tool ]]; then
                if ! module_service_transition disable "$module"; then
                    failures=$((failures + 1))
                    echo "Failed: disable $module before uninstall; target retained" >&2
                    continue
                fi
            fi
            if uninstall_one "$module" "$target" "$mode" "$source"; then
                if [[ "$mode" == script ]]; then
                    if is_script_installed "$module"; then failures=$((failures + 1)); echo "Failed: uninstall $module (still installed)" >&2; fi
                else
                    target_path=$(expand_path "$target")
                    if [[ -e "$target_path" ]]; then failures=$((failures + 1)); echo "Failed: uninstall $module (target retained)" >&2; fi
                fi
            else
                failures=$((failures + 1)); echo "Failed: uninstall $module" >&2
            fi
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; return 1; }

    if (($# == 0)); then
        remove_shell_config
        rm -f "$MANIFEST_FILE" "$HASH_FILE"
        rmdir "$STATE_DIR" 2>/dev/null || true
    fi
    (( failures == 0 ))
}

cmd_diff() {
    fetch_manifest || return 1
    local module target mode source local_path payload found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        module_selected "$module" "$@" || continue
        [[ "$mode" == "script" ]] && continue
        found=1
        local_path=$(expand_path "$target")
        payload=$(mktemp)
        fetch_payload "$source" "$payload"
        if [[ -f "$local_path" ]]; then
            diff -u "$local_path" "$payload" || true
        else
            echo "Missing: $local_path"
        fi
        rm -f "$payload"
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }
}

cmd_enable() {
    local modules=("$@") module failures=0
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        if ! is_service_module "$module" || [[ "$(module_service_unit "$module" 2>/dev/null || true)" == tool ]]; then
            echo "Not an enable/disable service: $module" >&2
            failures=$((failures + 1))
            continue
        fi
        module_service_transition enable "$module" || failures=$((failures + 1))
    done
    (( failures == 0 ))
}

cmd_disable() {
    local modules=("$@") module failures=0
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        if ! is_service_module "$module" || [[ "$(module_service_unit "$module" 2>/dev/null || true)" == tool ]]; then
            echo "Not an enable/disable service: $module" >&2
            failures=$((failures + 1))
            continue
        fi
        module_service_transition disable "$module" || failures=$((failures + 1))
    done
    (( failures == 0 ))
}

cmd_doctor() {
    local missing=0 tool
    for tool in awk cat curl diff dirname git grep install mktemp mv rm rmdir; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            echo "missing: $tool"
            missing=1
        fi
    done
    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        echo "missing: sha256sum or shasum"
        missing=1
    fi
    ((missing == 0)) && echo "ok"
    return "$missing"
}

AUTOUPDATE_SERVICE_UNIT="[Unit]
Description=Daily setup update check

[Service]
Type=oneshot
ExecStart=%h/.local/bin/setup update
"

AUTOUPDATE_TIMER_UNIT="[Unit]
Description=Daily setup update

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
"

cmd_schedule() {
    if [[ "${1:-}" == "status" ]]; then
        shift
        (($# == 0)) || { echo "Usage: setup schedule status" >&2; return 2; }
        cmd_schedule_status
        return
    fi
    (($# == 0)) || { echo "Usage: setup schedule [status]" >&2; return 2; }

    local script_path
    script_path="$(command -v setup 2>/dev/null || echo "$HOME/.local/bin/setup")"
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local plist_dir="$HOME/Library/LaunchAgents"
        local plist="$plist_dir/com.lost.plus.setup-update.plist"
        mkdir -p "$plist_dir"
        cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lost.plus.setup-update</string>
    <key>ProgramArguments</key>
    <array>
        <string>$script_path</string>
        <string>update</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>3</integer>
        <key>Minute</key><integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/setup-update.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/setup-update.log</string>
</dict>
</plist>
PLIST
        local _uid; _uid=$(id -u)
        launchctl bootout "gui/$_uid/com.lost.plus.setup-update" 2>/dev/null || true
        launchctl bootstrap "gui/$_uid" "$plist" 2>/dev/null || true
        echo "setup auto-update scheduled daily at 03:00 (launchd)"
    else
        local dir="$HOME/.config/systemd/user"
        mkdir -p "$dir"
        echo "$AUTOUPDATE_SERVICE_UNIT" > "$dir/setup-update.service"
        echo "$AUTOUPDATE_TIMER_UNIT" > "$dir/setup-update.timer"
        systemctl --user daemon-reload
        systemctl --user enable --now setup-update.timer
        echo "setup auto-update scheduled daily (systemd)"
    fi
}

cmd_schedule_status() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local label="com.lost.plus.setup-update"
        local plist="$HOME/Library/LaunchAgents/$label.plist"
        local _uid; _uid=$(id -u)
        if [[ ! -f "$plist" ]]; then
            echo "setup auto-update not scheduled (launchd)"
            return 1
        fi
        if launchctl print "gui/$_uid/$label" >/dev/null 2>&1; then
            echo "setup auto-update scheduled daily at 03:00 (launchd, loaded)"
            return 0
        fi
        echo "setup auto-update configured but not loaded (launchd)"
        return 1
    fi

    local timer="$HOME/.config/systemd/user/setup-update.timer"
    if [[ ! -f "$timer" ]]; then
        echo "setup auto-update not scheduled (systemd)"
        return 1
    fi
    local enabled="no" active="no"
    systemctl --user is-enabled --quiet setup-update.timer 2>/dev/null && enabled="yes"
    systemctl --user is-active --quiet setup-update.timer 2>/dev/null && active="yes"
    if [[ "$enabled" == "yes" && "$active" == "yes" ]]; then
        echo "setup auto-update scheduled daily (systemd, enabled and active)"
        return 0
    fi
    echo "setup auto-update configured but inactive (systemd, enabled=$enabled active=$active)"
    return 1
}

systemctl_inactive_state() {
    local state="$1" rc="$2"
    case "$state:$rc" in
        inactive:3|failed:3) return 0 ;;
        *) return 1 ;;
    esac
}

systemctl_disabled_state() {
    local state="$1" rc="$2"
    case "$state:$rc" in
        disabled:1) return 0 ;;
        *) return 1 ;;
    esac
}

cmd_unschedule() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local plist="$HOME/Library/LaunchAgents/com.lost.plus.setup-update.plist"
        local _uid output rc
        _uid=$(id -u)
        if output=$(launchctl bootout "gui/$_uid/com.lost.plus.setup-update" 2>&1); then
            :
        else
            rc=$?
            # launchctl reports an already-unloaded job as "Could not find
            # service" / "No such process". That is the desired terminal state.
            case "$output" in
                *"Could not find service"*|*"No such process"*) ;;
                *)
                    echo "setup: failed to unload auto-update launchd job; retaining $plist" >&2
                    [[ -n "$output" ]] && echo "$output" >&2
                    return "$rc"
                    ;;
            esac
        fi
        rm -f "$plist" || return 1
        echo "setup auto-update unscheduled"
    else
        local timer="$HOME/.config/systemd/user/setup-update.timer"
        local service="$HOME/.config/systemd/user/setup-update.service"
        if ! systemctl --user disable --now setup-update.timer; then
            # A failed disable may mean the desired state already holds, but
            # quiet nonzero statuses are ambiguous with D-Bus/user-manager
            # errors. Accept only successful textual queries with documented,
            # explicitly inactive + disabled terminal values.
            local active_state enabled_state active_rc enabled_rc
            if active_state=$(systemctl --user is-active setup-update.timer 2>/dev/null); then active_rc=0; else active_rc=$?; fi
            if enabled_state=$(systemctl --user is-enabled setup-update.timer 2>/dev/null); then enabled_rc=0; else enabled_rc=$?; fi
            if systemctl_inactive_state "$active_state" "$active_rc" \
               && systemctl_disabled_state "$enabled_state" "$enabled_rc"; then
                :
            else
                echo "setup: failed to disable auto-update timer; state indeterminate or still enabled/active; retaining $service and $timer" >&2
                return 1
            fi
        fi
        rm -f "$service" "$timer" || return 1
        systemctl --user daemon-reload || {
            echo "setup: removed units but daemon-reload failed" >&2
            return 1
        }
        echo "setup auto-update unscheduled"
    fi
}

# --- fzf interactive reconfigure ------------------------------------

detect_env_summary() {
    local os arch distro fs
    os=$(uname -s)
    arch=$(uname -m)
    if [[ -f /etc/os-release ]]; then
        distro=$(. /etc/os-release && echo "${NAME} ${VERSION_ID}")
    else
        distro="${os}"
    fi
    if [[ "$(uname -s)" == "Darwin" ]]; then
        fs=$(diskutil info / 2>/dev/null | awk '/File System/ {print $3}' || true)
        [[ -z "$fs" ]] && fs="unknown"
    else
        fs=$(stat -f -c '%T' / 2>/dev/null || echo "unknown")
    fi
    echo "${os} ${arch} · ${distro} · ${fs}"
}

_setup_picker_selection_has() {
    grep -Fqx -- "$1" "$SETUP_PICKER_SELECTION_FILE" 2>/dev/null
}

_setup_state_needs_update() {
    case "$1" in
        outdated|modified|unknown) return 0 ;;
        *) return 1 ;;
    esac
}

_setup_picker_header() {
    local selected total
    selected=$(wc -l < "$SETUP_PICKER_SELECTION_FILE")
    total=$(wc -l < "$SETUP_PICKER_SNAPSHOT_FILE")
    printf '%d/%d · %s · Enter=toggle/open/action · Esc=finish\n' \
        "$selected" "$total" "$SETUP_PICKER_ENV_SUMMARY"
}

_setup_picker_action_counts() {
    local m t mo s state installed svc active detail
    SETUP_PICKER_INSTALL_N=0
    SETUP_PICKER_UPDATE_N=0
    SETUP_PICKER_REINSTALL_N=0
    SETUP_PICKER_UNINSTALL_N=0
    SETUP_PICKER_ENABLE_N=0
    SETUP_PICKER_DISABLE_N=0
    while IFS=$'\t' read -r m t mo s state installed svc active detail; do
        _setup_picker_selection_has "$m" || continue
        [[ "$installed" == 0 ]] && SETUP_PICKER_INSTALL_N=$((SETUP_PICKER_INSTALL_N + 1))
        [[ "$installed" == 1 ]] && _setup_state_needs_update "$state" && SETUP_PICKER_UPDATE_N=$((SETUP_PICKER_UPDATE_N + 1))
        [[ "$installed" == 1 ]] && SETUP_PICKER_REINSTALL_N=$((SETUP_PICKER_REINSTALL_N + 1))
        [[ "$installed" == 1 && "$m" != fzf-multicolumn ]] && SETUP_PICKER_UNINSTALL_N=$((SETUP_PICKER_UNINSTALL_N + 1))
        [[ "$installed" == 1 && "$svc" == 1 && "$active" == 0 ]] && SETUP_PICKER_ENABLE_N=$((SETUP_PICKER_ENABLE_N + 1))
        [[ "$installed" == 1 && "$svc" == 1 && "$active" == 1 ]] && SETUP_PICKER_DISABLE_N=$((SETUP_PICKER_DISABLE_N + 1))
    done < "$SETUP_PICKER_SNAPSHOT_FILE"
    if (( SETUP_PICKER_ENABLE_N > 0 )); then
        SETUP_PICKER_SERVICE_ACTION=enable
        SETUP_PICKER_SERVICE_N=$SETUP_PICKER_ENABLE_N
    else
        SETUP_PICKER_SERVICE_ACTION=disable
        SETUP_PICKER_SERVICE_N=$SETUP_PICKER_DISABLE_N
    fi
    SETUP_PICKER_VISIBLE_ACTIONS=0
    (( SETUP_PICKER_INSTALL_N > 0 )) && SETUP_PICKER_VISIBLE_ACTIONS=$((SETUP_PICKER_VISIBLE_ACTIONS + 1))
    (( SETUP_PICKER_UPDATE_N > 0 )) && SETUP_PICKER_VISIBLE_ACTIONS=$((SETUP_PICKER_VISIBLE_ACTIONS + 1))
    (( SETUP_PICKER_REINSTALL_N > 0 )) && SETUP_PICKER_VISIBLE_ACTIONS=$((SETUP_PICKER_VISIBLE_ACTIONS + 1))
    (( SETUP_PICKER_UNINSTALL_N > 0 )) && SETUP_PICKER_VISIBLE_ACTIONS=$((SETUP_PICKER_VISIBLE_ACTIONS + 1))
    (( SETUP_PICKER_SERVICE_N > 0 )) && SETUP_PICKER_VISIBLE_ACTIONS=$((SETUP_PICKER_VISIBLE_ACTIONS + 1))
}

_setup_picker_render() {
    local delim="$SETUP_PICKER_DELIM" selected total top_mark='[ ]'
    local row m t mo s state installed svc active detail mark detail_header="${SETUP_PICKER_DETAIL_HEADER:-}"
    local -a action_rows=()
    local i last_span
    selected=$(wc -l < "$SETUP_PICKER_SELECTION_FILE")
    total=$(wc -l < "$SETUP_PICKER_SNAPSHOT_FILE")
    [[ -f "${SETUP_PICKER_DETAIL_HEADER_FILE:-}" ]] && detail_header=$(<"$SETUP_PICKER_DETAIL_HEADER_FILE")
    (( selected == total && total > 0 )) && top_mark='[*]'
    if (( selected == 0 )); then
        printf 'select-all%sall%s%s%s\n' "$delim" "$delim" "$top_mark" "$delim"
        printf '@@5@@all-menu%sall%s%s%s\n' "$delim" "$delim" "$detail_header" "$delim"
    else
        _setup_picker_action_counts
        printf 'select-all%sall%s%s%s\n' "$delim" "$delim" "$top_mark" "$delim"
        (( SETUP_PICKER_INSTALL_N > 0 )) && action_rows+=("action${delim}install${delim}Install $SETUP_PICKER_INSTALL_N${delim}")
        (( SETUP_PICKER_UPDATE_N > 0 )) && action_rows+=("action${delim}update${delim}Update $SETUP_PICKER_UPDATE_N${delim}")
        (( SETUP_PICKER_REINSTALL_N > 0 )) && action_rows+=("action${delim}reinstall${delim}Reinstall $SETUP_PICKER_REINSTALL_N${delim}")
        (( SETUP_PICKER_UNINSTALL_N > 0 )) && action_rows+=("action${delim}uninstall${delim}Uninstall $SETUP_PICKER_UNINSTALL_N${delim}")
        if (( SETUP_PICKER_SERVICE_N > 0 )); then
            action_rows+=("action${delim}${SETUP_PICKER_SERVICE_ACTION}${delim}$([[ "$SETUP_PICKER_SERVICE_ACTION" == enable ]] && echo Enable || echo Disable) $SETUP_PICKER_SERVICE_N${delim}")
        fi
        last_span=$((6 - SETUP_PICKER_VISIBLE_ACTIONS))
        for ((i = 0; i < ${#action_rows[@]}; i++)); do
            if (( i == ${#action_rows[@]} - 1 && last_span > 1 )); then
                printf '@@%d@@%s\n' "$last_span" "${action_rows[i]}"
            else
                printf '%s\n' "${action_rows[i]}"
            fi
        done
    fi
    while IFS=$'\t' read -r m t mo s state installed svc active detail; do
        _setup_picker_selection_has "$m" && mark='[*]' || mark='[ ]'
        printf 'checkbox%s%s%s%s%s\n' "$delim" "$m" "$delim" "$mark" "$delim"
        printf '@@5@@module%s%s%s%s%s\n' "$delim" "$m" "$delim" "$detail" "$delim"
    done < "$SETUP_PICKER_SNAPSHOT_FILE"
}

_setup_picker_toggle() {
    local kind="$1" key="$2" selected total tmp
    case "$kind" in
        checkbox)
            tmp="$SETUP_PICKER_SELECTION_FILE.new.$$"
            if _setup_picker_selection_has "$key"; then
                grep -Fvx -- "$key" "$SETUP_PICKER_SELECTION_FILE" > "$tmp" || true
            else
                cp "$SETUP_PICKER_SELECTION_FILE" "$tmp"
                printf '%s\n' "$key" >> "$tmp"
            fi
            mv "$tmp" "$SETUP_PICKER_SELECTION_FILE"
            ;;
        select-all)
            selected=$(wc -l < "$SETUP_PICKER_SELECTION_FILE")
            total=$(wc -l < "$SETUP_PICKER_SNAPSHOT_FILE")
            if (( selected == total && total > 0 )); then
                : > "$SETUP_PICKER_SELECTION_FILE"
            else
                : > "$SETUP_PICKER_SELECTION_FILE"
                while IFS=$'\t' read -r key _; do printf '%s\n' "$key"; done \
                    < "$SETUP_PICKER_SNAPSHOT_FILE" > "$SETUP_PICKER_SELECTION_FILE"
            fi
            ;;
        *) return 1 ;;
    esac
}

_setup_picker_position() {
    local kind="$1" key="$2" selected base=3 index=0 row module pos
    case "$kind" in
        select-all) echo 1; return ;;
        action)
            _setup_picker_action_counts
            pos=2
            if (( SETUP_PICKER_INSTALL_N > 0 )); then [[ "$key" == install ]] && { echo "$pos"; return; }; pos=$((pos + 1)); fi
            if (( SETUP_PICKER_UPDATE_N > 0 )); then [[ "$key" == update ]] && { echo "$pos"; return; }; pos=$((pos + 1)); fi
            if (( SETUP_PICKER_REINSTALL_N > 0 )); then [[ "$key" == reinstall ]] && { echo "$pos"; return; }; pos=$((pos + 1)); fi
            if (( SETUP_PICKER_UNINSTALL_N > 0 )); then [[ "$key" == uninstall ]] && { echo "$pos"; return; }; pos=$((pos + 1)); fi
            if (( SETUP_PICKER_SERVICE_N > 0 )) && [[ "$key" == "$SETUP_PICKER_SERVICE_ACTION" ]]; then echo "$pos"; return; fi
            echo 1
            return
            ;;
    esac
    selected=$(wc -l < "$SETUP_PICKER_SELECTION_FILE")
    if (( selected > 0 )); then
        _setup_picker_action_counts
        base=$((2 + SETUP_PICKER_VISIBLE_ACTIONS))
    fi
    while IFS=$'\t' read -r module _; do
        if [[ "$module" == "$key" ]]; then
            [[ "$kind" == module ]] && echo $((base + index * 2 + 1)) || echo $((base + index * 2))
            return
        fi
        index=$((index + 1))
    done < "$SETUP_PICKER_SNAPSHOT_FILE"
    echo 1
}

_setup_picker_transform() {
    local kind="$1" key="$2" pos
    case "$kind" in
        checkbox|select-all)
            _setup_picker_toggle "$kind" "$key" || return
            pos=$(_setup_picker_position "$kind" "$key")
            printf '%d\n' "$pos" > "$SETUP_PICKER_POSITION_FILE"
            echo 'reload-sync("$SETUP_PICKER_CALLBACK_SCRIPT" _setup_picker_render)'
            ;;
        module|action|all-menu) echo accept ;;
    esac
}

_setup_picker_result_transform() {
    local pos
    read -r pos < "$SETUP_PICKER_POSITION_FILE" || return 0
    : > "$SETUP_PICKER_POSITION_FILE"
    case "$pos" in
        ''|*[!0-9]*) return 0 ;;
        *) printf 'pos(%d)\n' "$pos" ;;
    esac
}

picker_has_span_capability() {
    local picker="$1" help
    [[ -x "$picker" ]] || return 1
    help=$("$picker" --help 2>&1) || return 1
    [[ "$help" == *--grid-span-prefix* ]]
}

managed_picker() {
    local picker="$HOME/.local/bin/fzf-multicolumn"
    picker_has_span_capability "$picker" && printf '%s\n' "$picker"
}

bootstrap_managed_picker() {
    local picker="$HOME/.local/bin/fzf-multicolumn"
    picker_has_span_capability "$picker" && return 0

    fetch_manifest || return 1
    local module target mode source found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ "$module" == "fzf-multicolumn" ]] || continue
        found=1
        echo "Bootstrapping managed span-aware picker..."
        _script_install "$module" "$target" "$source" || return 1
        break
    done < "$MANIFEST_FILE"
    (( found == 1 )) || { echo "setup: fzf-multicolumn is missing from the manifest" >&2; return 1; }
    picker_has_span_capability "$picker" || {
        echo "setup: installed picker does not advertise --grid-span-prefix" >&2
        return 1
    }
}

confirm_action() {
    local prompt="$1" answer picker
    picker=$(managed_picker || true)
    if [[ -n "$picker" && -t 0 && -t 1 ]]; then
        answer=$(printf '%s\n' yes no | "$picker" \
            --layout=reverse \
            --height=8 \
            --cycle \
            --bind='esc:abort' \
            --header="$prompt" || true)
    else
        printf '%s [y/N] ' "$prompt" >&2
        read -r answer </dev/tty 2>/dev/null || answer=""
        case "$answer" in
            y|Y|yes|YES|Yes) answer="yes" ;;
            *) answer="no" ;;
        esac
    fi

    if [[ "$answer" == "yes" ]]; then
        echo "Confirmed: $prompt"
        return 0
    fi
    echo "Canceled: $prompt"
    return 1
}

cmd_reconfigure() {
    fetch_manifest || return 1
    fetch_checksums
    local picker env_summary delim=$'\x1f' picker_state_dir picker_callbacks
    picker=$(managed_picker) || {
        echo "setup: managed picker is unavailable; run 'setup install fzf-multicolumn' and retry" >&2
        return 1
    }
    env_summary="$(hostname -s) · $(detect_env_summary)"
    picker_state_dir=$(mktemp -d)
    SETUP_PICKER_SNAPSHOT_FILE="$picker_state_dir/snapshot.tsv"
    SETUP_PICKER_SELECTION_FILE="$picker_state_dir/selected"
    SETUP_PICKER_POSITION_FILE="$picker_state_dir/position"
    SETUP_PICKER_DETAIL_HEADER_FILE="$picker_state_dir/detail-header"
    picker_callbacks="$picker_state_dir/callbacks.zsh"
    SETUP_PICKER_CALLBACK_SCRIPT="$picker_callbacks"
    SETUP_PICKER_DELIM="$delim"
    SETUP_PICKER_ENV_SUMMARY="$env_summary"
    SETUP_PICKER_DETAIL_HEADER=""
    export SETUP_PICKER_SNAPSHOT_FILE SETUP_PICKER_SELECTION_FILE SETUP_PICKER_POSITION_FILE SETUP_PICKER_DETAIL_HEADER_FILE SETUP_PICKER_DELIM \
        SETUP_PICKER_ENV_SUMMARY SETUP_PICKER_DETAIL_HEADER SETUP_PICKER_CALLBACK_SCRIPT
    {
        printf '%s\n' '#!/usr/bin/env zsh' 'emulate -R zsh' 'setopt KSH_ARRAYS SH_WORD_SPLIT NO_UNSET PIPE_FAIL'
        functions _setup_picker_selection_has _setup_state_needs_update _setup_picker_header \
            _setup_picker_action_counts _setup_picker_render _setup_picker_toggle \
            _setup_picker_position _setup_picker_transform _setup_picker_result_transform
        printf '%s\n' '"$@"'
    } > "$picker_callbacks"
    chmod 0700 "$picker_callbacks"
    : > "$SETUP_PICKER_SNAPSHOT_FILE"
    : > "$SETUP_PICKER_SELECTION_FILE"
    : > "$SETUP_PICKER_POSITION_FILE"
    : > "$SETUP_PICKER_DETAIL_HEADER_FILE"

    # Indexed state shared by the parent zsh process and picker callbacks. Rows are:
    # module<TAB>target<TAB>mode<TAB>source<TAB>state<TAB>installed<TAB>service<TAB>active<TAB>detail
    local -a selected_modules=() snapshot=()
    local detail_header=""

    selection_has() {
        local wanted="$1" item
        for item in "${selected_modules[@]}"; do [[ "$item" == "$wanted" ]] && return 0; done
        return 1
    }
    selection_add() {
        selection_has "$1" || selected_modules+=("$1")
    }
    selection_remove() {
        local wanted="$1" item out=()
        for item in "${selected_modules[@]}"; do [[ "$item" == "$wanted" ]] || out+=("$item"); done
        selected_modules=("${out[@]}")
    }
    selection_toggle() {
        if selection_has "$1"; then selection_remove "$1"; else selection_add "$1"; fi
    }
    snapshot_refresh() {
        snapshot=()
        local -a raw_snapshot=()
        local m t mo s target state status_label local_label remote_label installed extra svc=0 active=0 detail service_label row
        local w_module=6 w_local=5 w_service=7 w_remote=6
        while IFS=$'\t' read -r m t mo s; do
            [[ -z "${m:-}" || "$m" == \#* ]] && continue
            if [[ "$mo" == script ]]; then
                IFS=$'\t' read -r target state status_label local_label remote_label installed extra \
                    < <(script_status_fields "$m" "$t" "$s")
            else
                IFS=$'\t' read -r target state status_label local_label remote_label installed extra \
                    < <(file_status_fields "$m" "$t" "$s")
            fi
            svc=0; active=0
            if is_service_module "$m" && [[ "$(module_service_unit "$m")" != tool ]]; then
                svc=1
                [[ "$installed" == 1 ]] && module_is_active "$m" && active=1
            fi
            if [[ "$svc" == 1 ]]; then
                [[ "$active" == 1 ]] && service_label=active || service_label=inactive
            else
                [[ "$installed" == 1 ]] && service_label=installed || service_label=uninstalled
            fi
            raw_snapshot+=("$m"$'\t'"$t"$'\t'"$mo"$'\t'"$s"$'\t'"$state"$'\t'"$installed"$'\t'"$svc"$'\t'"$active"$'\t'"$local_label"$'\t'"$service_label"$'\t'"$remote_label"$'\t'"$status_label")
            (( ${#m} > w_module )) && w_module=${#m}
            (( ${#local_label} > w_local )) && w_local=${#local_label}
            (( ${#service_label} > w_service )) && w_service=${#service_label}
            (( ${#remote_label} > w_remote )) && w_remote=${#remote_label}
        done < "$MANIFEST_FILE"
        printf -v detail_header '%-*s  %-*s  %-*s  %-*s  %s' \
            "$w_module" module "$w_local" local "$w_service" service "$w_remote" remote status
        for row in "${raw_snapshot[@]}"; do
            IFS=$'\t' read -r m t mo s state installed svc active local_label service_label remote_label status_label <<< "$row"
            printf -v detail '%-*s  %-*s  %-*s  %-*s  %s' \
                "$w_module" "$m" "$w_local" "$local_label" "$w_service" "$service_label" "$w_remote" "$remote_label" "$status_label"
            snapshot+=("$m"$'\t'"$t"$'\t'"$mo"$'\t'"$s"$'\t'"$state"$'\t'"$installed"$'\t'"$svc"$'\t'"$active"$'\t'"$detail")
        done
    }
    snapshot_field() {
        local wanted="$1" field="$2" row m t mo s state installed svc active detail
        for row in "${snapshot[@]}"; do
            IFS=$'\t' read -r m t mo s state installed svc active detail <<< "$row"
            [[ "$m" == "$wanted" ]] || continue
            case "$field" in
                target) printf '%s\n' "$t" ;; mode) printf '%s\n' "$mo" ;; source) printf '%s\n' "$s" ;;
                state) printf '%s\n' "$state" ;; installed) printf '%s\n' "$installed" ;;
                service) printf '%s\n' "$svc" ;; active) printf '%s\n' "$active" ;;
            esac
            return
        done
    }
    eligible_count() {
        local action="$1" m state installed svc active n=0
        for m in "${selected_modules[@]}"; do
            state=$(snapshot_field "$m" state); installed=$(snapshot_field "$m" installed)
            svc=$(snapshot_field "$m" service); active=$(snapshot_field "$m" active)
            case "$action" in
                install) [[ "$installed" == 0 ]] && n=$((n + 1)) ;;
                update) [[ "$installed" == 1 ]] && _setup_state_needs_update "$state" && n=$((n + 1)) ;;
                reinstall) [[ "$installed" == 1 ]] && n=$((n + 1)) ;;
                uninstall) [[ "$installed" == 1 && "$m" != fzf-multicolumn ]] && n=$((n + 1)) ;;
                enable) [[ "$installed" == 1 && "$svc" == 1 && "$active" == 0 ]] && n=$((n + 1)) ;;
                disable) [[ "$installed" == 1 && "$svc" == 1 && "$active" == 1 ]] && n=$((n + 1)) ;;
            esac
        done
        printf '%s\n' "$n"
    }
    capitalize() {
        case "$1" in
            install) echo Install ;; update) echo Update ;; reinstall) echo Reinstall ;;
            uninstall) echo Uninstall ;; enable) echo Enable ;; disable) echo Disable ;;
            *) printf '%s\n' "$1" ;;
        esac
    }
    sync_picker_state() {
        : > "$SETUP_PICKER_SNAPSHOT_FILE"
        ((${#snapshot[@]} == 0)) || printf '%s\n' "${snapshot[@]}" > "$SETUP_PICKER_SNAPSHOT_FILE"
        : > "$SETUP_PICKER_SELECTION_FILE"
        ((${#selected_modules[@]} == 0)) || printf '%s\n' "${selected_modules[@]}" > "$SETUP_PICKER_SELECTION_FILE"
        SETUP_PICKER_DETAIL_HEADER="$detail_header"
        export SETUP_PICKER_DETAIL_HEADER
        printf '%s\n' "$detail_header" > "$SETUP_PICKER_DETAIL_HEADER_FILE"
    }
    load_picker_snapshot() {
        local row
        snapshot=()
        while IFS= read -r row; do [[ -n "$row" ]] && snapshot+=("$row"); done \
            < "$SETUP_PICKER_SNAPSHOT_FILE"
        [[ -f "$SETUP_PICKER_DETAIL_HEADER_FILE" ]] && detail_header=$(<"$SETUP_PICKER_DETAIL_HEADER_FILE")
    }
    load_picker_selection() {
        local item
        selected_modules=()
        while IFS= read -r item; do [[ -n "$item" ]] && selected_modules+=("$item"); done \
            < "$SETUP_PICKER_SELECTION_FILE"
    }
    action_summary() {
        local action="$1" attempted="$2" succeeded="$3" failed="$4" skipped="$5"
        echo "$(capitalize "$action"): attempted=$attempted succeeded=$succeeded failed=$failed skipped=$skipped"
        (( failed == 0 ))
    }
    run_service_action() {
        local action="$1" m cmd attempted=0 succeeded=0 failed=0 skipped=0 installed svc active
        for m in "${selected_modules[@]}"; do
            installed=$(snapshot_field "$m" installed); svc=$(snapshot_field "$m" service); active=$(snapshot_field "$m" active)
            if [[ "$installed" == 1 && "$svc" == 1 ]] && { [[ "$action" == enable && "$active" == 0 ]] || [[ "$action" == disable && "$active" == 1 ]]; }; then
                attempted=$((attempted + 1))
                if [[ "$action" == enable ]]; then cmd=$(module_enable_cmd "$m"); else cmd=$(module_disable_cmd "$m"); fi
                if module_service_transition "$action" "$m"; then
                    succeeded=$((succeeded + 1))
                else
                    failed=$((failed + 1))
                fi
            else skipped=$((skipped + 1))
            fi
        done
        action_summary "$action" "$attempted" "$succeeded" "$failed" "$skipped"
    }
    run_module_action() {
        local action="$1" ask_confirmation="${2:-1}" allow_current_update="${3:-0}"
        local m row t mo s state installed svc active attempted=0 succeeded=0 failed=0 skipped=0 old_force=$FORCE setup_row=""
        module_action_ran=0
        if (( ask_confirmation == 1 )) && [[ "$action" == uninstall || "$action" == reinstall ]]; then
            confirm_action "$(capitalize "$action") eligible selected modules?" || return 0
        fi
        module_action_ran=1
        [[ "$action" == reinstall ]] && FORCE=1
        for row in "${snapshot[@]}"; do
            IFS=$'\t' read -r m t mo s state installed svc active _ <<< "$row"
            selection_has "$m" || continue
            case "$action" in
                install) [[ "$installed" == 0 ]] || { skipped=$((skipped + 1)); continue; } ;;
                update)
                    [[ "$installed" == 1 ]] \
                        && { [[ "$allow_current_update" == 1 ]] || _setup_state_needs_update "$state"; } \
                        || { skipped=$((skipped + 1)); continue; }
                    ;;
                reinstall) [[ "$installed" == 1 ]] || { skipped=$((skipped + 1)); continue; } ;;
                uninstall) [[ "$installed" == 1 && "$m" != fzf-multicolumn ]] || { skipped=$((skipped + 1)); continue; } ;;
            esac
            attempted=$((attempted + 1))
            # setup is always last because install_one may exec the new CLI.
            if [[ "$m" == setup ]]; then setup_row="$row"; continue; fi
            local ok=0 target_path
            case "$action" in
                install|reinstall) install_one "$m" "$t" "$mo" "$s" && ok=1 ;;
                update)
                    if [[ "$mo" == script ]]; then _script_update "$m" "$t" "$s" && ok=1
                    else install_one "$m" "$t" "$mo" "$s" && ok=1
                    fi ;;
                uninstall)
                    local disable_ok=1
                    if is_service_module "$m" && [[ "$(module_service_unit "$m")" != tool ]]; then
                        disable_ok=0
                        module_service_transition disable "$m" && disable_ok=1
                        if (( disable_ok == 0 )); then
                            echo "Failed: disable $m before uninstall; target retained" >&2
                        fi
                    fi
                    if (( disable_ok == 1 )) && uninstall_one "$m" "$t" "$mo" "$s"; then
                        if [[ "$mo" == script ]]; then is_script_installed "$m" || ok=1
                        else target_path=$(expand_path "$t"); [[ ! -e "$target_path" ]] && ok=1
                        fi
                    fi ;;
            esac
            if (( ok )); then succeeded=$((succeeded + 1))
            else failed=$((failed + 1)); echo "Failed: $action $m" >&2
            fi
        done
        normalize_block_order "$HOME/.zshrc" "${ZSHRC_BLOCK_ORDER[@]}"
        if [[ -n "$setup_row" ]]; then
            IFS=$'\t' read -r m t mo s _ <<< "$setup_row"
            local setup_ok=0 setup_path
            case "$action" in
                uninstall)
                    if uninstall_one "$m" "$t" "$mo" "$s"; then
                        setup_path=$(expand_path "$t"); [[ ! -e "$setup_path" ]] && setup_ok=1
                    fi ;;
                *) install_one "$m" "$t" "$mo" "$s" && setup_ok=1 ;;
            esac
            if (( setup_ok )); then succeeded=$((succeeded + 1))
            else failed=$((failed + 1)); echo "Failed: $action setup" >&2
            fi
        fi
        FORCE=$old_force
        action_summary "$action" "$attempted" "$succeeded" "$failed" "$skipped"
    }
    build_individual_action_rows() {
        local wanted="$1" row m t mo s state installed svc active detail
        for row in "${snapshot[@]}"; do
            IFS=$'\t' read -r m t mo s state installed svc active detail <<< "$row"
            [[ "$m" == "$wanted" ]] || continue
            if [[ "$installed" == 1 ]]; then
                if [[ "$svc" == 1 ]]; then
                    if [[ "$active" == 1 ]]; then
                        printf 'action%sdisable%sDisable%s\n' "$delim" "$delim" "$delim"
                    else
                        printf 'action%senable%sEnable%s\n' "$delim" "$delim" "$delim"
                    fi
                fi
                printf 'action%supdate%sUpdate%s\n' "$delim" "$delim" "$delim"
                printf 'action%sreinstall%sReinstall%s\n' "$delim" "$delim" "$delim"
                [[ "$m" == fzf-multicolumn ]] || printf 'action%suninstall%sUninstall%s\n' "$delim" "$delim" "$delim"
            elif [[ "$svc" == 1 ]]; then
                printf 'action%sinstall-enable%sInstall + enable%s\n' "$delim" "$delim" "$delim"
            else
                printf 'action%sinstall%sInstall%s\n' "$delim" "$delim" "$delim"
            fi
            printf 'action%scancel%sCancel%s\n' "$delim" "$delim" "$delim"
            return
        done
    }
    run_individual_action() {
        local action="$1" module="$2" rc=0
        local -a saved_selection=("${selected_modules[@]}")
        selected_modules=("$module")
        case "$action" in
            enable|disable) run_service_action "$action" || rc=$? ;;
            install-enable)
                if run_module_action install 0 1; then
                    module_service_transition enable "$module" || rc=$?
                else
                    rc=$?
                fi
                ;;
            install|update|reinstall|uninstall)
                run_module_action "$action" 0 1 || rc=$?
                ;;
        esac
        selected_modules=("${saved_selection[@]}")
        return "$rc"
    }
    open_individual_menu() {
        local module="$1" choice kind action display
        individual_action_ran=0
        choice=$(build_individual_action_rows "$module" | "$picker" \
            --delimiter="$delim" --with-nth=3 --layout=reverse --cycle \
            --header="$module · individual action" --bind='esc:abort') || return 0
        IFS="$delim" read -r kind action display <<< "$choice"
        [[ "$kind" == action && "$action" != cancel ]] || return 0
        individual_action_ran=1
        run_individual_action "$action" "$module"
    }
    build_all_modules_action_rows() {
        printf 'all-action%supdate%supdate all%s\n' "$delim" "$delim" "$delim"
        printf 'all-action%sreinstall%sreinstall all%s\n' "$delim" "$delim" "$delim"
        printf 'all-action%suninstall%suninstall all%s\n' "$delim" "$delim" "$delim"
        printf 'all-action%srefresh%srefresh list%s\n' "$delim" "$delim" "$delim"
        printf 'all-action%scancel%scancel%s\n' "$delim" "$delim" "$delim"
    }
    open_all_modules_menu() {
        local choice kind action display row m t mo s setup_row="" old_force=$FORCE rc=0
        local -a saved_selection=("${selected_modules[@]}")
        all_menu_action_ran=0
        choice=$(build_all_modules_action_rows | "$picker" \
            --delimiter="$delim" --with-nth=3 --layout=reverse --cycle \
            --header='<ALL MODULES>' --bind='esc:abort') || return 0
        IFS="$delim" read -r kind action display <<< "$choice"
        [[ "$kind" == all-action && "$action" != cancel ]] || return 0
        case "$action" in
            refresh)
                all_menu_action_ran=1
                _CSUM_CACHE=""
                fetch_checksums
                ;;
            update)
                if confirm_action "Update ALL installed modules?"; then
                    all_menu_action_ran=1
                    cmd_update || rc=$?
                fi
                ;;
            reinstall)
                if confirm_action "Reinstall ALL modules (overwrites local changes)?"; then
                    all_menu_action_ran=1
                    FORCE=1
                    for row in "${snapshot[@]}"; do
                        IFS=$'\t' read -r m t mo s _ <<< "$row"
                        if [[ "$m" == setup ]]; then setup_row="$row"; continue; fi
                        install_one "$m" "$t" "$mo" "$s" || rc=$?
                    done
                    if [[ -n "$setup_row" ]]; then
                        IFS=$'\t' read -r m t mo s _ <<< "$setup_row"
                        install_one "$m" "$t" "$mo" "$s" || rc=$?
                    fi
                    FORCE=$old_force
                    normalize_block_order "$HOME/.zshrc" "${ZSHRC_BLOCK_ORDER[@]}"
                fi
                ;;
            uninstall)
                if confirm_action "Uninstall ALL modules? This is destructive."; then
                    all_menu_action_ran=1
                    selected_modules=()
                    for row in "${snapshot[@]}"; do selection_add "${row%%$'\t'*}"; done
                    run_module_action uninstall 0 || rc=$?
                    selected_modules=("${saved_selection[@]}")
                fi
                ;;
        esac
        FORCE=$old_force
        selected_modules=("${saved_selection[@]}")
        return "$rc"
    }

    local interactive_failed=0
    local picker_pos=1 individual_action_ran=0 all_menu_action_ran=0 module_action_ran=0 initial_snapshot=1
    main_picker() {
        "$picker" --grid=6 --grid-gap=2 --grid-span-prefix=@@ \
            --delimiter="$delim" --with-nth=3 --id-nth=1,2 --layout=reverse --cycle \
            --with-shell='zsh -f -c' --header="$(_setup_picker_header)" \
            --bind="enter:transform:$picker_callbacks _setup_picker_transform {1} {2}" \
            --bind="result:transform:$picker_callbacks _setup_picker_result_transform" \
            --bind="result:+transform-header:$picker_callbacks _setup_picker_header" \
            --bind='esc:abort' --bind="load:pos($picker_pos)" --preview-window=hidden
    }
    while true; do
        local choice kind key display row m all_selected=1 refresh_snapshot=0
        if (( initial_snapshot == 1 )); then
            choice=$({ snapshot_refresh; sync_picker_state; _setup_picker_render; } | main_picker) || break
            initial_snapshot=0
        else
            sync_picker_state
            choice=$(_setup_picker_render | main_picker) || break
        fi
        load_picker_snapshot
        load_picker_selection
        IFS="$delim" read -r kind key display <<< "$choice"
        case "$kind" in
            module)
                open_individual_menu "$key" || interactive_failed=1
                (( individual_action_ran == 1 )) && refresh_snapshot=1
                ;;
            all-menu)
                open_all_modules_menu || interactive_failed=1
                (( all_menu_action_ran == 1 )) && refresh_snapshot=1
                ;;
            select-all)
                for row in "${snapshot[@]}"; do
                    m=${row%%$'\t'*}; selection_has "$m" || { all_selected=0; break; }
                done
                if (( all_selected )); then selected_modules=()
                else
                    selected_modules=()
                    for row in "${snapshot[@]}"; do selection_add "${row%%$'\t'*}"; done
                fi ;;
            action)
                [[ $(eligible_count "$key") -gt 0 ]] || { echo "$key: 0 eligible, ${#selected_modules[@]} skipped."; continue; }
                case "$key" in
                    enable|disable)
                        run_service_action "$key" || interactive_failed=1
                        selected_modules=()
                        ;;
                    *)
                        run_module_action "$key" || interactive_failed=1
                        (( module_action_ran == 1 )) && selected_modules=()
                        ;;
                esac
                refresh_snapshot=1 ;;
        esac
        (( refresh_snapshot == 1 )) && snapshot_refresh
        sync_picker_state
        picker_pos=$(_setup_picker_position "$kind" "$key")
    done
    rm -rf "$picker_state_dir"
    return "$interactive_failed"
}
# Post-install: check if refresh-models needs auth onboarding
_post_auth_check() {
    local auth_marker="$STATE_DIR/refresh-models.needs-auth"
    [[ -f "$auth_marker" ]] || return 0

    local auth_bin="$HOME/.local/bin/refresh-models"
    [[ -x "$auth_bin" ]] || auth_bin=$(command -v refresh-models 2>/dev/null || true)
    if [[ ! -x "$auth_bin" ]]; then
        echo "Warning: refresh-models needs API keys, but its executable is unavailable. Run 'setup install refresh-models', then 'refresh-models auth'." >&2
        return 1
    fi
    if [[ -t 1 && -r /dev/tty ]]; then
        echo
        echo "refresh-models is installed but needs API keys. Launching auth..."
        if "$auth_bin" auth </dev/tty >/dev/tty 2>&1; then
            rm -f "$auth_marker"
            return 0
        fi
        echo "Warning: refresh-models auth failed; onboarding will be retried next time." >&2
        return 1
    fi
    echo "Warning: refresh-models is installed but needs API keys. Run 'setup' or '$auth_bin auth' to configure." >&2
    return 1
}


if [[ "${SETUP_SOURCE_ONLY:-0}" == "1" ]]; then
    return 0 2>/dev/null || exit 0
fi

while (($# > 0)); do
    case "$1" in
        --force) FORCE=1; shift ;;
        --batch) BATCH=1; shift ;;
        help|-h|--help) usage; exit 0 ;;
        *) break ;;
    esac
done

cmd="${1:-}"
(( $# > 0 )) && shift

if [[ -z "$cmd" ]]; then
    main_rc=0
    if [[ -t 1 && -r /dev/tty && "$BATCH" -eq 0 ]]; then
        configure_shell || true
        if bootstrap_managed_picker; then
            cmd_reconfigure || main_rc=$?
        else
            echo "Warning: interactive setup needs the managed span-aware picker." >&2
            echo "Run 'setup install fzf-multicolumn', then rerun 'setup'. Falling back to non-interactive update." >&2
            cmd_update || main_rc=$?
        fi
    else
        echo "Warning: no interactive terminal; running non-interactive update. Use 'setup' in a terminal for module selection." >&2
        cmd_update || main_rc=$?
    fi
    _post_auth_check || true
    exit "$main_rc"
fi

case "$cmd" in
    list) cmd_list "$@" ;;
    status) cmd_status "$@" ;;
    install)
        command_rc=0
        cmd_install "$@" || command_rc=$?
        _post_auth_check || true
        exit "$command_rc"
        ;;
    update)
        command_rc=0
        cmd_update "$@" || command_rc=$?
        _post_auth_check || true
        exit "$command_rc"
        ;;
    uninstall) cmd_uninstall "$@" ;;
    enable) cmd_enable "$@" ;;
    disable) cmd_disable "$@" ;;
    diff) cmd_diff "$@" ;;
    doctor) cmd_doctor ;;
    schedule) cmd_schedule "$@" ;;
    unschedule) cmd_unschedule "$@" ;;
    *) usage >&2; exit 1 ;;
esac
