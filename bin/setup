#!/usr/bin/env bash
# setup-module: setup
# setup-source: bin/setup
set -uo pipefail
ORIG_ARGS=("$@")

SOURCE_URL="${LINUX_SETUP_SOURCE_URL:-https://raw.githubusercontent.com/LPFchan/setup/main}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/setup"
MANIFEST_URL="$SOURCE_URL/manifest.tsv"
MANIFEST_FILE="$STATE_DIR/manifest.tsv"
HASH_FILE="$STATE_DIR/installed.tsv"
SCRIPT_HELPERS_FILE="$STATE_DIR/lib/script-helpers.sh"
FORCE=0

SERVICE_MODULES="kernel-simmer service-ctl gpu-fancontrol monitoring refresh-models backup"
USER_SERVICE_MODULES="refresh-models"
BATCH=0

fetch_script_helpers() {
    mkdir -p "$(dirname "$SCRIPT_HELPERS_FILE")"
    curl -fsSL --connect-timeout 8 --max-time 60 "$SOURCE_URL/lib/script-helpers.sh" -o "$SCRIPT_HELPERS_FILE" 2>/dev/null \
        || echo "Warning: could not fetch lib/script-helpers.sh" >&2
    # shellcheck disable=SC1090
    [[ -f "$SCRIPT_HELPERS_FILE" ]] && source "$SCRIPT_HELPERS_FILE"
}
fetch_script_helpers

usage() {
    cat <<'EOF'
Usage: setup [--force] [--batch] <command> [module...]
  Flags must come before the command.
  --force  overwrite when uninstalling locally edited files
  --batch  non-interactive mode

Commands:
  list                 List available modules
  status [module...]   Show installed/current/outdated/modified state
  install [module...]  Install module files (copies to ~/.local/bin/)
  update [module...]   Update installed modules; reports new modules available
  uninstall [module...] Remove managed files
  enable [module...]   Enable service modules (requires sudo)
  disable [module...]  Disable service modules (requires sudo)
  diff [module...]     Show local diff against remote source
  doctor               Check required local tools
  schedule [status]    Install daily auto-update timer or show its state
  unschedule           Remove daily auto-update timer

Run without arguments for interactive fzf reconfigure.

Environment:
  LINUX_SETUP_SOURCE_URL Override source URL root
EOF
}

_resolve_bin() {
    local name="$1"
    local path="$HOME/.local/bin/$name"
    if [[ -x "$path" ]]; then
        echo "$path"
    else
        echo "$name"
    fi
}

module_enable_cmd() {
    local bin
    case "$1" in
        kernel-simmer)  bin=$(_resolve_bin kernel-simmer); echo "$bin enable" ;;
        service-ctl)    bin=$(_resolve_bin service-ctl); echo "$bin enable --all" ;;
        gpu-fancontrol|monitoring)
                        bin=$(_resolve_bin service-ctl); echo "$bin enable $1" ;;
        refresh-models) bin=$(_resolve_bin refresh-models); echo "$bin enable" ;;
        backup)         bin=$(_resolve_bin backup); echo "$bin enable" ;;
    esac
}

module_disable_cmd() {
    local bin
    case "$1" in
        kernel-simmer)  bin=$(_resolve_bin kernel-simmer); echo "$bin disable" ;;
        service-ctl)    bin=$(_resolve_bin service-ctl); echo "$bin disable --all" ;;
        gpu-fancontrol|monitoring)
                        bin=$(_resolve_bin service-ctl); echo "$bin disable $1" ;;
        refresh-models) bin=$(_resolve_bin refresh-models); echo "$bin disable" ;;
        backup)         bin=$(_resolve_bin backup); echo "$bin disable" ;;
    esac
}

module_service_unit() {
    case "$1" in
        service-ctl)    echo "tool" ;;
        kernel-simmer)  echo "kernel-simmer.timer" ;;
        gpu-fancontrol) echo "gpu-fancontrol.service" ;;
        monitoring)     echo "monitoring.service" ;;
        refresh-models) echo "refresh-models.timer" ;;
        backup)         echo "backup-daily.timer" ;;
    esac
}

is_service_module() {
    local m
    for m in ${SERVICE_MODULES}; do [[ "$m" == "$1" ]] && return 0; done
    return 1
}

module_is_active() {
    local unit user_flag=""
    unit=$(module_service_unit "$1") || return 1
    if echo " ${USER_SERVICE_MODULES} " | grep -q " $1 "; then
        user_flag="--user"
    fi
    # macOS: check launchd for refresh-models
    if [[ "$1" == "refresh-models" ]] && [[ "$(uname -s)" == "Darwin" ]]; then
        launchctl print "gui/$(id -u)/com.lost.plus.refresh-models" &>/dev/null && return 0
        return 1
    fi
    [[ "$(systemctl ${user_flag} is-active "${unit}" 2>/dev/null)" == "active" ]]
}

sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        if [[ -n "${1:-}" ]]; then
            sha256sum "$1" | cut -d' ' -f1
        else
            sha256sum | cut -d' ' -f1
        fi
    elif command -v shasum >/dev/null 2>&1; then
        if [[ -n "${1:-}" ]]; then
            shasum -a 256 "$1" | cut -d' ' -f1
        else
            shasum -a 256 | cut -d' ' -f1
        fi
    else
        echo "missing sha256sum/shasum" >&2; exit 1
    fi
}

expand_path() {
    case "$1" in
        '~') printf '%s\n' "$HOME" ;;
        '~/'*) printf '%s/%s\n' "$HOME" "${1:2}" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

fetch_manifest() {
    mkdir -p "$STATE_DIR"
    curl -fsSL --connect-timeout 8 --max-time 60 "$MANIFEST_URL" -o "$MANIFEST_FILE" 2>/dev/null || true
}

module_selected() {
    local module="$1"
    shift || true
    if (($# == 0)); then
        return 0
    fi
    local wanted
    for wanted in "$@"; do
        [[ "$module" == "$wanted" ]] && return 0
    done
    return 1
}

installed_hash_for() {
    local target="$1"
    [[ -f "$HASH_FILE" ]] || return 0
    while IFS=$'\t' read -r path hash version; do
        [[ "$path" == "$target" ]] && printf '%s\n' "$hash" && return 0
    done < "$HASH_FILE"
}
fetch_checksums() {
    # Download checksums.tsv and cache source → sha256 mappings.
    if [[ -n "${_CSUM_CACHE:-}" ]]; then
        return 0
    fi
    local tmp
    tmp=$(mktemp)
    if curl -fsSL --connect-timeout 8 --max-time 60 "$SOURCE_URL/checksums.tsv" -o "$tmp" 2>/dev/null \
        && grep -q '^# source' "$tmp"; then
        _CSUM_CACHE=$(cat "$tmp")
    else
        echo "Warning: could not fetch checksums.tsv from $SOURCE_URL" >&2
    fi
    rm -f "$tmp"
}

remote_checksum() {
    local source="$1"
    [[ -z "${_CSUM_CACHE:-}" ]] && fetch_checksums
    printf '%s\n' "${_CSUM_CACHE:-}" | grep "^${source}"$'\t' | head -1 | cut -f2
}

_migrate_auth_json() {
    local old="$HOME/.local/share/opencode/auth.json"
    [[ -f "$old" ]] || return 0
    python3 -c "
import json, os, pathlib
old = os.path.expanduser('~/.local/share/opencode/auth.json')
zsenv = os.path.expanduser('~/.zshenv')
begin = '# BEGIN setup:api-keys'
end = '# END setup:api-keys'
try:
    data = json.load(open(old))
except Exception:
    exit(0)
if not isinstance(data, dict) or not data:
    exit(0)
lines = []
for p, e in data.items():
    if not isinstance(e, dict):
        continue
    etype = e.get('type', '')
    if etype == 'api':
        key = e.get('key', '')
        if key and isinstance(key, str) and key.strip():
            provider = p.replace('-', '_').upper()
            lines.append(f'export {provider}_API_KEY={key.strip()}')
    elif etype == 'oauth':
        access = e.get('access', '')
        if access and isinstance(access, str):
            provider = p.replace('-', '_').upper()
            lines.append(f'export {provider}_OAUTH_TOKEN={access}')
if not lines:
    exit(0)
existing = []
in_block = False
if os.path.exists(zsenv):
    for l in open(zsenv):
        s = l.strip()
        if s == begin: in_block = True; continue
        if s == end: in_block = False; continue
        if not in_block:
            existing.append(l)
with open(zsenv, 'w') as f:
    for l in existing:
        f.write(l)
    f.write(f'\n{begin}\n')
    for l in lines:
        f.write(l + '\n')
    f.write(f'{end}\n')
print(f'Exported {len(lines)} key(s) from {old} to {zsenv}')
" 2>&1 || true
}

module_for() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    while IFS= read -r line; do
        case "$line" in
            '# setup-module: '*) printf '%s\n' "${line#'# setup-module: '}"; return 0 ;;
        esac
    done < "$file"
}


has_managed_block() {
    local file="$1" label="$2"
    [[ -f "$file" ]] || return 1
    grep -Fq "# >>> setup:$label >>>" "$file" || grep -Fq "# >>> linux-setup:$label >>>" "$file"
}

# --- shell config helpers (for setup command) -----------------------

manage_block() {
    local file="$1" label="$2" content="$3" mode="$4" position="${5:-append}"
    local begin_mark="# >>> setup:$label >>>"
    local end_mark="# <<< setup:$label <<<"
    local old_begin_mark="# >>> linux-setup:$label >>>"
    local old_end_mark="# <<< linux-setup:$label <<<"

    mkdir -p "$(dirname "$file")"
    touch "$file"

    # Prepend an in-block warning so agents editing the file know it's managed
    # and their edits will be overwritten. Included in the block body, so it is
    # part of the content hash (consistent across write and drift detection).
    local warn="# [setup] managed block — do NOT edit between these markers; overwritten on 'setup update'. Source: LPFchan/setup"
    if [[ "$mode" != "remove" && -n "$content" ]]; then
        content="$warn"$'\n'"$content"
    fi

    _extract_block_body() {
        # Print lines between begin_mark and end_mark, exclusive.
        # Normalize: strip a single trailing newline if present.
        awk -v begin="$begin_mark" -v end="$end_mark" \
            -v old_begin="$old_begin_mark" -v old_end="$old_end_mark" '
            $0 == begin || $0 == old_begin { inblock=1; next }
            $0 == end   || $0 == old_end   { inblock=0; next }
            inblock { print }
        ' "$file" | sed '$ { /^$/ d; }'
    }

    case "$mode" in
        remove)
            if ! grep -Fq "$begin_mark" "$file" && ! grep -Fq "$old_begin_mark" "$file"; then
                return 0
            fi
            local _tmp; _tmp=$(mktemp)
            awk -v begin="$begin_mark" -v end="$end_mark" \
                -v old_begin="$old_begin_mark" -v old_end="$old_end_mark" '
                $0 == begin || $0 == old_begin { skip=1; next }
                $0 == end   || $0 == old_end   { skip=0; next }
                !skip
            ' "$file" > "$_tmp" && mv "$_tmp" "$file"
            echo "Removed $label from $file"
            ;;
        prepend|append)
            if grep -Fq "$begin_mark" "$file" || grep -Fq "$old_begin_mark" "$file"; then
                echo "Current $label -> $file"
                return 0
            fi
            if [[ "$position" == "prepend" ]]; then
                local _tmp; _tmp=$(mktemp)
                { printf '%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n\n' "$end_mark"; cat "$file"; } > "$_tmp"
                mv "$_tmp" "$file"
            else
                { printf '\n%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n' "$end_mark"; } >> "$file"
            fi
            echo "Added $label -> $file"
            ;;
        upsert)
            local new_hash; new_hash=$(printf '%s' "$content" | sed '$ { /^$/ d; }' | sha256)
            if ! grep -Fq "$begin_mark" "$file" && ! grep -Fq "$old_begin_mark" "$file"; then
                if [[ "$position" == "prepend" ]]; then
                    local _tmp; _tmp=$(mktemp)
                    { printf '%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n\n' "$end_mark"; cat "$file"; } > "$_tmp"
                    mv "$_tmp" "$file"
                else
                    { printf '\n%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n' "$end_mark"; } >> "$file"
                fi
                echo "Added $label -> $file"
                return 0
            fi
            local old_hash; old_hash=$(_extract_block_body | sha256)
            if [[ "$new_hash" != "$old_hash" ]]; then
                local _tmp; _tmp=$(mktemp)
                {
                    awk -v begin="$begin_mark" -v end="$end_mark" \
                        -v old_begin="$old_begin_mark" -v old_end="$old_end_mark" '
                        $0 == begin || $0 == old_begin { print; skip=1; next }
                        $0 == end   || $0 == old_end   { skip=0 }
                        !skip { print }
                    ' "$file" | while IFS= read -r line; do
                        if [[ "$line" == "$begin_mark" || "$line" == "$old_begin_mark" ]]; then
                            printf '%s\n' "$begin_mark"
                            printf '%s\n' "$content"
                        else
                            printf '%s\n' "$line"
                        fi
                    done
                } > "$_tmp" && mv "$_tmp" "$file"
                echo "Updated $file $label"
            else
                echo "Current $label -> $file"
            fi
            ;;
    esac
}

BLOCK_DELIM=$'\x1f'
# Core-owned shell scaffolding. Module-owned blocks participate in the
# canonical ordering below but are installed by their respective modules.
BLOCK_REGISTRY=(
    "zshenv${BLOCK_DELIM}path${BLOCK_DELIM}path_block${BLOCK_DELIM}upsert${BLOCK_DELIM}prepend"
)

# Canonical top→bottom order of setup-managed .zshrc blocks. Enforced by
# normalize_block_order at the end of every path that may add/rewrite a block.
ZSHRC_BLOCK_ORDER=(tmux-autostart tmux-title zsh-basics starship zsh-autocomplete zsh-syntax-highlighting ai-menu)

configure_shell() {
    local path_block

    # Migration: earlier versions named the shell-init block `zsh-ai`. Its
    # behavior now belongs to zsh-basics, which adopts it during module update.
    if [[ -f "$HOME/.zshrc" ]] && grep -Fq "# >>> setup:zsh-ai >>>" "$HOME/.zshrc"; then
        manage_block "$HOME/.zshrc" "zsh-ai" "" "remove"
    fi

    path_block='case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac'

    for entry in "${BLOCK_REGISTRY[@]}"; do
        IFS="$BLOCK_DELIM" read -r file_key label content_var mode position <<< "$entry"
        manage_block "$HOME/.$file_key" "$label" "${!content_var}" "$mode" "$position"
    done

    # Ownership migration: core used to install zsh-init on every host. Keep it
    # until an installed zsh-basics module can fold it into its own block; remove
    # the legacy orphan when zsh-basics is absent.
    if has_managed_block "$HOME/.zshrc" "zsh-init" \
       && [[ -z "$(script_state_for zsh-basics || true)" ]]; then
        manage_block "$HOME/.zshrc" "zsh-init" "" "remove"
    fi

    # Ownership migration: core used to install tmux-autostart on every host.
    # Keep the block when the tmux module is installed so that module update can
    # adopt it in place; remove the legacy orphan when the module is absent.
    if has_managed_block "$HOME/.zshrc" "tmux-autostart" \
       && [[ -z "$(script_state_for tmux || true)" ]]; then
        manage_block "$HOME/.zshrc" "tmux-autostart" "" "remove"
    fi
}

# Reorder the setup-managed blocks in <file> to match the given label order,
# preserving all unmanaged content exactly and staying idempotent.
#
#   normalize_block_order <file> <label1> <label2> ...
#
# Algorithm:
#   1. Scan the file into an ordered list of items; each item is either a
#      MANAGED BLOCK (full text from `# >>> setup:LABEL >>>` through its
#      matching `# <<< setup:LABEL <<<`, inclusive) or a run of NON-block lines.
#   2. The item positions that are blocks are "slots".
#   3. Sort present blocks by canonical order: known labels by their index in
#      the argument list; unknown labels sort AFTER all known ones, keeping
#      their original relative order (stable). Unknown blocks are never dropped.
#   4. Re-emit items in place; fill block-slots with the sorted blocks. Non-block
#      items stay exactly where they were.
#   5. Exactly one blank line separates consecutive elements; block interiors and
#      unmanaged lines are left byte-for-byte intact. Written atomically via mv.
normalize_block_order() {
    local file="$1"; shift
    [[ -f "$file" ]] || return 0
    local order=("$@")

    local tmp; tmp=$(mktemp)
    ORDER_LIST="$(printf '%s\n' "${order[@]}")" awk '
        function flush_nonblock(   i) {
            # Emit accumulated non-block lines as one item, trimming leading and
            # trailing blank lines (inter-item spacing is re-added on output).
            if (nb_count == 0) return
            start = 1; endi = nb_count
            while (start <= endi && nb[start] ~ /^[[:space:]]*$/) start++
            while (endi >= start && nb[endi] ~ /^[[:space:]]*$/) endi--
            if (start > endi) { nb_count = 0; return }
            item_type[++nitems] = "text"
            s = ""
            for (i = start; i <= endi; i++) s = s (i > start ? "\n" : "") nb[i]
            item_text[nitems] = s
            nb_count = 0
        }
        BEGIN {
            n_order = 0
            m = split(ENVIRON["ORDER_LIST"], oarr, "\n")
            for (i = 1; i <= m; i++) if (oarr[i] != "") order_idx[oarr[i]] = ++n_order
        }
        {
            if ($0 ~ /^# >>> setup:.* >>>$/) {
                flush_nonblock()
                label = $0
                sub(/^# >>> setup:/, "", label)
                sub(/ >>>$/, "", label)
                blk = $0
                inblock = 1
                item_type[++nitems] = "block"
                item_label[nitems] = label
                next
            }
            if (inblock) {
                blk = blk "\n" $0
                if ($0 ~ /^# <<< setup:.* <<<$/) {
                    inblock = 0
                    item_text[nitems] = blk
                }
                next
            }
            nb[++nb_count] = $0
        }
        END {
            flush_nonblock()

            # Collect block-slot indices and sort blocks by canonical order.
            nslots = 0
            for (i = 1; i <= nitems; i++) if (item_type[i] == "block") slot[++nslots] = i
            # Build a sort key per slot: known -> index; unknown -> big base +
            # original appearance order (stable, after all known).
            for (i = 1; i <= nslots; i++) {
                idx = slot[i]
                lbl = item_label[idx]
                if (lbl in order_idx) key[i] = order_idx[lbl]
                else key[i] = n_order + i   # keeps unknowns stable & last
                ord[i] = i
            }
            # Simple stable insertion sort on key[].
            for (i = 2; i <= nslots; i++) {
                kk = key[i]; oo = ord[i]; j = i - 1
                while (j >= 1 && key[j] > kk) { key[j+1] = key[j]; ord[j+1] = ord[j]; j-- }
                key[j+1] = kk; ord[j+1] = oo
            }
            # sorted_block_text[slotpos] = text of the block that belongs there.
            for (i = 1; i <= nslots; i++) sorted_text[i] = item_text[slot[ord[i]]]

            # Re-emit items; blocks pulled from sorted order, text as-is.
            si = 0; out = 0
            for (i = 1; i <= nitems; i++) {
                if (item_type[i] == "block") { piece = sorted_text[++si] }
                else                          { piece = item_text[i] }
                if (out++) printf "\n"      # one blank line between items
                printf "%s\n", piece
            }
        }
    ' "$file" > "$tmp" && mv "$tmp" "$file" || { rm -f "$tmp"; return 1; }
}

fetch_payload() {
    local source="$1" payload="$2"
    if curl -fsSL --connect-timeout 8 --max-time 60 "$SOURCE_URL/$source" -o "$payload" 2>/dev/null \
        && grep -q '^# setup-module: ' "$payload"; then
        return 0
    fi
    echo "Failed to fetch $source from $SOURCE_URL" >&2
    return 1
}

_script_install() {
    local module="$1" target="$2" source="$3"
    local payload
    payload=$(mktemp)
    if ! fetch_payload "$source" "$payload"; then
        rm -f "$payload"
        return 1
    fi
    # shellcheck disable=SC1090
    source "$payload"
    install
    local rc=$?
    rm -f "$payload"
    return $rc
}

# Run a script module's live status probe once and normalize its standardized
# output for every status surface.  The durable script state remains useful as
# an installation marker, but never decides live freshness.
#
# Fields: target, state, display status, local, remote, installed, details
script_status_fields() {
    local module="$1" target_spec="$2" source="$3"
    local payload result line rc state status_label local_label remote_label
    local target installed extra
    payload=$(mktemp)
    result=$(mktemp)
    target=$(expand_path "$target_spec")

    if ! fetch_payload "$source" "$payload"; then
        installed=$(is_script_installed "$module" && echo 1 || echo 0)
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$target" "error" "probe failed" "-" "-" "$installed" "fetch failed"
        rm -f "$payload" "$result"
        return 0
    fi

    # shellcheck disable=SC1090
    if ! source "$payload"; then
        installed=$(is_script_installed "$module" && echo 1 || echo 0)
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$target" "error" "probe failed" "-" "-" "$installed" "load failed"
        rm -f "$payload" "$result"
        return 0
    fi
    if status > "$result"; then
        rc=0
    else
        rc=$?
    fi
    line=$(awk 'NF { print; exit }' "$result")
    rm -f "$payload" "$result"

    state=$(awk 'NF { print $2; exit }' <<< "$line")
    local_label=$(sed -n 's/.* local=\([^ ]*\).*/\1/p' <<< "$line")
    remote_label=$(sed -n 's/.* remote=\([^ ]*\).*/\1/p' <<< "$line")
    [[ "$line" == *" target="* ]] && target=${line##* target=}
    local_label=${local_label:--}
    remote_label=${remote_label:--}

    case "$state:$rc" in
        current:0)
            status_label="up-to-date"; installed=1 ;;
        outdated:1)
            status_label="update available"; installed=1 ;;
        installed:0|unknown:0)
            status_label="remote unknown"; installed=1 ;;
        uninstalled:2)
            status_label="not installed"; installed=0 ;;
        *)
            state="error"; status_label="probe failed"
            installed=$(is_script_installed "$module" && echo 1 || echo 0) ;;
    esac

    if [[ "$state" == "error" ]]; then
        extra="probe failed"
    elif [[ "$local_label" != "-" || "$remote_label" != "-" ]]; then
        extra="local=$local_label remote=$remote_label"
    else
        extra=""
    fi
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$target" "$state" "$status_label" "$local_label" "$remote_label" "$installed" "$extra"
}

_script_uninstall() {
    local module="$1" target="$2" source="$3"
    local payload
    payload=$(mktemp)
    if ! fetch_payload "$source" "$payload"; then
        rm -f "$payload"
        return 1
    fi
    source "$payload"
    uninstall
    local rc=$?
    rm -f "$payload"
    return $rc
}

_script_update() {
    local module="$1" target="$2" source="$3"
    local payload
    payload=$(mktemp)
    if ! fetch_payload "$source" "$payload"; then
        rm -f "$payload"
        return 1
    fi
    source "$payload"
    update
    local rc=$?
    rm -f "$payload"
    return $rc
}

record_hash() {
    local target="$1" hash="$2" version="$3" tmp
    mkdir -p "$STATE_DIR"
    tmp=$(mktemp)
    if [[ -f "$HASH_FILE" ]]; then
        while IFS=$'\t' read -r path old_hash old_version; do
            [[ "$path" == "$target" ]] && continue
            printf '%s\t%s\t%s\n' "$path" "$old_hash" "${old_version:-}"
        done < "$HASH_FILE" > "$tmp"
    fi
    printf '%s\t%s\t%s\n' "$target" "$hash" "$version" >> "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_hash() {
    local target="$1" tmp
    [[ -f "$HASH_FILE" ]] || return 0
    tmp=$(mktemp)
    while IFS=$'\t' read -r path old_hash old_version; do
        [[ "$path" == "$target" ]] && continue
        printf '%s\t%s\t%s\n' "$path" "$old_hash" "${old_version:-}"
    done < "$HASH_FILE" > "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_marker_blocks() {
    local file="$1" tmp status=0
    [[ -f "$file" ]] || return 0
    tmp=$(mktemp)
    awk '
        /^# >>> linux-setup:/ { skip=1; changed=1; next }
        /^# <<< linux-setup:/ { skip=0; next }
        /^# >>> setup:/ { skip=1; changed=1; next }
        /^# <<< setup:/ { skip=0; next }
        !skip { print }
        END { if (changed) exit 42 }
    ' "$file" > "$tmp" || status=$?
    status=${status:-0}
    if [[ "$status" == 42 ]]; then
        mv "$tmp" "$file"
        echo "Updated $file"
    else
        rm -f "$tmp"
    fi
}

remove_shell_config() {
    remove_marker_blocks "$HOME/.zshenv"
    remove_marker_blocks "$HOME/.zshrc"
}

uninstall_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"

    [[ "$mode" == "script" ]] && { _script_uninstall "$module" "$target_spec" "$source"; return; }

    local target old_hash current_hash local_module
    target=$(expand_path "$target_spec")
    old_hash=$(installed_hash_for "$target" || true)

    if [[ ! -f "$target" ]]; then
        remove_hash "$target"
        echo "Missing $module -> $target"
        return 0
    fi

    if [[ -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" && "$FORCE" -ne 1 ]]; then
            echo "Local changes detected: keeping $target (use --force to remove)"
            return 0
        fi
    elif [[ "$FORCE" -ne 1 ]]; then
        local_module=$(module_for "$target" || true)
        if [[ "$local_module" != "$module" ]]; then
            echo "Untracked file: keeping $target (use --force to remove)"
            return 0
        fi
    fi

    rm -f "$target"
    remove_hash "$target"
    echo "Removed $module -> $target"
}

install_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"

    [[ "$mode" == "script" ]] && { _script_install "$module" "$target_spec" "$source"; return; }

    local target dir payload old_hash current_hash new_hash install_target remote_module remote_hash disk_hash

    target=$(expand_path "$target_spec")
    dir=$(dirname "$target")
    mkdir -p "$dir"

    payload=$(mktemp)

    fetch_payload "$source" "$payload" || { rm -f "$payload"; return 1; }
    remote_module=$(module_for "$payload" || true)

    if [[ "$remote_module" != "$module" ]]; then
        echo "Metadata mismatch for $source: expected module '$module', got '${remote_module:-missing}'" >&2
        rm -f "$payload"
        return 1
    fi

    new_hash=$(sha256 "$payload")
    old_hash=$(installed_hash_for "$target" || true)

    # Hash of the file actually on disk. Compared against the recorded hash so
    # we can detect drift: an earlier install that recorded a hash but whose
    # write failed or was interrupted leaves recorded ahead of the real file.
    disk_hash=""
    [[ -f "$target" ]] && disk_hash=$(sha256 "$target")

    # Only "current" (skip) when the remote matches the recorded hash AND the
    # on-disk file still matches that hash. Without the disk_hash check a drifted
    # file is skipped forever and `setup update` can never self-heal it — only a
    # force reinstall would. See the drift routing in the condition below.
    if [[ -f "$target" && -n "$old_hash" ]] && [[ "$new_hash" == "$old_hash" ]] \
       && [[ "$disk_hash" == "$old_hash" ]] && [[ "$FORCE" -ne 1 ]]; then
        if [[ "$module" == "refresh-models" ]]; then
            _migrate_auth_json
        fi
        echo "$module ${old_hash:0:7} (current) -> $target"
        rm -f "$payload"
        return 0
    fi

    # Route both "new content" and "disk drifted from recorded" to the normal
    # install path below (rewrite + re-record) rather than the foreign branch.
    if [[ -f "$target" && -n "$old_hash" ]] && { [[ "$new_hash" != "$old_hash" ]] || [[ "$disk_hash" != "$old_hash" ]]; }; then
        :
    elif [[ -f "$target" ]]; then
        install -m "$mode" "$payload" "$target" || {
            echo "Failed to write $module -> $target" >&2
            rm -f "$payload"
            return 1
        }
        record_hash "$target" "$new_hash" "$new_hash"
        echo "$module ${new_hash:0:7} (foreign) -> $target"
        rm -f "$payload"
        if [[ "$module" == "refresh-models" ]]; then
            _migrate_auth_json
        fi
        if [[ "$module" == "setup" ]]; then
            echo "Restarting setup..."
            exec "$target" ${ORIG_ARGS[@]+"${ORIG_ARGS[@]}"}
        fi
        return 0
    fi

    install -m "$mode" "$payload" "$target" || {
        echo "Failed to write $module -> $target" >&2
        rm -f "$payload"
        return 1
    }
    record_hash "$target" "$new_hash" "$new_hash"
    if [[ -n "$old_hash" && "$old_hash" != "$new_hash" ]]; then
        echo "$module ${old_hash:0:7} -> ${new_hash:0:7} -> $target"
    else
        echo "$module ${new_hash:0:7} (install) -> $target"
    fi
    if [[ "$module" == "refresh-models" ]]; then
        _migrate_auth_json
    fi
    rm -f "$payload"
    if [[ "$module" == "setup" ]]; then
        echo "Restarting setup..."
        exec "$target" ${ORIG_ARGS[@]+"${ORIG_ARGS[@]}"}
    fi
}

file_status_fields() {
    local module="$1" target_spec="$2" source="$3"
    local target remote_hash remote_label recorded_hash current_hash local_module \
          state status_label local_label installed extra

    target=$(expand_path "$target_spec")
    remote_hash=$(remote_checksum "$source" || true)
    [[ -n "$remote_hash" ]] && remote_label="${remote_hash:0:7}" || remote_label="-"

    if [[ ! -f "$target" ]]; then
        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$target" "uninstalled" "not installed" "-" "$remote_label" "0" "remote=$remote_label"
        return 0
    fi

    installed=1
    current_hash=$(sha256 "$target")
    local_label="${current_hash:0:7}"
    local_module=$(module_for "$target" || true)
    recorded_hash=$(installed_hash_for "$target" || true)

    if [[ "$local_module" != "$module" ]]; then
        state="foreign"
        status_label="foreign"
        extra="current=${current_hash:0:7} remote=$remote_label"
    elif [[ -z "$recorded_hash" ]]; then
        state="untracked"
        status_label="installed (untracked)"
        extra="current=${current_hash:0:7} remote=$remote_label untracked-hash"
    elif [[ "$current_hash" != "$recorded_hash" ]]; then
        state="modified"
        status_label="modified"
        extra="recorded=${recorded_hash:0:7} current=${current_hash:0:7} remote=$remote_label"
    elif [[ -z "$remote_hash" ]]; then
        state="unknown"
        status_label="remote unknown"
        extra="local=${recorded_hash:0:7} remote=-"
    elif [[ "$recorded_hash" != "$remote_hash" ]]; then
        state="outdated"
        status_label="update available"
        extra="local=${recorded_hash:0:7} remote=${remote_hash:0:7}"
    else
        state="current"
        status_label="up-to-date"
        extra="local=${recorded_hash:0:7} remote=${remote_hash:0:7}"
    fi

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "$target" "$state" "$status_label" "$local_label" "$remote_label" "$installed" "$extra"
}

status_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"

    local target state status_label local_label remote_label installed extra
    if [[ "$mode" == "script" ]]; then
        IFS=$'\t' read -r target state status_label local_label remote_label installed extra \
            < <(script_status_fields "$module" "$target_spec" "$source")
        if [[ "$local_label" == "-" && "$remote_label" == "-" ]]; then
            printf '%-25s %-12s target=%s\n' "$module" "$state" "$target"
        else
            printf '%-25s %-12s local=%s remote=%s target=%s\n' \
                "$module" "$state" "$local_label" "$remote_label" "$target"
        fi
        return
    fi

    IFS=$'\t' read -r target state status_label local_label remote_label installed extra \
        < <(file_status_fields "$module" "$target_spec" "$source")

    printf '%-25s %-12s %s target=%s\n' "$module" "$state" "$extra" "$target"
}

cmd_list() {
    fetch_manifest
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        printf '%-25s %s\n' "$module" "$target"
    done < "$MANIFEST_FILE"
}

cmd_status() {
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            status_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    if (($# == 0)); then
        echo
        shell_status
    fi
}

shell_status() {
    shell_status_one "$HOME/.zshenv" path
}

shell_status_one() {
    local file="$1" label="$2"
    if has_managed_block "$file" "$label"; then
        printf '%-25s %-12s target=%s\n' "$label" "managed" "$file"
    else
        printf '%-25s %-12s target=%s\n' "$label" "missing" "$file"
    fi
}

cmd_install() {
    local modules=("$@")
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "${modules[@]}"; then
            found=1
            install_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    # Enable each installed service module
    for module in "${modules[@]}"; do
        is_service_module "$module" || continue
        local ec; ec=$(module_enable_cmd "$module")
        echo "Enabling $module..."
        if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
            ${ec} 2>&1 || echo "(enable failed — check above for errors)"
        else
            sudo -E ${ec} 2>&1 || echo "(enable failed — run 'setup enable $module' with sudo)"
        fi
    done

    # A module install may have added a .zshrc block; keep canonical order.
    normalize_block_order "$HOME/.zshrc" "${ZSHRC_BLOCK_ORDER[@]}"
}

cmd_update() {
    configure_shell || true
    fetch_manifest
    local new_count=0 new_names=() failure_count=0 failure_names=() filters=()
    local target_module setup_target setup_mode setup_source setup_local_hash
    for target_module in "$@"; do
        filters+=("$target_module")
    done
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if [[ ${#filters[@]} -gt 0 ]]; then
            local found=0
            for f in "${filters[@]}"; do
                [[ "$module" == "$f" ]] && found=1 && break
            done
            [[ "$found" -eq 0 ]] && continue
        fi
        local target_path local_hash
        target_path=$(expand_path "$target")
        if [[ "$mode" == "script" ]]; then
            local script_target script_state script_status script_local script_remote script_installed script_extra
            IFS=$'\t' read -r script_target script_state script_status script_local script_remote script_installed script_extra \
                < <(script_status_fields "$module" "$target" "$source")
            case "$script_state" in
                current)
                    ;;
                outdated)
                    if ! _script_update "$module" "$target" "$source"; then
                        echo "Warning: $module update failed." >&2
                        failure_count=$((failure_count + 1))
                        failure_names+=("$module")
                    fi
                    ;;
                uninstalled)
                    new_count=$((new_count + 1))
                    new_names+=("$module")
                    ;;
                installed|unknown)
                    echo "Warning: could not determine whether $module is current; skipping update." >&2
                    failure_count=$((failure_count + 1))
                    failure_names+=("$module")
                    ;;
                *)
                    echo "Warning: could not probe $module; skipping update." >&2
                    failure_count=$((failure_count + 1))
                    failure_names+=("$module")
                    ;;
            esac
        else
            local_hash=$(installed_hash_for "$target_path" || true)
            if [[ "$module" == "setup" ]]; then
                setup_target="$target"; setup_mode="$mode"; setup_source="$source"
                setup_local_hash="$local_hash"
                continue
            fi
            if [[ -z "$local_hash" ]]; then
                new_count=$((new_count + 1))
                new_names+=("$module")
            else
                install_one "$module" "$target" "$mode" "$source"
            fi
        fi
    done < "$MANIFEST_FILE"
    # Update setup last — self-update exec restarts the process
    if [[ -n "${setup_target:-}" ]] && [[ -n "${setup_local_hash:-}" ]]; then
        install_one setup "$setup_target" "$setup_mode" "$setup_source"
    fi
    # All .zshrc blocks now exist (configure_shell + module loop); enforce order.
    normalize_block_order "$HOME/.zshrc" "${ZSHRC_BLOCK_ORDER[@]}"
    echo
    if [[ "$new_count" -gt 0 ]]; then
        echo "$new_count new module(s) available: ${new_names[*]}"
        echo "Run 'setup' to select what to install."
    fi
    if [[ "$failure_count" -gt 0 ]]; then
        echo "$failure_count module(s) could not be updated: ${failure_names[*]}" >&2
    elif [[ "$new_count" -eq 0 ]]; then
        echo "All modules up to date."
    fi
}

cmd_uninstall() {
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            if (($# > 0)); then
                local dc; dc=$(module_disable_cmd "$module") && {
                    echo "Disabling $module..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
                        ${dc} 2>&1 || true
                    else
                        sudo -E ${dc} 2>&1 || true
                    fi
                }
            fi
            uninstall_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    if (($# == 0)); then
        remove_shell_config
        rm -f "$MANIFEST_FILE" "$HASH_FILE"
        rmdir "$STATE_DIR" 2>/dev/null || true
    fi
}

cmd_diff() {
    fetch_manifest
    local module target mode source local_path payload found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        module_selected "$module" "$@" || continue
        [[ "$mode" == "script" ]] && continue
        found=1
        local_path=$(expand_path "$target")
        payload=$(mktemp)
        fetch_payload "$source" "$payload"
        if [[ -f "$local_path" ]]; then
            diff -u "$local_path" "$payload" || true
        else
            echo "Missing: $local_path"
        fi
        rm -f "$payload"
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }
}

cmd_enable() {
    local modules=("$@")
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        is_service_module "$module" || { echo "Not a service module: $module" >&2; continue; }
        local cmd; cmd=$(module_enable_cmd "$module")
        echo "Enabling $module..."
        if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
            ${cmd}
        else
            sudo -E ${cmd}
        fi
    done
}

cmd_disable() {
    local modules=("$@")
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        is_service_module "$module" || { echo "Not a service module: $module" >&2; continue; }
        local cmd; cmd=$(module_disable_cmd "$module")
        echo "Disabling $module..."
        if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
            ${cmd}
        else
            sudo -E ${cmd}
        fi
    done
}

cmd_doctor() {
    local missing=0 tool
    for tool in awk cat curl diff dirname git grep install mktemp mv rm rmdir; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            echo "missing: $tool"
            missing=1
        fi
    done
    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        echo "missing: sha256sum or shasum"
        missing=1
    fi
    ((missing == 0)) && echo "ok"
    return "$missing"
}

AUTOUPDATE_SERVICE_UNIT="[Unit]
Description=Daily setup update check

[Service]
Type=oneshot
ExecStart=%h/.local/bin/setup update
"

AUTOUPDATE_TIMER_UNIT="[Unit]
Description=Daily setup update

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
"

cmd_schedule() {
    if [[ "${1:-}" == "status" ]]; then
        shift
        (($# == 0)) || { echo "Usage: setup schedule status" >&2; return 2; }
        cmd_schedule_status
        return
    fi
    (($# == 0)) || { echo "Usage: setup schedule [status]" >&2; return 2; }

    local script_path
    script_path="$(command -v setup 2>/dev/null || echo "$HOME/.local/bin/setup")"
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local plist_dir="$HOME/Library/LaunchAgents"
        local plist="$plist_dir/com.lost.plus.setup-update.plist"
        mkdir -p "$plist_dir"
        cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lost.plus.setup-update</string>
    <key>ProgramArguments</key>
    <array>
        <string>$script_path</string>
        <string>update</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>3</integer>
        <key>Minute</key><integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/setup-update.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/setup-update.log</string>
</dict>
</plist>
PLIST
        local _uid; _uid=$(id -u)
        launchctl bootout "gui/$_uid/com.lost.plus.setup-update" 2>/dev/null || true
        launchctl bootstrap "gui/$_uid" "$plist" 2>/dev/null || true
        echo "setup auto-update scheduled daily at 03:00 (launchd)"
    else
        local dir="$HOME/.config/systemd/user"
        mkdir -p "$dir"
        echo "$AUTOUPDATE_SERVICE_UNIT" > "$dir/setup-update.service"
        echo "$AUTOUPDATE_TIMER_UNIT" > "$dir/setup-update.timer"
        systemctl --user daemon-reload
        systemctl --user enable --now setup-update.timer
        echo "setup auto-update scheduled daily (systemd)"
    fi
}

cmd_schedule_status() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local label="com.lost.plus.setup-update"
        local plist="$HOME/Library/LaunchAgents/$label.plist"
        local _uid; _uid=$(id -u)
        if [[ ! -f "$plist" ]]; then
            echo "setup auto-update not scheduled (launchd)"
            return 1
        fi
        if launchctl print "gui/$_uid/$label" >/dev/null 2>&1; then
            echo "setup auto-update scheduled daily at 03:00 (launchd, loaded)"
            return 0
        fi
        echo "setup auto-update configured but not loaded (launchd)"
        return 1
    fi

    local timer="$HOME/.config/systemd/user/setup-update.timer"
    if [[ ! -f "$timer" ]]; then
        echo "setup auto-update not scheduled (systemd)"
        return 1
    fi
    local enabled="no" active="no"
    systemctl --user is-enabled --quiet setup-update.timer 2>/dev/null && enabled="yes"
    systemctl --user is-active --quiet setup-update.timer 2>/dev/null && active="yes"
    if [[ "$enabled" == "yes" && "$active" == "yes" ]]; then
        echo "setup auto-update scheduled daily (systemd, enabled and active)"
        return 0
    fi
    echo "setup auto-update configured but inactive (systemd, enabled=$enabled active=$active)"
    return 1
}

cmd_unschedule() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local plist="$HOME/Library/LaunchAgents/com.lost.plus.setup-update.plist"
        local _uid; _uid=$(id -u)
        launchctl bootout "gui/$_uid/com.lost.plus.setup-update" 2>/dev/null || true
        rm -f "$plist"
        echo "setup auto-update unscheduled"
    else
        systemctl --user disable --now setup-update.timer 2>/dev/null || true
        rm -f "$HOME/.config/systemd/gui/setup-update.service" \
              "$HOME/.config/systemd/gui/setup-update.timer"
        systemctl --user daemon-reload
        echo "setup auto-update unscheduled"
    fi
}

# --- fzf interactive reconfigure ------------------------------------

detect_env_summary() {
    local os arch distro fs
    os=$(uname -s)
    arch=$(uname -m)
    if [[ -f /etc/os-release ]]; then
        distro=$(. /etc/os-release && echo "${NAME} ${VERSION_ID}")
    else
        distro="${os}"
    fi
    if [[ "$(uname -s)" == "Darwin" ]]; then
        fs=$(diskutil info / 2>/dev/null | awk '/File System/ {print $3}' || true)
        [[ -z "$fs" ]] && fs="unknown"
    else
        fs=$(stat -f -c '%T' / 2>/dev/null || echo "unknown")
    fi
    echo "${os} ${arch} · ${distro} · ${fs}"
}

confirm_action() {
    local prompt="$1" answer
    if command -v fzf >/dev/null 2>&1; then
        answer=$(printf '%s\n' yes no | fzf \
            --layout=reverse \
            --height=8 \
            --cycle \
            --bind='esc:abort' \
            --header="$prompt" 2>/dev/null || true)
    else
        printf '%s [y/N] ' "$prompt" >&2
        read -r answer || answer=""
        case "$answer" in
            y|Y|yes|YES|Yes) answer="yes" ;;
            *) answer="no" ;;
        esac
    fi

    if [[ "$answer" == "yes" ]]; then
        echo "Confirmed: $prompt"
        return 0
    fi
    echo "Canceled: $prompt"
    return 1
}

cmd_reconfigure() {
    fetch_manifest || true
    local env_summary
    env_summary="$(hostname -s) · $(detect_env_summary)"

    # Fetch remote checksums (one small file)
    fetch_checksums

    build_list() {
        # Rows are buffered so column widths can be sized to their content.
        local -a rows=("module|local|service|remote|status" "<ALL MODULES>|-|-|-|-")
        local -a non_svc=() svc=()

        while IFS=$'\t' read -r m t mo s; do
            [[ -z "${m:-}" || "$m" == \#* ]] && continue
            local target state file_installed extra \
                   svc_label local_label remote_label status_label

            # Script modules use one live probe for both CLI and table status.
            if [[ "$mo" == "script" ]]; then
                IFS=$'\t' read -r target state status_label local_label remote_label file_installed extra \
                    < <(script_status_fields "$m" "$t" "$s")
                svc_label=$([[ "$file_installed" == "1" ]] && echo installed || echo uninstalled)
                non_svc+=("$m|${local_label}|${svc_label}|${remote_label}|${status_label}")
                continue
            fi

            IFS=$'\t' read -r target state status_label local_label remote_label file_installed extra \
                < <(file_status_fields "$m" "$t" "$s")

            if is_service_module "$m"; then
                local unit; unit=$(module_service_unit "$m")
                if [[ "$unit" == "tool" ]]; then
                    svc_label=$([[ "$file_installed" == "1" ]] && echo "installed" || echo "uninstalled")
                elif [[ "$file_installed" == "1" ]] && module_is_active "$m"; then
                    svc_label="active"
                else
                    svc_label="inactive"
                fi
                svc+=("$m|${local_label}|${svc_label}|${remote_label}|${status_label}")
            else
                if [[ "$file_installed" == "1" ]]; then
                    svc_label="installed"
                else
                    svc_label="uninstalled"
                fi
                non_svc+=("$m|${local_label}|${svc_label}|${remote_label}|${status_label}")
            fi
        done < "$MANIFEST_FILE"

        # Sort each group alphabetically by module name
        IFS=$'\n' non_svc=($(sort <<<"${non_svc[*]}")); unset IFS
        IFS=$'\n' svc=($(sort <<<"${svc[*]}")); unset IFS
        rows+=("${non_svc[@]}" "${svc[@]}")

        # Size each column to its widest value across every row.
        local w0=0 w1=0 w2=0 w3=0 c0 c1 c2 c3 c4 entry
        for entry in "${rows[@]}"; do
            IFS='|' read -r c0 c1 c2 c3 c4 <<< "$entry"
            (( ${#c0} > w0 )) && w0=${#c0}
            (( ${#c1} > w1 )) && w1=${#c1}
            (( ${#c2} > w2 )) && w2=${#c2}
            (( ${#c3} > w3 )) && w3=${#c3}
        done

        # Print with dynamic widths (final column left unpadded).
        for entry in "${rows[@]}"; do
            IFS='|' read -r c0 c1 c2 c3 c4 <<< "$entry"
            printf "%-*s %-*s %-*s %-*s %s\n" "$w0" "$c0" "$w1" "$c1" "$w2" "$c2" "$w3" "$c3" "$c4"
        done
    }

    while true; do
        local selected mod target mode source action actions has_svc

        selected=$(build_list | fzf \
            --layout=reverse --cycle \
            --header="${env_summary}  |  ↑↓=navigate  Enter=actions  Esc=finish" \
            --bind='esc:abort' \
            --preview-window=hidden
        ) || break

        mod=$(echo "$selected" | awk '{print $1}')
        [[ -z "$mod" ]] && break

        if [[ "$mod" == "<ALL" ]]; then
            action=$(echo -e "update all\nreinstall all\nuninstall all\nrefresh list\ncancel" | fzf \
                --layout=reverse --cycle \
                --header="<ALL MODULES>" \
                --bind='esc:abort'
            ) || continue

            case "$action" in
                "refresh list")
                    _CSUM_CACHE=""
                    fetch_checksums
                    continue
                    ;;
                "update all")
                    confirm_action "Update ALL installed modules?" || continue
                    cmd_update
                    ;;
                "reinstall all")
                    local setup_entry
                    confirm_action "Reinstall ALL modules (overwrites local changes)?" || continue
                    FORCE=1
                    while IFS=$'\t' read -r m t mo s; do
                        [[ -z "${m:-}" || "$m" == \#* ]] && continue
                        if [[ "$m" == "setup" ]]; then
                            setup_entry="$t"$'\t'"$mo"$'\t'"$s"
                            continue
                        fi
                        install_one "$m" "$t" "$mo" "$s"
                    done < "$MANIFEST_FILE"
                    if [[ -n "${setup_entry:-}" ]]; then
                        IFS=$'\t' read -r st smo ss <<< "$setup_entry"
                        install_one setup "$st" "$smo" "$ss"
                    fi
                    FORCE=0
                    ;;
                "uninstall all")
                    confirm_action "Uninstall ALL modules? This is destructive." || continue
                    while IFS=$'\t' read -r m t mo s; do
                        [[ -z "${m:-}" || "$m" == \#* ]] && continue
                        local dc; dc=$(module_disable_cmd "$m") && {
                            echo "Disabling $m..."
                            if echo " ${USER_SERVICE_MODULES} " | grep -q " ${m} "; then
                                ${dc} 2>&1 || true
                            else
                                sudo -E ${dc} 2>&1 || true
                            fi
                        }
                        uninstall_one "$m" "$t" "$mo" "$s"
                    done < "$MANIFEST_FILE"
                    ;;
            esac
            continue
        fi

        while IFS=$'\t' read -r m t mo s; do
            [[ "$m" == "$mod" ]] && { target="$t"; mode="$mo"; source="$s"; break; }
        done < "$MANIFEST_FILE"
        [[ -z "$target" ]] && continue

        # Use cached values for state detection
        has_svc=0
        local file_installed=0 svc_active=0
        if [[ "$mode" == "script" ]]; then
            file_installed=$(is_script_installed "$mod" && echo 1 || echo 0)
        else
            got_local_hash=$(installed_hash_for "$(expand_path "$target")" || true)
            is_service_module "$mod" && has_svc=1
            if [[ -n "$got_local_hash" ]] || [[ -f "$(expand_path "$target")" ]]; then
                file_installed=1
            fi
            (( has_svc && file_installed )) && module_is_active "$mod" && svc_active=1
        fi

        actions=""
        if (( file_installed )); then
            (( has_svc && svc_active ))  && actions="${actions}disable"$'\n'
            (( has_svc && !svc_active )) && actions="${actions}enable"$'\n'
            actions="${actions}update"$'\n'
            actions="${actions}reinstall"$'\n'
            actions="${actions}uninstall"$'\n'
        else
            if (( has_svc )); then
                actions="install + enable"$'\n'
            else
                actions="install"$'\n'
            fi
        fi
        actions="${actions}cancel"

        action=$(echo "$actions" | fzf \
            --layout=reverse --cycle \
            --header="${mod}" \
            --bind='esc:abort'
        ) || continue

        case "$action" in
            cancel)    continue ;;
            install)   install_one "$mod" "$target" "$mode" "$source" ;;
            "install + enable")
                install_one "$mod" "$target" "$mode" "$source"
                local ec; ec=$(module_enable_cmd "$mod") && {
                    echo "Enabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${ec} 2>&1 || echo "(enable failed — see above)"
                    else
                        sudo -E ${ec} 2>&1 || echo "(enable failed — see above)"
                    fi
                } ;;
            enable)
                local ec; ec=$(module_enable_cmd "$mod") && {
                    echo "Enabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${ec} 2>&1 || echo "(enable failed — see above)"
                    else
                        sudo -E ${ec} 2>&1 || echo "(enable failed — see above)"
                    fi
                } ;;
            disable)
                local dc; dc=$(module_disable_cmd "$mod") && {
                    echo "Disabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${dc} 2>&1 || true
                    else
                        sudo -E ${dc} 2>&1 || true
                    fi
                } ;;
            update)
                install_one "$mod" "$target" "$mode" "$source" ;;
            reinstall)
                FORCE=1
                install_one "$mod" "$target" "$mode" "$source"
                FORCE=0 ;;
            uninstall)
                local dc; dc=$(module_disable_cmd "$mod") && {
                    echo "Disabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${dc} 2>&1 || true
                    else
                        sudo -E ${dc} 2>&1 || true
                    fi
                }
                uninstall_one "$mod" "$target" "$mode" "$source" ;;
        esac
        # A .zshrc block may have just been (re)written; keep canonical order.
        normalize_block_order "$HOME/.zshrc" "${ZSHRC_BLOCK_ORDER[@]}"
    done
}

if [[ "${SETUP_SOURCE_ONLY:-0}" == "1" ]]; then
    return 0 2>/dev/null || exit 0
fi

while (($# > 0)); do
    case "$1" in
        --force) FORCE=1; shift ;;
        --batch) BATCH=1; shift ;;
        help|-h|--help) usage; exit 0 ;;
        *) break ;;
    esac
done

# Post-install: check if refresh-models needs auth onboarding
_post_auth_check() {
    local auth_marker="$STATE_DIR/refresh-models.needs-auth"
    if [[ -f "$auth_marker" ]]; then
        if [[ -t 1 ]] && command -v fzf >/dev/null 2>&1; then
            echo
            echo "refresh-models is installed but needs API keys. Launching auth..."
            rm -f "$auth_marker"
            refresh-models auth
        else
            echo "Warning: refresh-models is installed but needs API keys. Run 'setup' or 'refresh-models auth' to configure." >&2
        fi
    fi
}

cmd="${1:-}"
shift || true

if [[ -z "$cmd" ]]; then
    if [[ -t 1 ]] && command -v fzf >/dev/null 2>&1; then
        configure_shell || true
        cmd_reconfigure
    else
        cmd_update || true
    fi
    _post_auth_check
    exit 0
fi

case "$cmd" in
    list) cmd_list "$@" ;;
    status) cmd_status "$@" ;;
    install) cmd_install "$@"; _post_auth_check ;;
    update) cmd_update "$@"; _post_auth_check ;;
    uninstall) cmd_uninstall "$@" ;;
    enable) cmd_enable "$@" ;;
    disable) cmd_disable "$@" ;;
    diff) cmd_diff "$@" ;;
    doctor) cmd_doctor ;;
    schedule) cmd_schedule "$@" ;;
    unschedule) cmd_unschedule "$@" ;;
    *) usage >&2; exit 1 ;;
esac
