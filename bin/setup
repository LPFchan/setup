#!/usr/bin/env bash
# setup-module: setup
# setup-source: bin/setup
set -uo pipefail
ORIG_ARGS=("$@")

SOURCE_URL="${LINUX_SETUP_SOURCE_URL:-https://raw.githubusercontent.com/LPFchan/setup/main}"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/setup"
MANIFEST_URL="$SOURCE_URL/manifest.tsv"
MANIFEST_FILE="$STATE_DIR/manifest.tsv"
HASH_FILE="$STATE_DIR/installed.tsv"
FORCE=0

SERVICE_MODULES="kernel-simmer service-ctl gpu-fancontrol monitoring refresh-models backup"
USER_SERVICE_MODULES="refresh-models"
BATCH=0

usage() {
    cat <<'EOF'
Usage: setup [--force] [--batch] <command> [module...]
  Flags must come before the command.
  --force  overwrite when uninstalling locally edited files
  --batch  non-interactive mode

Commands:
  list                 List available modules
  status [module...]   Show installed/current/outdated/modified state
  install [module...]  Install module files (copies to ~/.local/bin/)
  update [module...]   Update installed modules; reports new modules available
  uninstall [module...] Remove managed files
  enable [module...]   Enable service modules (requires sudo)
  disable [module...]  Disable service modules (requires sudo)
  diff [module...]     Show local diff against remote source
  doctor               Check required local tools
  schedule             Install daily auto-update timer
  unschedule           Remove daily auto-update timer

Run without arguments for interactive fzf reconfigure.

Environment:
  LINUX_SETUP_SOURCE_URL Override source URL root
EOF
}

module_enable_cmd() {
    case "$1" in
        kernel-simmer)  echo "kernel-simmer enable" ;;
        service-ctl)    echo "service-ctl enable --all" ;;
        gpu-fancontrol|monitoring)
                        echo "service-ctl enable $1" ;;
        refresh-models) echo "refresh-models enable" ;;
        backup)         echo "backup enable" ;;
    esac
}

module_disable_cmd() {
    case "$1" in
        kernel-simmer)  echo "kernel-simmer disable" ;;
        service-ctl)    echo "service-ctl disable --all" ;;
        gpu-fancontrol|monitoring)
                        echo "service-ctl disable $1" ;;
        refresh-models) echo "refresh-models disable" ;;
        backup)         echo "backup disable" ;;
    esac
}

module_service_unit() {
    case "$1" in
        service-ctl)    echo "tool" ;;
        kernel-simmer)  echo "kernel-simmer.timer" ;;
        gpu-fancontrol) echo "gpu-fancontrol.service" ;;
        monitoring)     echo "monitoring.service" ;;
        refresh-models) echo "refresh-models.timer" ;;
        backup)         echo "backup-daily.timer" ;;
    esac
}

is_service_module() {
    local m
    for m in ${SERVICE_MODULES}; do [[ "$m" == "$1" ]] && return 0; done
    return 1
}

module_is_active() {
    local unit user_flag=""
    unit=$(module_service_unit "$1") || return 1
    if echo " ${USER_SERVICE_MODULES} " | grep -q " $1 "; then
        user_flag="--user"
    fi
    # macOS: check launchd for refresh-models
    if [[ "$1" == "refresh-models" ]] && [[ "$(uname -s)" == "Darwin" ]]; then
        launchctl print "gui/$(id -u)/com.lost.plus.refresh-models" &>/dev/null && return 0
        return 1
    fi
    [[ "$(systemctl ${user_flag} is-active "${unit}" 2>/dev/null)" == "active" ]]
}

sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        if [[ -n "${1:-}" ]]; then
            sha256sum "$1" | cut -d' ' -f1
        else
            sha256sum | cut -d' ' -f1
        fi
    elif command -v shasum >/dev/null 2>&1; then
        if [[ -n "${1:-}" ]]; then
            shasum -a 256 "$1" | cut -d' ' -f1
        else
            shasum -a 256 | cut -d' ' -f1
        fi
    else
        echo "missing sha256sum/shasum" >&2; exit 1
    fi
}

expand_path() {
    case "$1" in
        '~') printf '%s\n' "$HOME" ;;
        '~/'*) printf '%s/%s\n' "$HOME" "${1:2}" ;;
        *) printf '%s\n' "$1" ;;
    esac
}

fetch_manifest() {
    mkdir -p "$STATE_DIR"
    curl -fsSL "$MANIFEST_URL" -o "$MANIFEST_FILE" 2>/dev/null || true
}

module_selected() {
    local module="$1"
    shift || true
    if (($# == 0)); then
        return 0
    fi
    local wanted
    for wanted in "$@"; do
        [[ "$module" == "$wanted" ]] && return 0
    done
    return 1
}

installed_hash_for() {
    local target="$1"
    [[ -f "$HASH_FILE" ]] || return 0
    while IFS=$'\t' read -r path hash version; do
        [[ "$path" == "$target" ]] && printf '%s\n' "$hash" && return 0
    done < "$HASH_FILE"
}
fetch_checksums() {
    # Download checksums.tsv and cache source → sha256 mappings.
    if [[ -n "${_CSUM_CACHE:-}" ]]; then
        return 0
    fi
    local tmp
    tmp=$(mktemp)
    if curl -fsSL "$SOURCE_URL/checksums.tsv" -o "$tmp" 2>/dev/null \
        && grep -q '^# source' "$tmp"; then
        _CSUM_CACHE=$(cat "$tmp")
    else
        echo "Warning: could not fetch checksums.tsv from $SOURCE_URL" >&2
    fi
    rm -f "$tmp"
}

remote_checksum() {
    local source="$1"
    [[ -z "${_CSUM_CACHE:-}" ]] && fetch_checksums
    printf '%s\n' "${_CSUM_CACHE:-}" | grep "^${source}"$'\t' | head -1 | cut -f2
}

AI_MIGRATION_SENTINEL="${STATE_DIR}/ai-menu-migrated"

_cleanup_legacy_ai_files() {
    [[ -f "$AI_MIGRATION_SENTINEL" ]] && return 0

    rm -f "$HOME/.bashrc.d/ai-start-menu"
    for _f in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.zshenv"; do
        [[ -f "$_f" ]] || continue
        if grep -qE 'linux-setup:(zsh-ai|bash-ai)' "$_f" 2>/dev/null; then
            _tmp=$(mktemp)
            awk '
                /^# >>> linux-setup:zsh-ai >>>/   { skip=1; next }
                /^# >>> linux-setup:bash-ai >>>/  { skip=1; next }
                /^# <<< linux-setup:zsh-ai <<</   { skip=0; next }
                /^# <<< linux-setup:bash-ai <<</  { skip=0; next }
                !skip { print }
            ' "$_f" > "$_tmp" && mv "$_tmp" "$_f"
        fi
        if grep -q 'ai-start-menu' "$_f" 2>/dev/null; then
            sed -i'' -e '/ai-start-menu/d' "$_f" 2>/dev/null || true
        fi
    done

    mkdir -p "${AI_MIGRATION_SENTINEL%/*}"
    touch "$AI_MIGRATION_SENTINEL"
    echo "Migrated ai-menu shell blocks"
}

_migrate_auth_json() {
    local old="$HOME/.local/share/opencode/auth.json"
    [[ -f "$old" ]] || return 0
    python3 -c "
import json, os, pathlib
old = os.path.expanduser('~/.local/share/opencode/auth.json')
zsenv = os.path.expanduser('~/.zshenv')
begin = '# BEGIN setup:api-keys'
end = '# END setup:api-keys'
try:
    data = json.load(open(old))
except Exception:
    exit(0)
if not isinstance(data, dict) or not data:
    exit(0)
lines = []
for p, e in data.items():
    if not isinstance(e, dict):
        continue
    etype = e.get('type', '')
    if etype == 'api':
        key = e.get('key', '')
        if key and isinstance(key, str) and key.strip():
            provider = p.replace('-', '_').upper()
            lines.append(f'export {provider}_API_KEY={key.strip()}')
    elif etype == 'oauth':
        access = e.get('access', '')
        if access and isinstance(access, str):
            provider = p.replace('-', '_').upper()
            lines.append(f'export {provider}_OAUTH_TOKEN={access}')
if not lines:
    exit(0)
existing = []
in_block = False
if os.path.exists(zsenv):
    for l in open(zsenv):
        s = l.strip()
        if s == begin: in_block = True; continue
        if s == end: in_block = False; continue
        if not in_block:
            existing.append(l)
with open(zsenv, 'w') as f:
    for l in existing:
        f.write(l)
    f.write(f'\n{begin}\n')
    for l in lines:
        f.write(l + '\n')
    f.write(f'{end}\n')
print(f'Exported {len(lines)} key(s) from {old} to {zsenv}')
" 2>&1 || true
}

module_for() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    while IFS= read -r line; do
        case "$line" in
            '# setup-module: '*) printf '%s\n' "${line#'# setup-module: '}"; return 0 ;;
            '# linux-setup-module: '*) printf '%s\n' "${line#'# linux-setup-module: '}"; return 0 ;;
        esac
    done < "$file"
}


has_managed_block() {
    local file="$1" label="$2"
    [[ -f "$file" ]] || return 1
    grep -Fq "# >>> linux-setup:$label >>>" "$file"
}

# --- shell config helpers (for setup command) -----------------------

manage_block() {
    local file="$1" label="$2" content="$3" mode="$4" position="${5:-append}"
    local begin_mark="# >>> linux-setup:$label >>>"
    local end_mark="# <<< linux-setup:$label <<<"

    mkdir -p "$(dirname "$file")"
    touch "$file"

    _extract_block_body() {
        # Print lines between begin_mark and end_mark, exclusive.
        # Normalize: strip a single trailing newline if present.
        awk -v begin="$begin_mark" -v end="$end_mark" '
            $0 == begin { inblock=1; next }
            $0 == end   { inblock=0; next }
            inblock { print }
        ' "$file" | sed '$ { /^$/ d; }'
    }

    case "$mode" in
        remove)
            grep -Fq "$begin_mark" "$file" || return 0
            local _tmp; _tmp=$(mktemp)
            awk -v begin="$begin_mark" -v end="$end_mark" '
                $0 == begin { skip=1; next }
                $0 == end   { skip=0; next }
                !skip
            ' "$file" > "$_tmp" && mv "$_tmp" "$file"
            echo "Removed $label from $file"
            ;;
        prepend|append)
            if grep -Fq "$begin_mark" "$file"; then
                echo "Current $label -> $file"
                return 0
            fi
            if [[ "$position" == "prepend" ]]; then
                local _tmp; _tmp=$(mktemp)
                { printf '%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n\n' "$end_mark"; cat "$file"; } > "$_tmp"
                mv "$_tmp" "$file"
            else
                { printf '\n%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n' "$end_mark"; } >> "$file"
            fi
            echo "Added $label -> $file"
            ;;
        upsert)
            local new_hash; new_hash=$(printf '%s' "$content" | sed '$ { /^$/ d; }' | sha256)
            if ! grep -Fq "$begin_mark" "$file"; then
                if [[ "$position" == "prepend" ]]; then
                    local _tmp; _tmp=$(mktemp)
                    { printf '%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n\n' "$end_mark"; cat "$file"; } > "$_tmp"
                    mv "$_tmp" "$file"
                else
                    { printf '\n%s\n' "$begin_mark"; printf '%s\n' "$content"; printf '%s\n' "$end_mark"; } >> "$file"
                fi
                echo "Added $label -> $file"
                return 0
            fi
            local old_hash; old_hash=$(_extract_block_body | sha256)
            if [[ "$new_hash" != "$old_hash" ]]; then
                local _tmp; _tmp=$(mktemp)
                {
                    awk -v begin="$begin_mark" -v end="$end_mark" '
                        $0 == begin { print; skip=1; next }
                        $0 == end   { skip=0 }
                        !skip { print }
                    ' "$file" | while IFS= read -r line; do
                        if [[ "$line" == "$begin_mark" ]]; then
                            printf '%s\n' "$line"
                            printf '%s\n' "$content"
                        else
                            printf '%s\n' "$line"
                        fi
                    done
                } > "$_tmp" && mv "$_tmp" "$file"
                echo "Updated $file $label"
            else
                echo "Current $label -> $file"
            fi
            ;;
    esac
}

BLOCK_DELIM=$'\x1f'
BLOCK_REGISTRY=(
    "zshenv${BLOCK_DELIM}path${BLOCK_DELIM}path_block${BLOCK_DELIM}upsert${BLOCK_DELIM}prepend"
    "zshrc${BLOCK_DELIM}zsh-ai${BLOCK_DELIM}zsh_ai_block${BLOCK_DELIM}upsert${BLOCK_DELIM}prepend"
    "bashrc${BLOCK_DELIM}path${BLOCK_DELIM}path_block${BLOCK_DELIM}upsert${BLOCK_DELIM}append"
    "bashrc${BLOCK_DELIM}bash-ai${BLOCK_DELIM}bash_ai_block${BLOCK_DELIM}upsert${BLOCK_DELIM}append"
)

configure_shell() {
    _cleanup_legacy_ai_files

    local path_block zsh_ai_block bash_ai_block bash_profile_block

    path_block='case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac'

    zsh_ai_block='[[ -o interactive && -t 0 ]] || return
[[ -n ${TERM_PROGRAM-} || -n ${SSH_TTY-} ]] || return
(( SHLVL > 1 )) && return

[[ -f "$HOME/.bashrc.d/ai-menu" ]] && source "$HOME/.bashrc.d/ai-menu"
if (( ${+functions[ai]} )) && [[ -z "${AI_AUTO_LAUNCHED:-}" ]]; then
    export AI_AUTO_LAUNCHED=1
    ai
fi'

    bash_ai_block='[[ $- == *i* && -t 0 ]] || return

[[ -f "$HOME/.bashrc.d/ai-menu" ]] && source "$HOME/.bashrc.d/ai-menu"
if declare -F ai >/dev/null && [[ -z "${AI_AUTO_LAUNCHED:-}" ]]; then
    export AI_AUTO_LAUNCHED=1
    ai
fi'

    bash_profile_block='case ":$PATH:" in
    *":$HOME/.local/bin:"*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

if [[ -f "$HOME/.bashrc" ]]; then
    . "$HOME/.bashrc"
fi'

    for entry in "${BLOCK_REGISTRY[@]}"; do
        IFS="$BLOCK_DELIM" read -r file_key label content_var mode position <<< "$entry"
        manage_block "$HOME/.$file_key" "$label" "${!content_var}" "$mode" "$position"
    done

    if [[ ! -f "$HOME/.bash_profile" && ! -f "$HOME/.bash_login" && ! -f "$HOME/.profile" ]]; then
        manage_block "$HOME/.bash_profile" bash-profile "$bash_profile_block" upsert append
    elif [[ -f "$HOME/.bash_profile" ]]; then
        manage_block "$HOME/.bash_profile" bash-profile "$bash_profile_block" upsert append
    else
        echo "Current bash login profile -> existing profile"
    fi
}

fetch_payload() {
    local source="$1" payload="$2"
    if curl -fsSL "$SOURCE_URL/$source" -o "$payload" 2>/dev/null \
        && grep -q '^# setup-module: ' "$payload"; then
        return 0
    fi
    echo "Failed to fetch $source from $SOURCE_URL" >&2
    return 1
}

record_hash() {
    local target="$1" hash="$2" version="$3" tmp
    mkdir -p "$STATE_DIR"
    tmp=$(mktemp)
    if [[ -f "$HASH_FILE" ]]; then
        while IFS=$'\t' read -r path old_hash old_version; do
            [[ "$path" == "$target" ]] && continue
            printf '%s\t%s\t%s\n' "$path" "$old_hash" "${old_version:-}"
        done < "$HASH_FILE" > "$tmp"
    fi
    printf '%s\t%s\t%s\n' "$target" "$hash" "$version" >> "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_hash() {
    local target="$1" tmp
    [[ -f "$HASH_FILE" ]] || return 0
    tmp=$(mktemp)
    while IFS=$'\t' read -r path old_hash old_version; do
        [[ "$path" == "$target" ]] && continue
        printf '%s\t%s\t%s\n' "$path" "$old_hash" "${old_version:-}"
    done < "$HASH_FILE" > "$tmp"
    mv "$tmp" "$HASH_FILE"
}

remove_marker_blocks() {
    local file="$1" tmp status=0
    [[ -f "$file" ]] || return 0
    tmp=$(mktemp)
    awk '
        /^# >>> linux-setup:/ { skip=1; changed=1; next }
        /^# <<< linux-setup:/ { skip=0; next }
        !skip { print }
        END { if (changed) exit 42 }
    ' "$file" > "$tmp" || status=$?
    status=${status:-0}
    if [[ "$status" == 42 ]]; then
        mv "$tmp" "$file"
        echo "Updated $file"
    else
        rm -f "$tmp"
    fi
}

remove_shell_config() {
    remove_marker_blocks "$HOME/.zshenv"
    remove_marker_blocks "$HOME/.zshrc"
    remove_marker_blocks "$HOME/.bashrc"
    remove_marker_blocks "$HOME/.bash_profile"
}

uninstall_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"
    local target old_hash current_hash local_module
    target=$(expand_path "$target_spec")
    old_hash=$(installed_hash_for "$target" || true)

    if [[ ! -f "$target" ]]; then
        remove_hash "$target"
        echo "Missing $module -> $target"
        return 0
    fi

    if [[ -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" && "$FORCE" -ne 1 ]]; then
            echo "Local changes detected: keeping $target (use --force to remove)"
            return 0
        fi
    elif [[ "$FORCE" -ne 1 ]]; then
        local_module=$(module_for "$target" || true)
        if [[ "$local_module" != "$module" ]]; then
            echo "Untracked file: keeping $target (use --force to remove)"
            return 0
        fi
    fi

    rm -f "$target"
    remove_hash "$target"
    echo "Removed $module -> $target"
}

install_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"
    local target dir payload old_hash current_hash new_hash install_target remote_module remote_hash

    target=$(expand_path "$target_spec")
    dir=$(dirname "$target")
    mkdir -p "$dir"

    payload=$(mktemp)

    fetch_payload "$source" "$payload" || { rm -f "$payload"; return 1; }
    remote_module=$(module_for "$payload" || true)

    if [[ "$remote_module" != "$module" ]]; then
        echo "Metadata mismatch for $source: expected module '$module', got '${remote_module:-missing}'" >&2
        rm -f "$payload"
        return 1
    fi

    new_hash=$(sha256 "$payload")
    old_hash=$(installed_hash_for "$target" || true)

    if [[ -f "$target" && -n "$old_hash" ]] && [[ "$new_hash" == "$old_hash" ]] && [[ "$FORCE" -ne 1 ]]; then
        # Run one-time migration even when file is current
        if [[ "$module" == "ai-menu" ]]; then
            _cleanup_legacy_ai_files
        fi
        if [[ "$module" == "refresh-models" ]]; then
            _migrate_auth_json
        fi
        echo "$module ${old_hash:0:7} (current) -> $target"
        rm -f "$payload"
        return 0
    fi

    if [[ -f "$target" && -n "$old_hash" ]] && [[ "$new_hash" != "$old_hash" ]]; then
        :
    elif [[ -f "$target" ]]; then
        install -m "$mode" "$payload" "$target"
        record_hash "$target" "$new_hash" "$new_hash"
        echo "$module ${new_hash:0:7} (foreign) -> $target"
        rm -f "$payload"
        if [[ "$module" == "ai-menu" ]]; then
            _cleanup_legacy_ai_files
        fi
        if [[ "$module" == "refresh-models" ]]; then
            _migrate_auth_json
        fi
        if [[ "$module" == "setup" ]]; then
            echo "Restarting setup..."
            exec "$target" ${ORIG_ARGS[@]+"${ORIG_ARGS[@]}"}
        fi
        return 0
    fi

    install -m "$mode" "$payload" "$target"
    record_hash "$target" "$new_hash" "$new_hash"
    if [[ -n "$old_hash" && "$old_hash" != "$new_hash" ]]; then
        echo "$module ${old_hash:0:7} -> ${new_hash:0:7} -> $target"
    else
        echo "$module ${new_hash:0:7} (install) -> $target"
    fi
    if [[ "$module" == "ai-menu" ]]; then
        rm -f "$HOME/.bashrc.d/ai-start-menu"
        for _f in "$HOME/.zshrc" "$HOME/.zshenv" "$HOME/.bashrc"; do
            [[ -f "$_f" ]] && sed -i'' -e '/ai-start-menu/d' "$_f" 2>/dev/null || true
        done
    fi
    if [[ "$module" == "refresh-models" ]]; then
        _migrate_auth_json
    fi
    rm -f "$payload"
    if [[ "$module" == "setup" ]]; then
        echo "Restarting setup..."
        exec "$target" "${ORIG_ARGS[@]}"
    fi
}

status_one() {
    local module="$1" target_spec="$2" mode="$3" source="$4"
    local target payload remote_hash local_hash local_module old_hash current_hash state extra
    target=$(expand_path "$target_spec")
    remote_hash=$(remote_checksum "$source")

    if [[ ! -f "$target" ]]; then
        printf '%-14s %-12s remote=%s target=%s\n' "$module" "uninstalled" "${remote_hash:0:7}" "$target"
        return 0
    fi

    local_module=$(module_for "$target" || true)
    old_hash=$(installed_hash_for "$target" || true)

    if [[ "$local_module" != "$module" ]]; then
        printf '%-14s %-12s target=%s\n' "$module" "foreign" "$target"
        return 0
    fi

    state="current"
    extra="local=${old_hash:0:7} remote=${remote_hash:0:7}"

    if [[ -n "$old_hash" ]]; then
        current_hash=$(sha256 "$target")
        if [[ "$current_hash" != "$old_hash" ]]; then
            state="modified"
        fi
    else
        extra="$extra untracked-hash"
    fi

    if [[ "$state" != "modified" ]]; then
        if [[ -n "$old_hash" && "$old_hash" != "$remote_hash" ]]; then
            state="outdated"
        fi
    fi

    printf '%-14s %-12s %s target=%s\n' "$module" "$state" "$extra" "$target"
}

cmd_list() {
    fetch_manifest
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        printf '%-14s %s\n' "$module" "$target"
    done < "$MANIFEST_FILE"
}

cmd_status() {
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            status_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    if (($# == 0)); then
        echo
        shell_status
    fi
}

shell_status() {
    shell_status_one "$HOME/.zshenv" path
    shell_status_one "$HOME/.zshrc" zsh-ai
    shell_status_one "$HOME/.bashrc" path
    shell_status_one "$HOME/.bashrc" bash-ai
    if [[ -f "$HOME/.bash_profile" || -f "$HOME/.bash_login" || -f "$HOME/.profile" ]]; then
        printf '%-14s %-12s target=%s\n' "bash-profile" "existing" "login profile present"
    else
        printf '%-14s %-12s target=%s\n' "bash-profile" "missing" "$HOME/.bash_profile"
    fi
}

shell_status_one() {
    local file="$1" label="$2"
    if has_managed_block "$file" "$label"; then
        printf '%-14s %-12s target=%s\n' "$label" "managed" "$file"
    else
        printf '%-14s %-12s target=%s\n' "$label" "missing" "$file"
    fi
}

cmd_install() {
    local modules=("$@")
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "${modules[@]}"; then
            found=1
            install_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    # Enable each installed service module
    for module in "${modules[@]}"; do
        is_service_module "$module" || continue
        local ec; ec=$(module_enable_cmd "$module")
        echo "Enabling $module..."
        if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
            ${ec} 2>&1 || echo "(enable failed — check above for errors)"
        else
            sudo -E ${ec} 2>&1 || echo "(enable failed — run 'setup enable $module' with sudo)"
        fi
    done
}

cmd_update() {
    fetch_manifest
    local new_count=0 new_names=() filters=()
    local target_module
    for target_module in "$@"; do
        filters+=("$target_module")
    done
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if [[ ${#filters[@]} -gt 0 ]]; then
            local found=0
            for f in "${filters[@]}"; do
                [[ "$module" == "$f" ]] && found=1 && break
            done
            [[ "$found" -eq 0 ]] && continue
        fi
        local target_path local_hash
        target_path=$(expand_path "$target")
        local_hash=$(installed_hash_for "$target_path" || true)
        if [[ -z "$local_hash" ]]; then
            new_count=$((new_count + 1))
            new_names+=("$module")
        else
            install_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    echo
    if [[ "$new_count" -gt 0 ]]; then
        echo "$new_count new module(s) available: ${new_names[*]}"
        echo "Run 'setup' to select what to install."
    else
        echo "All modules up to date."
    fi
}

cmd_uninstall() {
    fetch_manifest
    local found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        if module_selected "$module" "$@"; then
            found=1
            if (($# > 0)); then
                local dc; dc=$(module_disable_cmd "$module") && {
                    echo "Disabling $module..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
                        ${dc} 2>&1 || true
                    else
                        sudo -E ${dc} 2>&1 || true
                    fi
                }
            fi
            uninstall_one "$module" "$target" "$mode" "$source"
        fi
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }

    if (($# == 0)); then
        remove_shell_config
        rm -f "$MANIFEST_FILE" "$HASH_FILE"
        rmdir "$STATE_DIR" 2>/dev/null || true
    fi
}

cmd_diff() {
    fetch_manifest
    local module target mode source local_path payload found=0
    while IFS=$'\t' read -r module target mode source; do
        [[ -z "${module:-}" || "$module" == \#* ]] && continue
        module_selected "$module" "$@" || continue
        found=1
        local_path=$(expand_path "$target")
        payload=$(mktemp)
        fetch_payload "$source" "$payload"
        if [[ -f "$local_path" ]]; then
            diff -u "$local_path" "$payload" || true
        else
            echo "Missing: $local_path"
        fi
        rm -f "$payload"
    done < "$MANIFEST_FILE"
    ((found == 1)) || { echo "No matching modules." >&2; exit 1; }
}

cmd_enable() {
    local modules=("$@")
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        is_service_module "$module" || { echo "Not a service module: $module" >&2; continue; }
        local cmd; cmd=$(module_enable_cmd "$module")
        echo "Enabling $module..."
        if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
            ${cmd}
        else
            sudo -E ${cmd}
        fi
    done
}

cmd_disable() {
    local modules=("$@")
    ((${#modules[@]} == 0)) && modules=(${SERVICE_MODULES})
    for module in "${modules[@]}"; do
        is_service_module "$module" || { echo "Not a service module: $module" >&2; continue; }
        local cmd; cmd=$(module_disable_cmd "$module")
        echo "Disabling $module..."
        if echo " ${USER_SERVICE_MODULES} " | grep -q " ${module} "; then
            ${cmd}
        else
            sudo -E ${cmd}
        fi
    done
}

cmd_doctor() {
    local missing=0 tool
    for tool in awk cat curl cut diff dirname grep install mktemp mv rm rmdir; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            echo "missing: $tool"
            missing=1
        fi
    done
    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        echo "missing: sha256sum or shasum"
        missing=1
    fi
    ((missing == 0)) && echo "ok"
    return "$missing"
}

AUTOUPDATE_SERVICE_UNIT="[Unit]
Description=Daily setup update check

[Service]
Type=oneshot
ExecStart=%h/.local/bin/setup update
"

AUTOUPDATE_TIMER_UNIT="[Unit]
Description=Daily setup update

[Timer]
OnCalendar=daily
Persistent=true

[Install]
WantedBy=timers.target
"

cmd_schedule() {
    local script_path
    script_path="$(command -v setup 2>/dev/null || echo "$HOME/.local/bin/setup")"
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local plist_dir="$HOME/Library/LaunchAgents"
        local plist="$plist_dir/com.lost.plus.setup-update.plist"
        mkdir -p "$plist_dir"
        cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.lost.plus.setup-update</string>
    <key>ProgramArguments</key>
    <array>
        <string>$script_path</string>
        <string>update</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>3</integer>
        <key>Minute</key><integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/setup-update.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/setup-update.log</string>
</dict>
</plist>
PLIST
        local _uid; _uid=$(id -u)
        launchctl bootout "gui/$_uid/com.lost.plus.setup-update" 2>/dev/null || true
        local r; r=$(launchctl bootstrap "gui/$_uid" "$plist" 2>&1) || true
        if echo "$r" | grep -q '125'; then
            launchctl load "$plist" 2>/dev/null || true
        fi
        echo "setup auto-update scheduled daily at 03:00 (launchd)"
    else
        local dir="$HOME/.config/systemd/user"
        mkdir -p "$dir"
        echo "$AUTOUPDATE_SERVICE_UNIT" > "$dir/setup-update.service"
        echo "$AUTOUPDATE_TIMER_UNIT" > "$dir/setup-update.timer"
        systemctl --user daemon-reload
        systemctl --user enable --now setup-update.timer
        echo "setup auto-update scheduled daily (systemd)"
    fi
}

cmd_unschedule() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        local plist="$HOME/Library/LaunchAgents/com.lost.plus.setup-update.plist"
        local _uid; _uid=$(id -u)
        launchctl bootout "gui/$_uid/com.lost.plus.setup-update" 2>/dev/null || true
        rm -f "$plist"
        echo "setup auto-update unscheduled"
    else
        systemctl --user disable --now setup-update.timer 2>/dev/null || true
        rm -f "$HOME/.config/systemd/user/setup-update.service" \
              "$HOME/.config/systemd/user/setup-update.timer"
        systemctl --user daemon-reload
        echo "setup auto-update unscheduled"
    fi
}

# --- fzf interactive reconfigure ------------------------------------

detect_env_summary() {
    local os arch distro fs
    os=$(uname -s)
    arch=$(uname -m)
    if [[ -f /etc/os-release ]]; then
        distro=$(. /etc/os-release && echo "${NAME} ${VERSION_ID}")
    else
        distro="${os}"
    fi
    if [[ "$(uname -s)" == "Darwin" ]]; then
        fs=$(diskutil info / 2>/dev/null | awk '/File System/ {print $3}' || true)
        [[ -z "$fs" ]] && fs="unknown"
    else
        fs=$(stat -f -c '%T' / 2>/dev/null || echo "unknown")
    fi
    echo "${os} ${arch} · ${distro} · ${fs}"
}

cmd_reconfigure() {
    configure_shell || true
    fetch_manifest || true
    local env_summary
    env_summary="$(hostname -s) · $(detect_env_summary)"

    # Fetch remote checksums (one small file)
    fetch_checksums

    build_list() {
        # Header: name, local_ver, service, remote_ver, status
        printf "%-14s %-13s %-11s %-13s %-17s\n" \
            "module" "local" "service" "remote" "status"

        # <ALL MODULES> pseudo-entry
        printf "%-14s %-13s %-11s %-13s %-17s\n" \
            "<ALL MODULES>" "-" "-" "-" "-"

        while IFS=$'\t' read -r m t mo s; do
            [[ -z "${m:-}" || "$m" == \#* ]] && continue
            local target local_hash remote_hash \
                   svc_label local_label remote_label status_label

            target=$(expand_path "$t")
            local_hash=$(installed_hash_for "$target" || true)
            remote_hash=$(remote_checksum "$s")
            [[ -z "$remote_hash" ]] && remote_hash="-"

            if [[ -z "$local_hash" || "$local_hash" == "-" ]]; then
                if [[ -f "$target" ]]; then
                    local_label="${local_hash:0:7}"
                    status_label="installed (untracked)"
                else
                    local_label="-"
                    status_label="not installed"
                fi
            elif [[ "$local_hash" != "$remote_hash" ]]; then
                local_label="${local_hash:0:7}"
                status_label="update available"
            else
                local_label="${local_hash:0:7}"
                status_label="up-to-date"
            fi

            [[ -z "$remote_hash" || "$remote_hash" == "-" ]] && remote_label="-" || remote_label="${remote_hash:0:7}"

            if is_service_module "$m"; then
                local unit; unit=$(module_service_unit "$m")
                if [[ "$unit" == "tool" ]]; then
                    svc_label=$([[ -f "$target" ]] && echo "installed" || echo "uninstalled")
                elif module_is_active "$m"; then
                    svc_label="active"
                else
                    svc_label="inactive"
                fi
                svc+=("$m|${local_label}|${svc_label}|${remote_label}|${status_label}")
            else
                if [[ (-n "$local_hash" && "$local_hash" != "-") || -f "$target" ]]; then
                    svc_label="installed"
                else
                    svc_label="uninstalled"
                fi
                non_svc+=("$m|${local_label}|${svc_label}|${remote_label}|${status_label}")
            fi
        done < "$MANIFEST_FILE"

        # Sort each group alphabetically by module name
        IFS=$'\n' non_svc=($(sort <<<"${non_svc[*]}")); unset IFS
        IFS=$'\n' svc=($(sort <<<"${svc[*]}")); unset IFS

        # Print non-service first, then service
        for entry in "${non_svc[@]}" "${svc[@]}"; do
            IFS='|' read -r m l s r u <<< "$entry"
            printf "%-14s %-13s %-11s %-13s %-17s\n" "$m" "$l" "$s" "$r" "$u"
        done
    }

    while true; do
        local selected mod target mode source action actions has_svc

        selected=$(build_list | fzf \
            --layout=reverse --cycle \
            --header="${env_summary}  |  ↑↓=navigate  Enter=actions  Esc=finish" \
            --bind='esc:abort' \
            --preview-window=hidden
        ) || break

        mod=$(echo "$selected" | awk '{print $1}')
        [[ -z "$mod" ]] && break

        if [[ "$mod" == "<ALL" ]]; then
            action=$(echo -e "update all\nreinstall all\nuninstall all\nrefresh list\ncancel" | fzf \
                --layout=reverse --cycle \
                --header="<ALL MODULES>" \
                --bind='esc:abort'
            ) || continue

            case "$action" in
                "refresh list")
                    _CSUM_CACHE=""
                    fetch_checksums
                    continue
                    ;;
                "update all")
                    local confirm
                    confirm=$(echo -e "yes\nno" | fzf --layout=reverse --height=3 --cycle --bind='esc:abort' --header="Update ALL installed modules?" 2>/dev/null || true)
                    [[ "$confirm" == "yes" ]] || continue
                    while IFS=$'\t' read -r m t mo s; do
                        [[ -z "${m:-}" || "$m" == \#* ]] && continue
                        local_hash=$(installed_hash_for "$(expand_path "$t")" || true)
                        [[ -n "$local_hash" ]] && install_one "$m" "$t" "$mo" "$s"
                    done < "$MANIFEST_FILE"
                    ;;
                "reinstall all")
                    local confirm
                    confirm=$(echo -e "yes\nno" | fzf --layout=reverse --height=3 --cycle --bind='esc:abort' --header="Reinstall ALL modules (overwrites local changes)?" 2>/dev/null || true)
                    [[ "$confirm" == "yes" ]] || continue
                    FORCE=1
                    while IFS=$'\t' read -r m t mo s; do
                        [[ -z "${m:-}" || "$m" == \#* ]] && continue
                        install_one "$m" "$t" "$mo" "$s"
                    done < "$MANIFEST_FILE"
                    FORCE=0
                    ;;
                "uninstall all")
                    local confirm
                    confirm=$(echo -e "yes\nno" | fzf --layout=reverse --height=3 --cycle --bind='esc:abort' --header="Uninstall ALL modules? This is destructive." 2>/dev/null || true)
                    [[ "$confirm" == "yes" ]] || continue
                    while IFS=$'\t' read -r m t mo s; do
                        [[ -z "${m:-}" || "$m" == \#* ]] && continue
                        local dc; dc=$(module_disable_cmd "$m") && {
                            echo "Disabling $m..."
                            if echo " ${USER_SERVICE_MODULES} " | grep -q " ${m} "; then
                                ${dc} 2>&1 || true
                            else
                                sudo -E ${dc} 2>&1 || true
                            fi
                        }
                        uninstall_one "$m" "$t" "$mo" "$s"
                    done < "$MANIFEST_FILE"
                    ;;
            esac
            continue
        fi

        while IFS=$'\t' read -r m t mo s; do
            [[ "$m" == "$mod" ]] && { target="$t"; mode="$mo"; source="$s"; break; }
        done < "$MANIFEST_FILE"
        [[ -z "$target" ]] && continue

        # Use cached values for state detection
        got_local_hash=$(installed_hash_for "$(expand_path "$target")" || true)
        has_svc=0
        is_service_module "$mod" && has_svc=1
        local file_installed=0 svc_active=0
        if [[ -n "$got_local_hash" ]] || [[ -f "$(expand_path "$target")" ]]; then
            file_installed=1
        fi
        (( has_svc && file_installed )) && module_is_active "$mod" && svc_active=1

        actions=""
        if (( file_installed )); then
            (( has_svc && svc_active ))  && actions="${actions}disable"$'\n'
            (( has_svc && !svc_active )) && actions="${actions}enable"$'\n'
            actions="${actions}update"$'\n'
            actions="${actions}reinstall"$'\n'
            actions="${actions}uninstall"$'\n'
        else
            if (( has_svc )); then
                actions="install + enable"$'\n'
            else
                actions="install"$'\n'
            fi
        fi
        actions="${actions}cancel"

        action=$(echo "$actions" | fzf \
            --layout=reverse --cycle \
            --header="${mod}" \
            --bind='esc:abort'
        ) || continue

        case "$action" in
            cancel)    continue ;;
            install)   install_one "$mod" "$target" "$mode" "$source" ;;
            "install + enable")
                install_one "$mod" "$target" "$mode" "$source"
                local ec; ec=$(module_enable_cmd "$mod") && {
                    echo "Enabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${ec} 2>&1 || echo "(enable failed — see above)"
                    else
                        sudo -E ${ec} 2>&1 || echo "(enable failed — see above)"
                    fi
                } ;;
            enable)
                local ec; ec=$(module_enable_cmd "$mod") && {
                    echo "Enabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${ec} 2>&1 || echo "(enable failed — see above)"
                    else
                        sudo -E ${ec} 2>&1 || echo "(enable failed — see above)"
                    fi
                } ;;
            disable)
                local dc; dc=$(module_disable_cmd "$mod") && {
                    echo "Disabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${dc} 2>&1 || true
                    else
                        sudo -E ${dc} 2>&1 || true
                    fi
                } ;;
            update)
                install_one "$mod" "$target" "$mode" "$source" ;;
            reinstall)
                FORCE=1
                install_one "$mod" "$target" "$mode" "$source"
                FORCE=0 ;;
            uninstall)
                local dc; dc=$(module_disable_cmd "$mod") && {
                    echo "Disabling $mod..."
                    if echo " ${USER_SERVICE_MODULES} " | grep -q " ${mod} "; then
                        ${dc} 2>&1 || true
                    else
                        sudo -E ${dc} 2>&1 || true
                    fi
                }
                uninstall_one "$mod" "$target" "$mode" "$source" ;;
        esac
    done

    # Post-reconfigure: check if refresh-models needs auth onboarding
    local auth_marker="$STATE_DIR/refresh-models.needs-auth"
    if [[ -f "$auth_marker" ]]; then
        echo
        echo "refresh-models is installed but needs API keys. Launching auth..."
        rm -f "$auth_marker"
        refresh-models auth
    fi
}

while (($# > 0)); do
    case "$1" in
        --force) FORCE=1; shift ;;
        --batch) BATCH=1; shift ;;
        help|-h|--help) usage; exit 0 ;;
        *) break ;;
    esac
done

cmd="${1:-}"
shift || true

if [[ -z "$cmd" ]]; then
    if [[ -t 1 ]] && command -v fzf >/dev/null 2>&1; then
        cmd_reconfigure
    else
        cmd_update || true
    fi
    exit 0
fi

case "$cmd" in
    list) cmd_list "$@" ;;
    status) cmd_status "$@" ;;
    install) cmd_install "$@" ;;
    update) cmd_update "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    enable) cmd_enable "$@" ;;
    disable) cmd_disable "$@" ;;
    diff) cmd_diff "$@" ;;
    doctor) cmd_doctor ;;
    schedule) cmd_schedule "$@" ;;
    unschedule) cmd_unschedule "$@" ;;
    *) usage >&2; exit 1 ;;
esac
