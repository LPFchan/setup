#!/usr/bin/env bash
# setup-module: backup
# setup-source: bin/backup
#
# backup — unified backup to bingus NAS via NFS
#
# btrfs send over NFS mount to bingus. Zero local retention —
# the only copy lives on bingus.
#
# Commands:
#   enable              Install backup infrastructure
#   disable             Remove backup scripts, timers, NFS config
#   status              Show backup config, last/next run
#   trigger [daily|weekly]  Run backup now
#   restore [date]      Interactively pick or restore specific date
#   help                Show this message

set -euo pipefail

NAME="backup"
CONF_DIR="/etc/${NAME}"

# --- helpers ----------------------------------------------------------

die() { echo "error: $*" >&2; exit 1; }
warn() { echo "warn: $*" >&2; }
info() { echo "$*"; }

require_root() {
    [[ $EUID -eq 0 ]] || die "this command requires root — try sudo ${NAME} $*"
}

detect_fs() { stat -f -c '%T' "${1:-/}" 2>/dev/null || echo "unknown"; }
detect_host() { hostname -s; }

# --- paths config -----------------------------------------------------

write_paths_file() {
    local host="$1" file="${CONF_DIR}/paths.d/${1}"
    mkdir -p "${CONF_DIR}/paths.d"
    cat > "${file}" <<'PATHS'
# Each line is an rsync source path (with -aR preserving full path).
# Lines starting with # are ignored.
# Lines starting with - are rsync --exclude patterns.
# Strategy: blanket home + blacklist excludes (catches future projects automatically).
/home/yeowool/
- .cache/
- .rustup/
- .cargo/
- .npm/
- .local/
- .snap/
- .gnupg/
- .docker/
- .copilot/
- .landscape/
- .vscode-server/
- .terminfo/
- node_modules/
- .venv/
- __pycache__/
- *.log
- .git/
/etc/fstab
/etc/systemd/system/
/etc/sysctl.d/
/etc/default/earlyoom
/etc/cloudflared/
/etc/fail2ban/jail.d/
/etc/ssh/ssh_host_*
/etc/ssh/sshd_config.d/
/usr/local/bin/
/usr/local/sbin/
PATHS

    local home_dir sudo_user
    sudo_user="${SUDO_USER:-}"
    if [[ -n "$sudo_user" ]]; then
        home_dir=$(getent passwd "$sudo_user" | cut -d: -f6)
    fi
    [[ -n "$home_dir" ]] || home_dir=$(getent passwd 1000 | cut -d: -f6)
    [[ -n "$home_dir" ]] || die "cannot derive home directory — no SUDO_USER and no UID 1000 user"
    if [[ "$home_dir" != "/home/yeowool" ]]; then
        sed -i "s|/home/yeowool|${home_dir}|g" "$file"
    fi
}

# --- enable-time setup ------------------------------------------------

setup_nfs() {
    local host="$1"
    [[ "$(detect_fs /)" == "btrfs" ]] || die "requires btrfs root — this host has $(detect_fs /)"

    mkdir -p /mnt/bingus-backups
    grep -q 'mnt.bingus-backups' /etc/fstab || \
        echo 'bingus:/volume1/bak /mnt/bingus-backups nfs defaults,noatime,nofail 0 0' >> /etc/fstab
    mountpoint -q /mnt/bingus-backups || mount -t nfs bingus:/volume1/bak /mnt/bingus-backups || true
    mountpoint -q /mnt/bingus-backups || die "cannot mount bingus NFS — check Synology export for this host's IP"

    btrfs subvolume show /bak &>/dev/null || {
        mkdir -p /bak
        btrfs subvolume create /bak
    }
}

# --- script generation ------------------------------------------------

generate_daily_script() {
    local host="$1"

    {
        cat <<HEADER
#!/bin/bash
set -euo pipefail
exec 9>/var/lock/backup.lock || exit 1
trap 'rm -f /var/lock/backup.lock' EXIT

PATHS_FILE="/etc/backup/paths.d/${host}"
HEADER

        echo "DEST=\"/bak\""
        echo "REMOTE=\"/mnt/bingus-backups/${host}\""
        echo 'PATTERN="*-full.*"'
        echo 'RETENTION_DAYS="8"'

        cat <<'SETUP'
mountpoint -q /mnt/bingus-backups || exit 1

list_remote() { ls -1 "$REMOTE"/$1 2>/dev/null; }
delete_remote() { rm -f "$REMOTE/$(basename "$1")"; }
SETUP

        cat <<'ENGINE'
run_rsync() {
    local excludes=() sources=()
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        if [[ "$line" == -* ]]; then
            excludes+=("--exclude=${line#-}")
        else
            sources+=("$line")
        fi
    done < "$PATHS_FILE"
    local expanded
    for src in "${sources[@]}"; do
        expanded=$(eval echo "$src" 2>/dev/null) || true
        [ -n "$expanded" ] && rsync -aR --ignore-missing-args "${excludes[@]}" $expanded "$DEST"/ || true
    done
}
run_rsync

mkdir -p "$DEST/rebuild"
apt-mark showmanual > "$DEST/rebuild/apt-manual.txt"
npm ls -g --depth=0 --json > "$DEST/rebuild/npm-global.json" 2>/dev/null || true
fnm ls > "$DEST/rebuild/fnm-versions.txt" 2>/dev/null || true
pipx list --json > "$DEST/rebuild/pipx-list.json" 2>/dev/null || true
snap list > "$DEST/rebuild/snap-list.txt" 2>/dev/null || true
docker images --format '{{.Repository}}:{{.Tag}}' > "$DEST/rebuild/docker-images.txt" 2>/dev/null || true
ENGINE

        cat <<'SHIP'
SNAP="/bak-$(date +%Y%m%d)"
btrfs subvolume snapshot -r /bak "$SNAP"
btrfs send "$SNAP" > "$REMOTE/$(date +%Y%m%d)-full.bin"
btrfs subvolume delete "$SNAP"
SHIP

        cat <<'PRUNE'
CUTOFF=$(date -d "${RETENTION_DAYS} days ago" +%Y%m%d)
list_remote "$PATTERN" 2>/dev/null | while read -r f; do
    [ -z "$f" ] && continue
    f_date=$(basename "$f" | grep -oP '^\d{8}' || true)
    if [ -n "$f_date" ] && [ "$f_date" -lt "$CUTOFF" ]; then
        delete_remote "$f" 2>/dev/null || true
    fi
done || true
PRUNE
    } > /usr/local/bin/backup-daily

    chmod +x /usr/local/bin/backup-daily
    bash -n /usr/local/bin/backup-daily || { rm -f /usr/local/bin/backup-daily; die "syntax error in generated backup-daily"; }
}

generate_weekly() {
    cp /usr/local/bin/backup-daily /usr/local/bin/backup-weekly
    sed -i 's/backup.lock/weekly.lock/' /usr/local/bin/backup-weekly
    sed -i 's/RETENTION_DAYS="8"/RETENTION_DAYS="29"/' /usr/local/bin/backup-weekly
    sed -i 's/-full\./-weekly./' /usr/local/bin/backup-weekly
    chmod +x /usr/local/bin/backup-weekly
}

# --- systemd units ----------------------------------------------------

write_systemd_units() {
    local host="$1"

    for period in daily weekly; do
        cat > "/etc/systemd/system/backup-${period}.service" <<UNIT
[Unit]
Description=Backup ${period} to bingus (${host} via NFS)
After=remote-fs.target
Wants=remote-fs.target
[Service]
Type=oneshot
ExecStart=/usr/local/bin/backup-${period}
UNIT
    done

    cat > /etc/systemd/system/backup-daily.timer <<TIMER
[Timer]
OnCalendar=daily
Persistent=true
[Install]
WantedBy=timers.target
TIMER

    cat > /etc/systemd/system/backup-weekly.timer <<TIMER
[Timer]
OnCalendar=Sun 03:00
Persistent=true
[Install]
WantedBy=timers.target
TIMER

    systemctl daemon-reload
    systemctl enable --now backup-daily.timer backup-weekly.timer
}

# --- commands ---------------------------------------------------------

cmd_enable() {
    require_root
    local host
    host=$(detect_host)

    [[ "$(detect_fs /)" == "btrfs" ]] || die "requires btrfs root"
    timeout 3 bash -c 'echo > /dev/tcp/bingus/2049' 2>/dev/null || die "bingus NFS unreachable"

    info "host:       ${host}"
    info "filesystem: $(detect_fs /)"

    setup_nfs "$host"
    write_paths_file "$host"
    generate_daily_script "$host"
    generate_weekly
    write_systemd_units "$host"
    info "backup enabled (btrfs → NFS → bingus)"
}

cmd_disable() {
    require_root

    for unit in backup-daily backup-weekly; do
        systemctl disable --now "${unit}.timer" 2>/dev/null || true
        systemctl disable --now "${unit}.service" 2>/dev/null || true
        rm -f "/etc/systemd/system/${unit}.timer" "/etc/systemd/system/${unit}.service"
    done
    systemctl daemon-reload
    rm -f /usr/local/bin/backup-daily /usr/local/bin/backup-weekly

    umount /mnt/bingus-backups 2>/dev/null || true
    sed -i '\|mnt.bingus-backups|d' /etc/fstab
    info "backup disabled"
}

cmd_status() {
    echo "host:       $(detect_host)"
    echo "filesystem: $(detect_fs /)"
    echo "nfs mount:  $(mountpoint -q /mnt/bingus-backups 2>/dev/null && echo mounted || echo not-mounted)"
    echo
    for unit in backup-daily backup-weekly; do
        local state next
        state=$(systemctl is-active "${unit}.timer" 2>/dev/null || echo "not-installed")
        if [[ "$state" != "not-installed" ]]; then
            next=$(systemctl show -p NextElapseUSecRealtime "${unit}.timer" 2>/dev/null | cut -d= -f2- | xargs || echo "?")
            echo "  ${unit}.timer: ${state} (next: ${next})"
        fi
    done
}

cmd_trigger() {
    require_root
    local period="${1:-daily}"
    local script="/usr/local/bin/backup-${period}"
    [[ -x "$script" ]] || die "no backup script for '${period}'"
    "$script"
    info "${period} backup completed"
}

cmd_restore() {
    local host
    host=$(detect_host)
    local files=""
    local recover="/tmp/recovery"
    local date_arg="${1:-}"

    # NFS probe
    if mountpoint -q /mnt/bingus-backups 2>/dev/null; then
        files=$(ls -1 /mnt/bingus-backups/"${host}"/[0-9]*-full.bin /mnt/bingus-backups/"${host}"/[0-9]*-weekly.bin 2>/dev/null) || files=""
    else
        if timeout 3 bash -c 'echo > /dev/tcp/bingus/2049' 2>/dev/null; then
            mkdir -p /mnt/bingus-backups
            timeout 10 mount -t nfs bingus:/volume1/bak /mnt/bingus-backups 2>/dev/null && {
                files=$(ls -1 /mnt/bingus-backups/"${host}"/[0-9]*-full.bin /mnt/bingus-backups/"${host}"/[0-9]*-weekly.bin 2>/dev/null) || files=""
            }
        fi
    fi

    [[ -n "$files" ]] || die "no backups found for ${host} on bingus NFS"

    if [[ "$(detect_fs /)" != "btrfs" ]]; then
        warn "NFS artifacts present but unrestorable on $(detect_fs /) (requires btrfs)"
        echo "$files" | sed 's|.*/||' | sort -r | tail -5
        return 1
    fi

    if [[ -z "$date_arg" ]]; then
        if command -v fzf >/dev/null && [[ -t 1 ]]; then
            date_arg=$(
                echo "$files" | sed 's|.*/||' | sort -r | \
                fzf --header="Select backup to restore (Enter=restore, Esc=cancel)"
            ) || { info "cancelled"; return 0; }
        else
            echo "$files" | sed 's|.*/||' | sort -r | tail -5
            echo "Run 'backup restore YYYYMMDD-full.bin' for a specific file"
            return 0
        fi
    fi

    local src="/mnt/bingus-backups/${host}/${date_arg}"
    [[ -f "$src" ]] || die "no NFS artifact: ${date_arg}"
    mkdir -p "${recover}/${date_arg%.bin}"
    cat "$src" | btrfs receive "${recover}/${date_arg%.bin}"
    info "Restored to ${recover}/${date_arg%.bin}"
}

# --- main -------------------------------------------------------------

cmd="${1:-help}"; [[ $# -gt 0 ]] && shift

case "$cmd" in
    enable)  cmd_enable ;;
    disable) cmd_disable ;;
    status)  cmd_status ;;
    trigger) cmd_trigger "${1:-daily}" ;;
    restore) cmd_restore "$@" ;;
    help|--help|-h)
        cat <<HELP
Usage: ${NAME} <command> [args]

Commands:
  enable              Install backup infrastructure
  disable             Remove backup scripts and timers
  status              Show backup config and schedule
  trigger [daily|weekly]  Run backup now
  restore [date]      Interactively pick or restore specific date
  help                Show this message
HELP
        ;;
    *) die "unknown command. Try '${NAME} help'." ;;
esac
