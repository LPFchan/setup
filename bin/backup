#!/usr/bin/env bash
# setup-module: backup
# setup-source: bin/backup
#
# backup — unified backup to bingus NAS
#
# Transport-driven dispatch: NFS (btrfs+LAN) or rsyncd (tar+Tailscale).
# Zero local retention — the only copy lives on bingus.
#
# Commands:
#   enable              Detect and install backup infrastructure
#   disable             Remove backup scripts, timers, transport config
#   status              Show backup config, last/next run
#   trigger [daily|weekly]  Run backup now
#   restore [date]      Interactively pick or restore specific date
#   help                Show this message

set -euo pipefail

NAME="backup"
CONF_DIR="/etc/${NAME}"

# --- helpers ----------------------------------------------------------

die() { echo "error: $*" >&2; exit 1; }
warn() { echo "warn: $*" >&2; }
info() { echo "$*"; }

require_root() {
    [[ $EUID -eq 0 ]] || die "this command requires root — try sudo ${NAME} $*"
}

detect_fs() { stat -f -c '%T' "${1:-/}" 2>/dev/null || echo "unknown"; }
detect_host() { hostname -s; }

detect_transport() {
    local fs lan_ip
    fs=$(detect_fs /)
    lan_ip=$(timeout 3 getent ahosts bingus 2>/dev/null | awk '/^[0-9]+\./ {print $1; exit}')
    if [[ -n "$lan_ip" && "$lan_ip" =~ ^(10\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.) ]]; then
        if [[ "$fs" == "btrfs" ]] && timeout 3 bash -c "echo > /dev/tcp/${lan_ip}/2049" 2>/dev/null; then
            echo "nfs"
        elif timeout 3 bash -c 'echo > /dev/tcp/bingus.lost.plus/873' 2>/dev/null; then
            echo "rsyncd"
        else
            echo "unreachable"
        fi
    elif timeout 3 bash -c 'echo > /dev/tcp/bingus.lost.plus/873' 2>/dev/null; then
        echo "rsyncd"
    else
        echo "unreachable"
    fi
}

# --- paths config -----------------------------------------------------

write_paths_file() {
    local host="$1" file="${CONF_DIR}/paths.d/${1}"
    mkdir -p "${CONF_DIR}/paths.d"
    cat > "${file}" <<'PATHS'
# Each line is an rsync source path (with -aR preserving full path).
# Lines starting with # are ignored.
# Lines starting with - are rsync --exclude patterns.
# Strategy: blanket home + blacklist excludes (catches future projects automatically).
/home/yeowool/
- .cache/
- .rustup/
- .cargo/
- .npm/
- .local/
- .snap/
- .gnupg/
- .docker/
- .copilot/
- .landscape/
- .vscode-server/
- .terminfo/
- node_modules/
- .venv/
- __pycache__/
- *.log
- .git/
/etc/fstab
/etc/systemd/system/
/etc/sysctl.d/
/etc/default/earlyoom
/etc/cloudflared/
/etc/samba/smb.conf
/etc/fail2ban/jail.d/
/etc/ssh/ssh_host_*
/etc/ssh/sshd_config.d/
/usr/local/bin/
/usr/local/sbin/
PATHS

    local home_dir
    home_dir=$(getent passwd 1000 | cut -d: -f6)
    [[ -n "$home_dir" ]] || die "no UID 1000 user found — cannot derive home directory"
    if [[ "$home_dir" != "/home/yeowool" ]]; then
        sed -i "s|/home/yeowool|${home_dir}|g" "$file"
    fi
}

# --- enable-time setup ------------------------------------------------

setup_transport_nfs() {
    local host="$1"
    [[ "$(detect_fs /)" == "btrfs" ]] || die "NFS transport requires btrfs root — this host has $(detect_fs /)"

    mkdir -p /mnt/bingus-backups
    grep -q 'mnt.bingus-backups' /etc/fstab || \
        echo 'bingus:/volume1/bak /mnt/bingus-backups nfs defaults,noatime,nofail 0 0' >> /etc/fstab
    mountpoint -q /mnt/bingus-backups || mount -t nfs bingus:/volume1/bak /mnt/bingus-backups || true
    mountpoint -q /mnt/bingus-backups || die "cannot mount bingus NFS — check Synology export for this host's IP"

    btrfs subvolume show /bak &>/dev/null || {
        mkdir -p /bak
        btrfs subvolume create /bak
    }
}

setup_transport_rsyncd() {
    local host="$1"
    local staging_root="/var/cache/backup-${host}"

    if [[ -e /mnt/block && ! -e "$staging_root" ]]; then
        ln -s /mnt/block/backups "$staging_root"
    fi

    if [[ "$(df --output=avail /var/cache 2>/dev/null | tail -1)" -lt 52428800 ]] 2>/dev/null; then
        warn "/var/cache is low on space (<50GB) — consider symlinking ${staging_root} to a larger volume"
    fi

    mkdir -p "${staging_root}/staging"

    [[ -f /etc/rsync.secrets ]] || {
        cat <<INS
rsyncd password required.

Get it from vaultwarden:
  folder: llm
  item:   ${host} bingus rsync password

Store it:
  echo '<password>' | sudo tee /etc/rsync.secrets
  sudo chmod 600 /etc/rsync.secrets

Then re-run: sudo backup enable
INS
        exit 1
    }

    systemctl list-unit-files tailscaled.service &>/dev/null || \
        die "rsyncd transport requires Tailscale — install and start tailscaled"
}

# --- adapter functions (emit sections to stdout) -----------------------

adapter_header_nfs() {
    local host="$1"
    echo "DEST=\"/bak\""
    echo "REMOTE=\"/mnt/bingus-backups/${host}\""
}

adapter_setup_nfs() {
    cat <<'SETUP'
mountpoint -q /mnt/bingus-backups || exit 1

list_remote() { ls -1 "$REMOTE"/$1 2>/dev/null; }
delete_remote() { rm -f "$REMOTE/$(basename "$1")"; }
SETUP
}

adapter_ship_nfs() {
    cat <<'SHIP'
SNAP="/bak-$(date +%Y%m%d)"
btrfs subvolume snapshot -r /bak "$SNAP"
btrfs send "$SNAP" > "$REMOTE/$(date +%Y%m%d)-full.bin"
btrfs subvolume delete "$SNAP"
SHIP
}

adapter_header_rsyncd() {
    local host="$1"
    echo "DEST=\"/var/cache/backup-${host}/staging\""
    echo "REMOTE=\"rsync://${host}@bingus.lost.plus/bak/${host}\""
    echo "RSYNC_RSH=\"--password-file=/etc/rsync.secrets\""
}

adapter_setup_rsyncd() {
    cat <<'SETUP'
rm -rf "$DEST" && mkdir -p "$DEST"

list_remote() { rsync --list-only ${RSYNC_RSH} "$REMOTE"/$1 2>/dev/null | awk '{print $NF}' | grep -v '^\.'; }
delete_remote() {
    local empty=$(mktemp -d)
    rsync -r --delete --include="$(basename "$1")" --exclude='*' ${RSYNC_RSH} "$empty/" "$REMOTE/"
    rmdir "$empty"
}
SETUP
}

adapter_ship_rsyncd() {
    local host="$1"
    cat <<SHIP
TARBALL="/var/cache/backup-${host}/\$(date +%Y%m%d)-full.tar.gz"
tar -czf "\$TARBALL" -C "\$DEST" .
rsync -a \${RSYNC_RSH} "\$TARBALL" "\$REMOTE/"
rm -f "\$TARBALL"
SHIP
}

# --- script generation ------------------------------------------------

generate_daily_script() {
    local transport="$1" host="$2"

    {
        cat <<HEADER
#!/bin/bash
set -euo pipefail
exec 9>/var/lock/backup.lock || exit 1
trap 'rm -f /var/lock/backup.lock' EXIT

PATHS_FILE="/etc/backup/paths.d/${host}"
HEADER
        "adapter_header_${transport}" "$host"
        echo 'PATTERN="*-full.*"'
        echo 'RETENTION_DAYS="8"'

        "adapter_setup_${transport}" "$host"

        cat <<'ENGINE'
run_rsync() {
    local excludes=() sources=()
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue
        if [[ "$line" == -* ]]; then
            excludes+=("--exclude=${line#-}")
        else
            sources+=("$line")
        fi
    done < "$PATHS_FILE"
    local expanded
    for src in "${sources[@]}"; do
        expanded=$(eval echo "$src" 2>/dev/null) || true
        [ -n "$expanded" ] && rsync -aR "${excludes[@]}" $expanded "$DEST"/
    done
}
run_rsync

mkdir -p "$DEST/rebuild"
apt-mark showmanual > "$DEST/rebuild/apt-manual.txt"
npm ls -g --depth=0 --json > "$DEST/rebuild/npm-global.json" 2>/dev/null || true
fnm ls > "$DEST/rebuild/fnm-versions.txt" 2>/dev/null || true
pipx list --json > "$DEST/rebuild/pipx-list.json" 2>/dev/null || true
snap list > "$DEST/rebuild/snap-list.txt" 2>/dev/null || true
docker images --format '{{.Repository}}:{{.Tag}}' > "$DEST/rebuild/docker-images.txt" 2>/dev/null || true
ENGINE

        "adapter_ship_${transport}" "$host"

        cat <<'PRUNE'
CUTOFF=$(date -d "${RETENTION_DAYS} days ago" +%Y%m%d)
list_remote "$PATTERN" 2>/dev/null | while read -r f; do
    [ -z "$f" ] && continue
    f_date=$(basename "$f" | grep -oP '^\d{8}' || true)
    if [ -n "$f_date" ] && [ "$f_date" -lt "$CUTOFF" ]; then
        delete_remote "$f" 2>/dev/null || true
    fi
done || true
PRUNE
    } > /usr/local/bin/backup-daily

    chmod +x /usr/local/bin/backup-daily
    bash -n /usr/local/bin/backup-daily || { rm -f /usr/local/bin/backup-daily; die "syntax error in generated backup-daily"; }
}

generate_weekly() {
    cp /usr/local/bin/backup-daily /usr/local/bin/backup-weekly
    sed -i 's/backup.lock/weekly.lock/' /usr/local/bin/backup-weekly
    sed -i 's/RETENTION_DAYS="8"/RETENTION_DAYS="29"/' /usr/local/bin/backup-weekly
    sed -i 's/-full\./-weekly./' /usr/local/bin/backup-weekly
    chmod +x /usr/local/bin/backup-weekly
}

# --- systemd units ----------------------------------------------------

write_systemd_units() {
    local host="$1" transport="$2"

    for period in daily weekly; do
        cat > "/etc/systemd/system/backup-${period}.service" <<UNIT
[Unit]
Description=Backup ${period} to bingus (${host} via ${transport})
$( [[ "${transport}" == "rsyncd" ]] && echo "After=tailscaled.service" && echo "Requires=tailscaled.service" )
[Service]
Type=oneshot
ExecStart=/usr/local/bin/backup-${period}
UNIT
    done

    cat > /etc/systemd/system/backup-daily.timer <<TIMER
[Timer]
OnCalendar=daily
Persistent=true
[Install]
WantedBy=timers.target
TIMER

    cat > /etc/systemd/system/backup-weekly.timer <<TIMER
[Timer]
OnCalendar=Sun 03:00
Persistent=true
[Install]
WantedBy=timers.target
TIMER

    systemctl daemon-reload
    systemctl enable --now backup-daily.timer backup-weekly.timer
}

# --- commands ---------------------------------------------------------

cmd_enable() {
    require_root
    local host transport
    host=$(detect_host)
    transport=$(detect_transport)

    info "host:       ${host}"
    info "filesystem: $(detect_fs /)"
    info "transport:  ${transport}"

    case "$transport" in
        nfs)
            setup_transport_nfs "$host"
            write_paths_file "$host"
            generate_daily_script nfs "$host"
            generate_weekly
            write_systemd_units "$host" nfs
            info "backup enabled (btrfs → NFS → bingus)"
            ;;
        rsyncd)
            setup_transport_rsyncd "$host"
            write_paths_file "$host"
            generate_daily_script rsyncd "$host"
            generate_weekly
            write_systemd_units "$host" rsyncd
            info "backup enabled (tar → rsyncd → bingus)"
            ;;
        *)
            die "bingus unreachable"
            ;;
    esac
}

cmd_disable() {
    require_root
    local transport
    transport=$(detect_transport)

    for unit in backup-daily backup-weekly; do
        systemctl disable --now "${unit}.timer" 2>/dev/null || true
        systemctl disable --now "${unit}.service" 2>/dev/null || true
        rm -f "/etc/systemd/system/${unit}.timer" "/etc/systemd/system/${unit}.service"
    done
    systemctl daemon-reload
    rm -f /usr/local/bin/backup-daily /usr/local/bin/backup-weekly

    if [[ "$transport" == "nfs" || "$transport" == "unreachable" ]]; then
        umount /mnt/bingus-backups 2>/dev/null || true
        sed -i '\|mnt.bingus-backups|d' /etc/fstab
    fi
    if [[ "$transport" == "rsyncd" || "$transport" == "unreachable" ]]; then
        rm -f /etc/rsync.secrets
    fi
    info "backup disabled"
}

cmd_status() {
    echo "host:       $(detect_host)"
    echo "filesystem: $(detect_fs /)"
    echo "transport:  $(detect_transport)"
    echo
    for unit in backup-daily backup-weekly; do
        local state next
        state=$(systemctl is-active "${unit}.timer" 2>/dev/null || echo "not-installed")
        if [[ "$state" != "not-installed" ]]; then
            next=$(systemctl show -p NextElapseUSecRealtime "${unit}.timer" 2>/dev/null | cut -d= -f2- | xargs || echo "?")
            echo "  ${unit}.timer: ${state} (next: ${next})"
        fi
    done
}

cmd_trigger() {
    require_root
    local period="${1:-daily}"
    local script="/usr/local/bin/backup-${period}"
    [[ -x "$script" ]] || die "no backup script for '${period}'"
    "$script"
    info "${period} backup completed"
}

cmd_restore() {
    local host transport
    host=$(detect_host)
    transport=$(detect_transport)
    local nfs_avail=0 rsyncd_avail=0
    local nfs_files="" rsyncd_files=""
    local recover="/tmp/recovery"
    local date_arg="${1:-}"

    # NFS probe
    if mountpoint -q /mnt/bingus-backups 2>/dev/null; then
        nfs_files=$(ls -1 /mnt/bingus-backups/"${host}"/[0-9]*-full.bin /mnt/bingus-backups/"${host}"/[0-9]*-weekly.bin 2>/dev/null) || nfs_files=""
    else
        if timeout 3 bash -c 'echo > /dev/tcp/bingus/2049' 2>/dev/null; then
            mkdir -p /mnt/bingus-backups
            timeout 10 mount -t nfs bingus:/volume1/bak /mnt/bingus-backups 2>/dev/null && {
                nfs_files=$(ls -1 /mnt/bingus-backups/"${host}"/[0-9]*-full.bin /mnt/bingus-backups/"${host}"/[0-9]*-weekly.bin 2>/dev/null) || nfs_files=""
            }
        fi
    fi
    if [[ -n "$nfs_files" ]]; then
        if [[ "$(detect_fs /)" == "btrfs" ]]; then
            nfs_avail=1
        else
            warn "NFS artifacts present but unrestorable on $(detect_fs /) (requires btrfs)"
        fi
    fi

    # rsyncd probe
    local rsh=""
    [[ -f /etc/rsync.secrets ]] && rsh="--password-file=/etc/rsync.secrets"
    if [[ -z "$rsh" ]]; then
        warn "rsyncd unavailable — credentials missing (re-store from vaultwarden)"
    else
        rsyncd_files=$(rsync --list-only $rsh "rsync://${host}@bingus.lost.plus/bak/${host}/" 2>/dev/null \
            | awk '{print $NF}' | grep -E '^\d{8}-(full|weekly)\.' ) || rsyncd_files=""
        [[ -n "$rsyncd_files" ]] && rsyncd_avail=1
    fi

    [[ $nfs_avail -eq 0 && $rsyncd_avail -eq 0 ]] && die "no restorable backups found for ${host} on bingus"

    # Build merged list
    local all_files=""
    if [[ $nfs_avail -eq 1 ]]; then
        all_files+=$(echo "$nfs_files" | sed 's|.*/||' | sed 's/^/[nfs] /')$'\n'
    fi
    if [[ $rsyncd_avail -eq 1 ]]; then
        all_files+=$(echo "$rsyncd_files" | sed 's/^/[tar] /')$'\n'
    fi

    if [[ -z "$date_arg" ]]; then
        if command -v fzf >/dev/null && [[ -t 1 ]]; then
            date_arg=$(
                echo "$all_files" | grep -v '^$' | sort -r | \
                fzf --header="Select backup to restore (Enter=restore, Esc=cancel)"
            ) || { info "cancelled"; return 0; }
            date_arg=$(echo "$date_arg" | sed 's/^\[[a-z]*\] //')
        else
            echo "$all_files" | grep -v '^$' | sort -r | tail -5
            echo "Run 'backup restore YYYYMMDD-full.bin' for a specific file"
            return 0
        fi
    fi

    # Dispatch by artifact type
    local src=""
    if [[ "$date_arg" == *.bin ]]; then
        # NFS artifact (btrfs receive)
        src="/mnt/bingus-backups/${host}/${date_arg}"
        [[ -f "$src" ]] || die "no NFS artifact: ${date_arg}"
        mkdir -p "${recover}/${date_arg%.bin}"
        cat "$src" | btrfs receive "${recover}/${date_arg%.bin}"
        info "Restored to ${recover}/${date_arg%.bin}"
    elif [[ "$date_arg" == *.tar.gz ]]; then
        # rsyncd artifact (tar extract)
        [[ -n "$rsh" ]] || die "rsyncd credentials missing"
        local tar
        tar=$(mktemp)
        rsync -a $rsh "rsync://${host}@bingus.lost.plus/bak/${host}/${date_arg}" "$tar" 2>/dev/null || {
            rm -f "$tar"; die "cannot fetch ${date_arg}"; }
        mkdir -p "${recover}/${date_arg%.tar.gz}"
        tar -xzf "$tar" -C "${recover}/${date_arg%.tar.gz}"
        rm -f "$tar"
        info "Restored to ${recover}/${date_arg%.tar.gz}"
    else
        die "unrecognized artifact format: ${date_arg}"
    fi
}

# --- main -------------------------------------------------------------

cmd="${1:-help}"; [[ $# -gt 0 ]] && shift

case "$cmd" in
    enable)  cmd_enable ;;
    disable) cmd_disable ;;
    status)  cmd_status ;;
    trigger) cmd_trigger "${1:-daily}" ;;
    restore) cmd_restore "$@" ;;
    help|--help|-h)
        cat <<HELP
Usage: ${NAME} <command> [args]

Commands:
  enable              Detect and install backup infrastructure
  disable             Remove backup scripts and timers
  status              Show backup config and schedule
  trigger [daily|weekly]  Run backup now
  restore [date]      Interactively pick or restore specific date
  help                Show this message
HELP
        ;;
    *) die "unknown command. Try '${NAME} help'." ;;
esac