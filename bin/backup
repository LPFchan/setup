#!/usr/bin/env bash
# setup-module: backup
# setup-source: bin/backup
#
# Incremental backups to bingus over SFTP using Restic.

set -euo pipefail

NAME="backup"
CONF_DIR="${BACKUP_CONF_DIR:-/etc/backup}"
STATE_DIR="${BACKUP_STATE_DIR:-/var/lib/backup}"
CACHE_DIR="${BACKUP_CACHE_DIR:-/var/cache/backup}"
SYSTEMD_DIR="${BACKUP_SYSTEMD_DIR:-/etc/systemd/system}"
LOCK_FILE="${BACKUP_LOCK_FILE:-/run/lock/backup.lock}"
RECOVERY_DIR="${BACKUP_RECOVERY_DIR:-/var/tmp/backup-recovery}"

die() { echo "error: $*" >&2; exit 1; }
warn() { echo "warn: $*" >&2; }
info() { echo "$*"; }

require_root() {
    [[ $EUID -eq 0 || "${BACKUP_TEST_MODE:-0}" == 1 ]] || \
        die "this command requires root — try sudo ${NAME} $*"
}

detect_host() { hostname -s; }

operator_identity() {
    local user home
    user="${SUDO_USER:-}"
    [[ -n "$user" && "$user" != root ]] || user=$(getent passwd 1000 | cut -d: -f1)
    [[ -n "$user" ]] || die "cannot determine the primary user"
    home=$(getent passwd "$user" | cut -d: -f6)
    [[ -n "$home" ]] || die "cannot determine home directory for ${user}"
    printf '%s\t%s\n' "$user" "$home"
}

write_if_missing() {
    local path="$1" mode="$2"
    shift 2
    [[ -e "$path" ]] && return 0
    install -m "$mode" /dev/null "$path"
    printf '%s\n' "$@" > "$path"
}

write_default_policy() {
    local host="$1" user="$2" home="$3" default_repository legacy_repository tmp
    default_repository="sftp:${user}@bingus.lost.plus:/bak/${host}-restic"
    legacy_repository="sftp:${user}@bingus.lost.plus:/volume1/bak/${host}-restic"
    mkdir -p "$CONF_DIR" "$STATE_DIR/provenance"
    chmod 755 "$CONF_DIR"
    chmod 700 "$STATE_DIR"

    write_if_missing "$CONF_DIR/config" 644 \
        "RESTIC_REPOSITORY=${default_repository}" \
        "BACKUP_USER=${user}" \
        "SFTP_IDENTITY=${home}/.ssh/id_ed25519" \
        "SFTP_KNOWN_HOSTS=${home}/.ssh/known_hosts" \
        "MAX_FILE_SIZE=20M" \
        "UPLOAD_LIMIT_KIB=30720" \
        "KEEP_DAILY=7" \
        "KEEP_WEEKLY=5" \
        "KEEP_MONTHLY=12" \
        "KEEP_YEARLY=3"
    if grep -Fqx "RESTIC_REPOSITORY=${legacy_repository}" "$CONF_DIR/config"; then
        tmp=$(mktemp)
        awk -v old="RESTIC_REPOSITORY=${legacy_repository}" \
            -v new="RESTIC_REPOSITORY=${default_repository}" \
            '{ if ($0 == old) $0 = new; print }' "$CONF_DIR/config" > "$tmp"
        install -m 0644 "$tmp" "$CONF_DIR/config"
        rm -f "$tmp"
    fi

    write_if_missing "$CONF_DIR/sources" 644 \
        "# Paths backed up automatically, subject to excludes and MAX_FILE_SIZE." \
        "$home" \
        "/etc" \
        "/usr/local/bin" \
        "/usr/local/sbin" \
        "$STATE_DIR/provenance"

    write_if_missing "$CONF_DIR/excludes" 644 \
        "# Restic exclude patterns for reproducible or disposable data." \
        "**/.cache/**" \
        "**/node_modules/**" \
        "**/.venv/**" \
        "**/__pycache__/**" \
        "**/.npm/_cacache/**" \
        "**/.cargo/registry/**" \
        "**/.cargo/git/**" \
        "**/.rustup/toolchains/**" \
        "**/target/debug/**" \
        "**/target/release/**"

    write_if_missing "$CONF_DIR/large-whitelist" 644 \
        "# Exact large files or directories that must be backed up despite the limit." \
        "# One absolute path per line. These entries override both size and blacklist rules." \
        "$home/Eastself"
}

load_config() {
    [[ -r "$CONF_DIR/config" ]] || die "missing ${CONF_DIR}/config — run 'backup enable'"
    # This root-owned file contains only shell assignments and is intentionally sourceable.
    # shellcheck disable=SC1090
    source "$CONF_DIR/config"
    : "${RESTIC_REPOSITORY:?missing RESTIC_REPOSITORY}"
    : "${BACKUP_USER:?missing BACKUP_USER}"
    : "${SFTP_IDENTITY:?missing SFTP_IDENTITY}"
    : "${SFTP_KNOWN_HOSTS:?missing SFTP_KNOWN_HOSTS}"
    : "${MAX_FILE_SIZE:=20M}"
    : "${UPLOAD_LIMIT_KIB:=30720}"
    : "${KEEP_DAILY:=7}"
    : "${KEEP_WEEKLY:=5}"
    : "${KEEP_MONTHLY:=12}"
    : "${KEEP_YEARLY:=3}"
    [[ -r "$SFTP_IDENTITY" ]] || die "missing SFTP identity: ${SFTP_IDENTITY}"
    [[ -r "$SFTP_KNOWN_HOSTS" ]] || die "missing SSH known_hosts: ${SFTP_KNOWN_HOSTS}"
    BACKUP_HOME=$(getent passwd "$BACKUP_USER" | cut -d: -f6)
    [[ -n "$BACKUP_HOME" ]] || die "cannot determine home directory for ${BACKUP_USER}"
}

restic_cmd() {
    local sftp_args identity_q known_hosts_q
    if [[ $EUID -eq 0 ]]; then
        install -d -o root -g root -m 0700 "$CACHE_DIR"
    else
        mkdir -p "$CACHE_DIR"
        chmod 700 "$CACHE_DIR"
    fi
    printf -v identity_q '%q' "$SFTP_IDENTITY"
    printf -v known_hosts_q '%q' "$SFTP_KNOWN_HOSTS"
    sftp_args="-i ${identity_q} -o IdentitiesOnly=yes -o BatchMode=yes -o StrictHostKeyChecking=yes -o UserKnownHostsFile=${known_hosts_q} -o ServerAliveInterval=30 -o ServerAliveCountMax=4"
    (
        unset RESTIC_PASSWORD RESTIC_PASSWORD_FILE RESTIC_PASSWORD_COMMAND
        export RESTIC_REPOSITORY
        restic --insecure-no-password -o "sftp.args=${sftp_args}" \
            --cache-dir "$CACHE_DIR" --limit-upload "$UPLOAD_LIMIT_KIB" "$@"
    )
}

operator_path() {
    local path latest_nvm=""
    path="$BACKUP_HOME/.local/bin:$BACKUP_HOME/.cargo/bin:$BACKUP_HOME/.bun/bin"
    path+=":$BACKUP_HOME/.local/share/fnm/aliases/default/bin"
    if [[ -d "$BACKUP_HOME/.nvm/versions/node" ]]; then
        latest_nvm=$(find "$BACKUP_HOME/.nvm/versions/node" -mindepth 1 -maxdepth 1 \
            -type d -printf '%f\t%p/bin\n' 2>/dev/null | sort -V | tail -n 1 | cut -f2-)
        [[ -z "$latest_nvm" ]] || path+=":$latest_nvm"
    fi
    printf '%s:%s\n' "$path" '/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin'
}

operator_tool() {
    PATH="$(operator_path)" command -v "$1" 2>/dev/null
}

run_as_operator() {
    if [[ $EUID -eq 0 && "$BACKUP_USER" != root ]]; then
        runuser -u "$BACKUP_USER" -- env HOME="$BACKUP_HOME" PATH="$(operator_path)" "$@"
    else
        HOME="$BACKUP_HOME" PATH="$(operator_path)" "$@"
    fi
}

read_path_list() {
    local file="$1"
    [[ -r "$file" ]] || return 0
    sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' \
        -e '/^$/d' -e '/^#/d' "$file"
}

provenance_id() {
    printf '%s' "$1" | sha256sum | cut -c1-16
}

single_line() {
    tr '\t\r\n' '   ' | sed -e 's/[[:space:]]*$//'
}

discover_environments() {
    local root="$1" output="$2"
    find "$root" -xdev \
        \( -type d \( -name .cache -o -name .npm -o -name .bun -o -name .cargo \
        -o -name .rustup -o -name .nvm -o -name __pycache__ \) -prune \) -o \
        \( -type d -name .venv -printf 'python\t%p\0' -prune \) -o \
        \( -type d -name node_modules -printf 'node\t%p\0' -prune \) -o \
        \( -type d -name target -prune \) -o \
        \( -type d -name .git -printf 'git\t%p\0' -prune \) -o \
        \( -type f -name .git -printf 'git\t%p\0' \) -o \
        \( -type f -name Cargo.toml -printf 'rust\t%p\0' \) \
        2>/dev/null > "$output"
}

collect_python_provenance() {
    local out="$1" health="$2" discovery="$3" kind venv python id version manifest status detail
    local env_dir="$out/environments/python"
    mkdir -p "$env_dir"
    find "$env_dir" -type f -delete
    printf 'path\tpython\tpackages\tstatus\n' > "$out/python-environments.tsv"

    while IFS=$'\t' read -r -d '' kind venv; do
        [[ "$kind" == python ]] || continue
        python="$venv/bin/python"
        id=$(provenance_id "$venv")
        manifest="environments/python/${id}-pip-freeze.txt"
        version=unavailable
        status=unknown
        detail="missing runnable Python environment"
        if [[ -x "$python" ]]; then
            version=$(run_as_operator "$python" --version 2>&1 | single_line || true)
            if run_as_operator "$python" -m pip freeze --all > "$out/$manifest" 2>/dev/null; then
                status=exact
                detail="installed package versions captured"
            else
                rm -f "$out/$manifest"
                manifest=""
                detail="pip package inventory unavailable"
            fi
        fi
        printf '%s\t%s\t%s\t%s\n' "$venv" "$version" "$manifest" "$status" \
            >> "$out/python-environments.tsv"
        printf 'python\t%s\t%s\t%s\n' "$venv" "$status" "$detail" >> "$health"
    done < "$discovery"
}

collect_node_provenance() {
    local root="$1" out="$2" health="$3" discovery="$4"
    local kind modules project lock candidate tool npm_tool bun_tool pnpm_tool id manifest status detail
    local env_dir="$out/environments/node"
    local -a locks=(package-lock.json npm-shrinkwrap.json pnpm-lock.yaml yarn.lock bun.lock bun.lockb)
    mkdir -p "$env_dir"
    find "$env_dir" -type f -delete
    printf 'project\tlockfile\tinstalled_tree\tstatus\n' > "$out/node-environments.tsv"
    {
        printf 'tool\tversion\n'
        for candidate in node npm bun pnpm yarn; do
            tool=$(operator_tool "$candidate" || true)
            [[ -n "$tool" ]] || continue
            printf '%s\t%s\n' "$candidate" \
                "$(run_as_operator "$tool" --version 2>/dev/null | single_line || true)"
        done
    } > "$out/javascript-toolchains.tsv"
    {
        printf 'manager\tversion\tpath\n'
        if [[ -d "$root/.nvm/versions/node" ]]; then
            find "$root/.nvm/versions/node" -mindepth 1 -maxdepth 1 -type d \
                -printf 'nvm\t%f\t%p\n' 2>/dev/null
        fi
        if [[ -d "$root/.local/share/fnm/node-versions" ]]; then
            find "$root/.local/share/fnm/node-versions" -mindepth 1 -maxdepth 1 -type d \
                -printf 'fnm\t%f\t%p\n' 2>/dev/null
        fi
    } > "$out/javascript-runtimes.tsv"
    npm_tool=$(operator_tool npm || true)
    bun_tool=$(operator_tool bun || true)
    pnpm_tool=$(operator_tool pnpm || true)
    [[ -z "$npm_tool" ]] || run_as_operator "$npm_tool" ls -g --depth=0 --json \
        > "$out/npm-global.json" 2>/dev/null || true
    [[ -z "$bun_tool" ]] || run_as_operator "$bun_tool" pm ls -g \
        > "$out/bun-global.txt" 2>/dev/null || true
    [[ -z "$pnpm_tool" ]] || run_as_operator "$pnpm_tool" ls -g --depth=0 --json \
        > "$out/pnpm-global.json" 2>/dev/null || true

    while IFS=$'\t' read -r -d '' kind modules; do
        [[ "$kind" == node ]] || continue
        project=${modules%/node_modules}
        lock=""
        manifest=""
        status=unknown
        detail="no project manifest"
        for candidate in "${locks[@]}"; do
            if [[ -f "$project/$candidate" ]]; then
                lock="$project/$candidate"
                status=exact
                detail="lockfile preserved"
                break
            fi
        done
        if [[ -z "$lock" && -f "$project/package.json" && -n "$npm_tool" ]]; then
            id=$(provenance_id "$project")
            manifest="environments/node/${id}-installed-tree.json"
            run_as_operator "$npm_tool" ls --all --json --prefix "$project" \
                > "$out/$manifest" 2>/dev/null || true
            if [[ -s "$out/$manifest" ]]; then
                status=partial
                detail="installed versions captured without a lockfile"
            else
                rm -f "$out/$manifest"
                manifest=""
                detail="dependency inventory unavailable"
            fi
        fi
        printf '%s\t%s\t%s\t%s\n' "$project" "$lock" "$manifest" "$status" \
            >> "$out/node-environments.tsv"
        printf 'node\t%s\t%s\t%s\n' "$project" "$status" "$detail" >> "$health"
    done < "$discovery"
}

collect_rust_provenance() {
    local out="$1" health="$2" discovery="$3" kind manifest project lock status detail tool
    tool=$(operator_tool rustup || true)
    [[ -z "$tool" ]] || run_as_operator "$tool" toolchain list -v \
        > "$out/rust-toolchains.txt" 2>/dev/null || true
    tool=$(operator_tool cargo || true)
    [[ -z "$tool" ]] || run_as_operator "$tool" install --list \
        > "$out/cargo-installed.txt" 2>/dev/null || true
    printf 'project\tlockfile\tstatus\n' > "$out/rust-projects.tsv"
    while IFS=$'\t' read -r -d '' kind manifest; do
        [[ "$kind" == rust ]] || continue
        project=${manifest%/Cargo.toml}
        lock="$project/Cargo.lock"
        if [[ -f "$lock" ]]; then
            status=exact
            detail="Cargo.lock preserved"
        else
            lock=""
            status=partial
            detail="Cargo manifest preserved without a lockfile"
        fi
        printf '%s\t%s\t%s\n' "$project" "$lock" "$status" >> "$out/rust-projects.tsv"
        printf 'rust\t%s\t%s\t%s\n' "$project" "$status" "$detail" >> "$health"
    done < "$discovery"
}

collect_huggingface_provenance() {
    local root="$1" out="$2" health="$3" hub cache name kind repo_id ref revision found
    hub="$root/.cache/huggingface/hub"
    printf 'type\trepository\tref\trevision\tcache_path\n' > "$out/huggingface-cache.tsv"
    [[ -d "$hub" ]] || return 0

    while IFS= read -r -d '' cache; do
        name=${cache##*/}
        kind=${name%%--*}
        repo_id=${name#*--}
        repo_id=${repo_id//--//}
        found=0
        if [[ -d "$cache/refs" ]]; then
            while IFS= read -r -d '' ref; do
                revision=$(single_line < "$ref")
                printf '%s\t%s\t%s\t%s\t%s\n' "$kind" "$repo_id" \
                    "${ref#"$cache/refs/"}" "$revision" "$cache" >> "$out/huggingface-cache.tsv"
                found=1
            done < <(find "$cache/refs" -type f -print0 2>/dev/null)
        fi
        if ((found == 0)) && [[ -d "$cache/snapshots" ]]; then
            while IFS= read -r -d '' revision; do
                printf '%s\t%s\t%s\t%s\t%s\n' "$kind" "$repo_id" snapshot \
                    "${revision##*/}" "$cache" >> "$out/huggingface-cache.tsv"
                found=1
            done < <(find "$cache/snapshots" -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
        fi
        if ((found == 1)); then
            printf 'huggingface\t%s\texact\trepository revision captured\n' "$cache" >> "$health"
        else
            printf 'huggingface\t%s\tunknown\tno cached revision found\n' "$cache" >> "$health"
        fi
    done < <(find "$hub" -mindepth 1 -maxdepth 1 -type d \
        \( -name 'models--*' -o -name 'datasets--*' -o -name 'spaces--*' \) -print0 2>/dev/null)
}

refresh_provenance() (
    local out="$STATE_DIR/provenance" src repo path origin branch head dirty kind tool
    local discovery
    local -a sources=()
    mkdir -p "$out"
    discovery=$(mktemp "${TMPDIR:-/tmp}/backup-discovery.XXXXXXXX")
    trap 'rm -f "$discovery"' EXIT
    mapfile -t sources < <(read_path_list "$CONF_DIR/sources")
    ((${#sources[@]} > 0)) || die "no backup sources configured"

    {
        printf 'generated_at\t%s\n' "$(date --iso-8601=seconds)"
        printf 'host\t%s\n' "$(detect_host)"
        printf 'max_file_size\t%s\n' "$MAX_FILE_SIZE"
        printf 'repository\t%s\n' "$RESTIC_REPOSITORY"
    } > "$out/backup-policy.tsv"

    apt-mark showmanual > "$out/apt-manual.txt" 2>/dev/null || true
    dpkg-query -W -f='${binary:Package}\t${Version}\n' > "$out/deb-versions.tsv" 2>/dev/null || true
    snap list > "$out/snap-list.txt" 2>/dev/null || true
    tool=$(operator_tool pipx || true)
    [[ -z "$tool" ]] || run_as_operator "$tool" list --json \
        > "$out/pipx-list.json" 2>/dev/null || true
    docker image ls --digests --format '{{.Repository}}\t{{.Tag}}\t{{.Digest}}\t{{.ID}}' \
        > "$out/docker-images.tsv" 2>/dev/null || true
    lsblk --json --output NAME,SIZE,FSTYPE,UUID,MOUNTPOINTS > "$out/block-devices.json" 2>/dev/null || true
    systemctl list-unit-files --state=enabled --no-legend > "$out/enabled-units.txt" 2>/dev/null || true

    discover_environments "${sources[0]}" "$discovery"
    printf 'ecosystem\tpath\tstatus\tdetail\n' > "$out/reconstruction-health.tsv"
    collect_python_provenance "$out" "$out/reconstruction-health.tsv" "$discovery"
    collect_node_provenance "${sources[0]}" "$out" "$out/reconstruction-health.tsv" "$discovery"
    collect_rust_provenance "$out" "$out/reconstruction-health.tsv" "$discovery"
    collect_huggingface_provenance "${sources[0]}" "$out" "$out/reconstruction-health.tsv"
    {
        printf 'ecosystem\tstatus\tcount\n'
        awk -F '\t' 'NR > 1 { count[$1 FS $3]++ } END {
            for (key in count) print key FS count[key]
        }' "$out/reconstruction-health.tsv" | sort
    } > "$out/reconstruction-summary.tsv"

    local large_tmp="$out/large-files.unsorted.tsv"
    : > "$large_tmp"
    for src in "${sources[@]}"; do
        [[ -e "$src" ]] || continue
        find "$src" -xdev -type f -size "+${MAX_FILE_SIZE}" \
            -printf '%s\t%T@\t%p\n' 2>/dev/null >> "$large_tmp" || true
    done
    {
        printf 'bytes\tmodified_epoch\tpath\n'
        sort -n "$large_tmp"
    } > "$out/large-files.tsv"
    rm -f "$large_tmp"

    : > "$out/git-repositories.tsv"
    printf 'path\torigin\tbranch\thead\tdirty_entries\n' >> "$out/git-repositories.tsv"
    tool=$(operator_tool git || true)
    while IFS=$'\t' read -r -d '' kind repo; do
        [[ "$kind" == git ]] || continue
        path=${repo%/.git}
        [[ -n "$tool" ]] || continue
        origin=$(run_as_operator "$tool" -C "$path" remote get-url origin 2>/dev/null || true)
        branch=$(run_as_operator "$tool" -C "$path" branch --show-current 2>/dev/null || true)
        head=$(run_as_operator "$tool" -C "$path" rev-parse HEAD 2>/dev/null || true)
        dirty=$({ run_as_operator "$tool" -C "$path" status --porcelain -uno \
            2>/dev/null || true; } | wc -l)
        printf '%s\t%s\t%s\t%s\t%s\n' "$path" "$origin" "$branch" "$head" "$dirty" \
            >> "$out/git-repositories.tsv"
    done < "$discovery"
)

run_backup() (
    trap 'exit 130' INT
    trap 'exit 143' TERM

    require_root
    command -v restic >/dev/null 2>&1 || die "restic is not installed"
    command -v flock >/dev/null 2>&1 || die "flock is not installed"
    load_config

    mkdir -p "$(dirname "$LOCK_FILE")"
    exec 9> "$LOCK_FILE"
    flock -n 9 || die "another backup operation is already running"

    refresh_provenance

    local -a sources=() whitelist=() exclude_args=()
    local automatic_rc=0 whitelist_rc=0 failure_rc=0
    mapfile -t sources < <(read_path_list "$CONF_DIR/sources")
    ((${#sources[@]} > 0)) || die "no backup sources configured"
    [[ -s "$CONF_DIR/excludes" ]] && exclude_args=(--exclude-file "$CONF_DIR/excludes")

    restic_cmd backup --host "$(detect_host)" --tag automatic --one-file-system \
        --exclude-larger-than "$MAX_FILE_SIZE" "${exclude_args[@]}" "${sources[@]}" \
        || automatic_rc=$?

    mapfile -t whitelist < <(read_path_list "$CONF_DIR/large-whitelist")
    if ((${#whitelist[@]} > 0)); then
        local -a existing=()
        local item
        for item in "${whitelist[@]}"; do
            [[ -e "$item" ]] && existing+=("$item") || warn "whitelist path missing: ${item}"
        done
        if ((${#existing[@]} > 0)); then
            restic_cmd backup --host "$(detect_host)" --tag large-whitelist \
                --one-file-system "${existing[@]}" || whitelist_rc=$?
        fi
    fi

    if ((automatic_rc == 3)); then
        warn "automatic snapshot completed with unreadable source files"
    elif ((automatic_rc != 0)); then
        failure_rc=$automatic_rc
    fi
    if ((whitelist_rc == 3)); then
        warn "large-whitelist snapshot completed with unreadable source files"
    elif ((whitelist_rc != 0 && failure_rc == 0)); then
        failure_rc=$whitelist_rc
    fi
    ((failure_rc == 0)) || return "$failure_rc"

    restic_cmd forget --host "$(detect_host)" \
        --keep-daily "$KEEP_DAILY" --keep-weekly "$KEEP_WEEKLY" \
        --keep-monthly "$KEEP_MONTHLY" --keep-yearly "$KEEP_YEARLY" --prune
    restic_cmd check
)

write_systemd_units() {
    local executable="$1" host="$2"
    mkdir -p "$SYSTEMD_DIR"
    remove_legacy_systemd_artifacts

    cat > "$SYSTEMD_DIR/backup.service" <<UNIT
[Unit]
Description=Incremental backup and repository maintenance for ${host} over SFTP
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=${executable} run
Nice=19
IOSchedulingClass=idle
CPUSchedulingPolicy=idle
CPUWeight=10
IOWeight=10
MemoryHigh=4G
MemoryMax=8G
Environment=GOMAXPROCS=2
Environment=RESTIC_READ_CONCURRENCY=1
TimeoutStartSec=12h
TimeoutStopSec=10min
KillSignal=SIGINT
UNIT

    cat > "$SYSTEMD_DIR/backup.timer" <<'UNIT'
[Unit]
Description=Daily incremental backup and repository maintenance

[Timer]
OnCalendar=*-*-* 09:00:00
RandomizedDelaySec=15min
Persistent=false

[Install]
WantedBy=timers.target
UNIT
}

remove_legacy_nfs() {
    umount -l /mnt/bingus-backups 2>/dev/null || true
    if [[ -f /etc/fstab ]]; then
        sed -i '\|[[:space:]]/mnt/bingus-backups[[:space:]]|d' /etc/fstab
    fi
    rm -f /usr/local/bin/backup-daily /usr/local/bin/backup-weekly
}

remove_legacy_systemd_artifacts() {
    rm -f "$SYSTEMD_DIR/backup-daily.service" "$SYSTEMD_DIR/backup-daily.timer" \
        "$SYSTEMD_DIR/backup-weekly.service" "$SYSTEMD_DIR/backup-weekly.timer" \
        "$SYSTEMD_DIR/timers.target.wants/backup-daily.timer" \
        "$SYSTEMD_DIR/timers.target.wants/backup-weekly.timer"
}

prepare_backup_units() {
    local unit

    systemctl disable backup.timer 2>/dev/null || true
    for unit in backup-daily.timer backup-weekly.timer; do
        systemctl disable "$unit" 2>/dev/null || true
    done
    rm -f "$SYSTEMD_DIR/timers.target.wants/backup-daily.timer" \
        "$SYSTEMD_DIR/timers.target.wants/backup-weekly.timer"

    for unit in backup.timer backup-daily.timer backup-daily.service \
        backup-weekly.timer backup-weekly.service; do
        systemctl stop --no-block "$unit" 2>/dev/null || true
    done
}

stop_backup_units() {
    prepare_backup_units
    systemctl stop --no-block backup.service 2>/dev/null || true
}

reload_and_reset_legacy_units() {
    local unit

    systemctl daemon-reload
    for unit in backup-daily.service backup-daily.timer \
        backup-weekly.service backup-weekly.timer; do
        systemctl reset-failed "$unit" 2>/dev/null || true
    done
}

install_restic_standalone() (
    set -e
    local version=0.19.1 arch checksum asset archive binary install_path
    [[ "$(uname -s)" == Linux ]] || die "automatic Restic installation only supports Linux"
    case "$(uname -m)" in
        x86_64|amd64)
            arch=amd64
            checksum=f415415624dcc452f2a02b8c33641791a8c6d6d3b65bbb3543fcf9a25151585c
            ;;
        aarch64|arm64)
            arch=arm64
            checksum=a5f64aaab53d51e311fa3829124c5b703f2d14cf187d8640b6be3b2b49376465
            ;;
        *) die "unsupported architecture for Restic: $(uname -m)" ;;
    esac

    command -v apt-get >/dev/null 2>&1 || die "install Restic 0.17 or newer, then retry"
    local packages=()
    command -v curl >/dev/null 2>&1 || packages+=(ca-certificates curl)
    command -v bzip2 >/dev/null 2>&1 || packages+=(bzip2)
    ((${#packages[@]} == 0)) || apt-get install -y "${packages[@]}"

    asset="restic_${version}_linux_${arch}.bz2"
    archive=$(mktemp)
    binary=$(mktemp)
    trap 'rm -f -- "$archive" "$binary"' EXIT
    curl --fail --location --retry 3 \
        --output "$archive" "https://github.com/restic/restic/releases/download/v${version}/${asset}"
    printf '%s  %s\n' "$checksum" "$archive" | sha256sum --check --status - \
        || die "Restic release checksum verification failed"
    bzip2 --decompress --stdout "$archive" > "$binary"
    install_path=${RESTIC_INSTALL_PATH:-/usr/local/bin/restic}
    mkdir -p "$(dirname "$install_path")"
    install -m 0755 "$binary" "$install_path"
)

install_restic() {
    if ! command -v restic >/dev/null 2>&1; then
        command -v apt-get >/dev/null 2>&1 || die "install Restic 0.17 or newer, then retry"
        apt-get install -y restic
    fi
    if restic --help 2>/dev/null | grep -q -- '--insecure-no-password'; then
        return 0
    fi

    info "installing current Restic for empty-password repository support..."
    install_restic_standalone
    hash -r
    restic --help 2>/dev/null | grep -q -- '--insecure-no-password' || \
        die "Restic 0.17 or newer is required"
}

verify_bingus_host_key() {
    local repository_host
    command -v ssh-keygen >/dev/null 2>&1 || die "ssh-keygen is required"
    [[ "$RESTIC_REPOSITORY" == sftp:* ]] || die "repository is not an SFTP URL"
    repository_host=${RESTIC_REPOSITORY#sftp:}
    repository_host=${repository_host%%:*}
    repository_host=${repository_host##*@}
    if ! ssh-keygen -F "$repository_host" -f "$SFTP_KNOWN_HOSTS" >/dev/null 2>&1; then
        die "${repository_host} is absent from ${SFTP_KNOWN_HOSTS}; verify its fingerprint manually and add the key before enabling backup"
    fi
}

cmd_enable() {
    require_root
    local host user home executable
    host=$(detect_host)
    IFS=$'\t' read -r user home < <(operator_identity)
    executable=$(readlink -f "$0")

    install_restic
    write_default_policy "$host" "$user" "$home"
    load_config
    verify_bingus_host_key

    prepare_backup_units
    remove_legacy_nfs

    if ! restic_cmd cat config >/dev/null 2>&1; then
        info "initializing Restic repository on bingus..."
        restic_cmd init
    fi

    write_systemd_units "$executable" "$host"
    reload_and_reset_legacy_units
    systemctl enable --now backup.timer
    info "backup enabled: incremental Restic over SFTP (daily around 09:00)"
    info "policy: ${CONF_DIR}/config, ${CONF_DIR}/sources, ${CONF_DIR}/excludes, ${CONF_DIR}/large-whitelist"
}

cmd_disable() {
    require_root
    stop_backup_units
    rm -f "$SYSTEMD_DIR/backup.service" "$SYSTEMD_DIR/backup.timer"
    remove_legacy_systemd_artifacts
    reload_and_reset_legacy_units
    remove_legacy_nfs
    info "backup schedule disabled; configuration, repository, and legacy /bak data retained"
}

cmd_status() {
    echo "host:      $(detect_host)"
    echo "transport: SFTP"
    if [[ -r "$CONF_DIR/config" ]]; then
        # shellcheck disable=SC1090
        source "$CONF_DIR/config"
        echo "repository: ${RESTIC_REPOSITORY:-not-configured}"
        echo "threshold:  ${MAX_FILE_SIZE:-20M}"
        echo "access:     empty-password"
    else
        echo "repository: not-configured"
    fi
    command -v restic >/dev/null 2>&1 && echo "restic:     $(restic version)" || echo "restic:     not-installed"
    local state next
    state=$(systemctl is-active backup.timer 2>/dev/null || true)
    [[ -n "$state" ]] || state=not-installed
    next=$(systemctl show -p NextElapseUSecRealtime --value backup.timer 2>/dev/null || true)
    echo "backup:    ${state}${next:+ (next: ${next})}"
    [[ ! -e /bak ]] || echo "legacy:     /bak retained (not used by this backup)"
}

cmd_snapshots() {
    require_root
    load_config
    restic_cmd snapshots
}

cmd_restore() {
    require_root
    local snapshot="${1:-latest}" target="${2:-$RECOVERY_DIR/$(date +%Y%m%d-%H%M%S)}" fstype
    load_config
    mkdir -p "$target"
    fstype=$(findmnt -no FSTYPE --target "$target" 2>/dev/null || true)
    [[ "$fstype" != tmpfs ]] || warn "restore target is memory-backed tmpfs: ${target}"
    restic_cmd restore "$snapshot" --target "$target"
    info "restored ${snapshot} to ${target}"
}

cmd_trigger() {
    case "${1:-backup}" in
        backup) run_backup ;;
        check)
            require_root
            load_config
            mkdir -p "$(dirname "$LOCK_FILE")"
            exec 9> "$LOCK_FILE"
            flock -n 9 || die "another backup operation is already running"
            restic_cmd check
            ;;
        *) die "trigger must be backup or check" ;;
    esac
}

usage() {
    cat <<HELP
Usage: ${NAME} <command> [args]

Commands:
  enable                         Configure SFTP/Restic and enable the daily timer
  disable                        Disable the timer; preserve config and data
  status                         Show local configuration and schedule
  trigger [backup|check]
  snapshots                      List available snapshots
  restore [snapshot] [target]    Restore a snapshot (default: latest)
  help                           Show this message

Policy files:
  ${CONF_DIR}/config             Size limit, repository, upload and retention settings
  ${CONF_DIR}/sources            Roots included automatically
  ${CONF_DIR}/excludes           Disposable paths excluded at any size
  ${CONF_DIR}/large-whitelist    Large paths that override both rules
HELP
}

if [[ "${BACKUP_SOURCE_ONLY:-0}" != 1 ]]; then
    cmd="${1:-help}"
    (($# == 0)) || shift
    case "$cmd" in
        enable) cmd_enable ;;
        disable) cmd_disable ;;
        status) cmd_status ;;
        run) run_backup ;;
        trigger) cmd_trigger "${1:-backup}" ;;
        snapshots) cmd_snapshots ;;
        restore) cmd_restore "$@" ;;
        help|--help|-h) usage ;;
        *) die "unknown command. Try '${NAME} help'." ;;
    esac
fi
